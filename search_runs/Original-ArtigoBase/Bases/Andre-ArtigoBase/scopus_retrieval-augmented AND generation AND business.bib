@CONFERENCE{Bernardi2024413,
	author = {Bernardi, Mario Luca and Casciani, Angelo and Cimitile, Marta and Marrella, Andrea},
	title = {A preliminary study on Business Process-aware Large Language Models},
	year = {2024},
	journal = {CEUR Workshop Proceedings},
	volume = {3762},
	pages = {413 – 418},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85205583365&partnerID=40&md5=43312e342527495bdea8a510dfc164f2},
	affiliations = {Department of Engineering, University of Sannio, Piazza Roma 21, Benevento, 82100, Italy; Department of Computer, Control and Management Engineering, Sapienza University of Rome, Via Ariosto 25, Rome, 00185, Italy; Department of Law and Digital Society, UnitelmaSapienza, Piazza Sassari, Rome, 00185, Italy},
	abstract = {AI-Augmented Business Process Management Systems (ABPMSs) are innovative information systems with increased flexibility, autonomy, and conversational capability. These systems can be boosted by Large Language Models (LLMs), renowned for their ability to handle natural language processing tasks. Nevertheless, no significant empirical validations exist about their usefulness in process-driven decision support. In this study, we propose a business process-oriented LLM framework, for enacting actionable conversations with workers involved in a business process, leveraging Retrieval-Augmented Generation (RAG) to enrich process-specific knowledge. The methodology has been assessed to evaluate its capacity to produce precise responses to inquiries posed by users within a public administration context. The preliminary study shows the framework’s ability to identify specific activities and sequence flows within the targeted process model, thereby providing valuable insights into its potential for improving ABPMSs. © 2024 Copyright for this paper by its authors.},
	author_keywords = {Business Process; Decision Support Systems; Large Language Models; Retrieval-Augmented Generation},
	keywords = {Enterprise resource management; Information management; Natural language processing systems; Business Process; Business process management systems; Decision supports; Increased flexibility; Language model; Language processing; Large language model; Natural languages; Retrieval-augmented generation; Support systems; Decision support systems},
	correspondence_address = {A. Casciani; Department of Computer, Control and Management Engineering, Sapienza University of Rome, Rome, Via Ariosto 25, 00185, Italy; email: angelo.casciani@uniroma1.it},
	editor = {Di Martino S. and University of Naples Federico II, Department of Electrical Engineering and Information Technology (DIETI), Via Claudio 21, Naples and Sansone C. and University of Naples Federico II, Department of Electrical Engineering and Information Technology (DIETI), Via Claudio 21, Naples and Masciari E. and University of Naples Federico II, Department of Electrical Engineering and Information Technology (DIETI), Via Claudio 21, Naples and Rossi S. and University of Naples Federico II, Department of Electrical Engineering and Information Technology (DIETI), Via Claudio 21, Naples and Gravina M. and University of Naples Federico II, Department of Electrical Engineering and Information Technology (DIETI), Via Claudio 21, Naples},
