}

@CONFERENCE{Zhang2024738,
	author = {Zhang, Tianyang and Jiang, Zhuoxuan and Bai, Shengguang and Zhang, Tianrui and Lin, Lin and Liu, Yang and Ren, Jiawei},
	title = {RAG4ITOps: A Supervised Fine-Tunable and Comprehensive RAG Framework for IT Operations and Maintenance},
	year = {2024},
	journal = {EMNLP 2024 - 2024 Conference on Empirical Methods in Natural Language Processing, Proceedings of the Industry Track},
	pages = {738 – 754},
	doi = {10.18653/v1/2024.emnlp-industry.56},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85216798011&doi=10.18653%2fv1%2f2024.emnlp-industry.56&partnerID=40&md5=2403164c33542d3f587a1e4270e63ec6},
	affiliations = {Learnable.ai, Shanghai, China; Shanghai Business School, Shanghai, China; University of North Carolina Greensboro, Greensboro, NC, United States; Skema Business School, Paris, France; North Carolina Central University, Durham, NC, United States},
	abstract = {With the ever-increasing demands on Question Answering (QA) systems for IT operations and maintenance, an efficient and supervised fine-tunable framework is necessary to ensure the data security, private deployment and continuous upgrading. Although Large Language Models (LLMs) have notably improved the open-domain QA’s performance, how to efficiently handle enterprise-exclusive corpora and build domain-specific QA systems are still less-studied for industrial applications. In this paper, we propose a general and comprehensive framework based on Retrieval Augmented Generation (RAG) and facilitate the whole business process of establishing QA systems for IT operations and maintenance. In accordance with the prevailing RAG method, our proposed framework, named with RAG4ITOps, composes of two major stages: (1) Models Fine-tuning & Data Vectorization, and (2) Online QA System Process. At the Stage 1, we leverage a contrastive learning method with two negative sampling strategies to fine-tune the embedding model, and design the instruction templates to fine-tune the LLM with a Retrieval Augmented Fine-Tuning method. At the Stage 2, an efficient process of QA system is built for serving. We collect enterprise-exclusive corpora from the domain of cloud computing, and the extensive experiments show that our method achieves superior results than counterparts on two kinds of QA tasks. Our experiment also provide a case for applying the RAG4ITOps to real-world enterprise-level applications. © 2024 Association for Computational Linguistics.},
	keywords = {Contrastive Learning; Metadata; Network security; Problem oriented languages; Supervised learning; Business Process; Domain specific; Fine tuning; Generation method; Language model; Open domain question answering; Operations and maintenance; Performance; Question answering systems; Tunables; Computational linguistics},
	correspondence_address = {Z. Jiang; Shanghai Business School, Shanghai, China; email: jzx@sbs.edu.cn},
	editor = {Dernoncourt F. and Preotiuc-Pietro D. and Shimorina A.},
	publisher = {Association for Computational Linguistics (ACL)},
	isbn = {979-889176166-7},
	language = {English},
	abbrev_source_title = {EMNLP - Conf. Empir. Methods Nat. Lang. Process., Proc. Ind. Track},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; Conference name: 2024 Conference on Empirical Methods in Natural Language Processing, EMNLP 2024; Conference date: 12 November 2024 through 16 November 2024; Conference code: 205881; All Open Access, Green Open Access}
}