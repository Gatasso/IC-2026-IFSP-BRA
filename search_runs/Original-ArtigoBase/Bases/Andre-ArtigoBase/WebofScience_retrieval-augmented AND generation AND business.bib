@inproceedings{ WOS:001363176200012,
Author = {Agliata, Antonio and Pilato, Antonio and Mariacarmen, Sorrentino and
   Bottiglieri, Salvatore and Di Nardo, Emanuel and Ciaramella, Angelo},
