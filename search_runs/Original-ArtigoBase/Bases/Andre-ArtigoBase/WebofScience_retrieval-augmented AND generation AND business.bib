@inproceedings{ WOS:001324524205058,
Author = {Liu, Xuanqing and Wang, Runhui and Song, Yang and Kong, Luyang},
Book-Group-Author = {ASSOC COMPUTING MACHINERY},
Title = {GRAM: Generative Retrieval Augmented Matching of Data Schemas in the
   Context of Data Security},
