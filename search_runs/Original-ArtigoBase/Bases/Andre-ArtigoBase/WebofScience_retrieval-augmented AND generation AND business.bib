
@article{ WOS:001262366300009,
Author = {Posedaru, Bogdan-Stefan and Pantelimon, Florin-Valeriu and Dulgheru,
   Mihai-Nicolae and Georgescu, Tiberiu-Marian},
Title = {Artificial Intelligence Text Processing Using Retrieval-Augmented
   Generation: Applications in Business and Education Fields},
