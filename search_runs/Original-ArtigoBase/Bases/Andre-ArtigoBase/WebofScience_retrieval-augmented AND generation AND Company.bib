Title = {Information Extraction from Sustainability Reports in Turkish through
   RAG Approach},
Booktitle = {32ND IEEE SIGNAL PROCESSING AND COMMUNICATIONS APPLICATIONS CONFERENCE,
   SIU 2024},
Series = {Signal Processing and Communications Applications Conference},
Year = {2024},
Note = {32nd IEEE Signal Processing and Communications Applications Conference
   (SIU), Tarsus Univ Campus, Mersin, TURKEY, MAY 15-18, 2024},
Organization = {IEEE; IEEE Turkey; Koluman \& Berdan; Loodos; Figes; Turkcell; Yildirim
   Elect},
Abstract = {Sustainability plays a central role in addressing global challenges,
   encompassing environmental, economic, and social principles.
   Sustainability reports evaluate organizations' environmental impacts,
   social responsibilities, and adherence to governance principles,
   ensuring transparency. In this study, Retrieval Augmented Generation
   (RAG) technology is employed to assess the Turkish sustainability
   reports of 10 companies listed in the BIST Sustainability-25 index in
   terms of ESG (Environmental, Social, Governance) factors. Information
   retrieval is conducted producing 47 prompts related to ESG criteria. The
   BM25 and BERTurk approaches identify the most relevant sections in
   sustainability reports, which are then input into the GPT3.5-Turbo
   model. According to the results obtained, it is seen that using the BM25
   method performed better than BERTurk when extracting information from
   documents with the RAG approach.},
