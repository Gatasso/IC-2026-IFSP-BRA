ISSN = {0742-597X},
EISSN = {1943-5479},
Keywords = {Construction regulation; Quality compliance check; Retrieval-augmented
   generation (RAG); Term frequency-inverse document frequency (TF-IDF);
   Large language model (LLM)},
Keywords-Plus = {AUTOMATED INFORMATION EXTRACTION; CODE COMPLIANCE CHECKING; SEMANTIC
