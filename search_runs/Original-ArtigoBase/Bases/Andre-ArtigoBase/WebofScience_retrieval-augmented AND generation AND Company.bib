@article{ WOS:001375649500003,
Author = {Zhang, Liuhong and Li, Shixuan and Peng, Hongxing},
Title = {Lora for dense passage retrieval of ConTextual masked auto-encoding},
Journal = {SIGNAL IMAGE AND VIDEO PROCESSING},
Year = {2025},
