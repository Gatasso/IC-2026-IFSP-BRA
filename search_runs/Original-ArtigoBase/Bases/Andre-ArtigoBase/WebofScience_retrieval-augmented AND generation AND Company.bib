@inproceedings{ WOS:001312816100037,
Author = {Liu, Chang and Hoang, Loc and Stolman, Andrew and Wu, Bo},
Editor = {Olney, AM and Chounta, IA and Liu, Z and Santos, OC and Bittencourt, II},
Title = {HiTA: A RAG-Based Educational Platform that Centers Educators in the
   Instructional Loop},
