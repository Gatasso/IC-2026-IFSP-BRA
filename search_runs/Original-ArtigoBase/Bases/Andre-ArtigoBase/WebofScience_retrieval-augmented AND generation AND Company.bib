   Leng, Shaolong; Wei, Song, Sichuan Juhong Bldg Mat Co Ltd, 20 Huangshijing Rd, Neijiang 641005, Sichuan, Peoples R China.},
DOI = {10.1061/JMENEA.MEENG-6444},
