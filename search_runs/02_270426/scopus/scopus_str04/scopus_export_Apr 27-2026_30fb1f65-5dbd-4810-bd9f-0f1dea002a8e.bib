	note = {Cited by: 0; Conference name: 25th International Conference on Electronic Business, ICEB 2025; Conference sponsors: AISNET.ORG#; DAI HOC KINH TE QUOC DAN  NEU#; ICEBNET.ORG#; WAIKATO#; Conference code: 341979; Conference date: 21 August 2025 through 25 August 2025}
}

@ARTICLE{Holvoet2025224,
