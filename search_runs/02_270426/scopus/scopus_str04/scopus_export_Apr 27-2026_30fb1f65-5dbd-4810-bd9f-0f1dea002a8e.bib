	keywords = {Digital storage; Embeddings; Extraction; Information retrieval; Information retrieval systems; Information use; Knowledge graph; Knowledge management; Query processing; Question answering; Regulatory compliance; Search engines; Agentic RAG; Knowledge graphs; Legal documents; Legal questions; Legal system; Question Answering; Regulation compliance; Regulatory level; Retrieval-augmented generation; Semantic retrieval; Semantics},
