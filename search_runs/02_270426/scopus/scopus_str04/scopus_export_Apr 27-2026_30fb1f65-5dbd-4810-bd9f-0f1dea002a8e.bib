@CONFERENCE{Radhamani2025,
	author = {Radhamani, V. and Blessie, E Chandra and Nithya, S. and Dharssini, K. and Prasannapathi, S.},
	title = {A Comparative Evaluation of Knuth-Morris-Pratt Algorithm and Large Language Models with Retrieval Augmented Generation},
