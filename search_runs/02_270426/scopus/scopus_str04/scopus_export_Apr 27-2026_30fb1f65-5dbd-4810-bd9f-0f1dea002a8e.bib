	keywords = {Failure analysis; Fatigue of materials; Fault detection; Graph theory; Intelligent agents; Learning systems; Life cycle assessment; Service life; Alert life-cycle; Alert reduction; Cloud systems; Current system; Graph model; Language model; Large-scales; Lifecycle management; Operational efficiencies; Users' experiences; Multi agent systems},
