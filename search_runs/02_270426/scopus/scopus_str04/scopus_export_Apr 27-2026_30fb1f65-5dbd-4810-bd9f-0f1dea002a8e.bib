@ARTICLE{Shimizu2025787,
	author = {Shimizu, Takayuki and Kanai, Hideaki},
	title = {Attitudinal Changes in Self-Disclosure Through Chatbots in Career Guidance: Factors Encouraging Disclosure Difficulties Among Students Needing Support},
	year = {2025},
	journal = {Applied Human Factors and Ergonomics International},
	volume = {199},
