@ARTICLE{Hu2025109,
	author = {Hu, Zhengbing and Paprotskyi, Markiian-Mykhailo and Vysotska, Victoria and Chyrun, Lyubomyr and Ushenko, Yuriy and Uhryn, Dmytro},
	title = {Local Agentic RAG-Based Information System Development for Intelligent Analysis of GitHub Code Repositories in Computer Science Education},
	year = {2025},
	journal = {International Journal of Modern Education and Computer Science},
	volume = {17},
