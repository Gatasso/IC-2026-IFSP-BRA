@CONFERENCE{Rackauckas202492,
	author = {Rackauckas, Zackary and Câmara, Arthur and Zavrel, Jakub},
	title = {Evaluating RAG-Fusion with RAGElo: an Automated Elo-based Framework},
	year = {2024},
	journal = {CEUR Workshop Proceedings},
	volume = {3752},
