	affiliations = {School of Artificial Intelligence, Chongqing Technology and Business University Chongqing, Chongqing, China},
	abstract = {Accurately identifying whether cross-border e-commerce product listings comply with regulations is essential for reducing business risks, ensuring the orderly growth of cross-border trade, and promoting a standardized global e-commerce market. However, current methods on cross-border e-commerce platforms heavily rely on manual reviews, which face challenges such as low accuracy, inefficiency, and difficulty in retrieving relevant policy documents. To address these challenges, this paper proposes a novel compliance identification model framework for cross-border e-commerce product listings that integrates Large Language Models and hybrid retrieval technology (LLM-HRT-CEPCI). The model combines Large Language Models, multi-level policy vector database construction, hybrid retrieval, and retrieval-augmented generation technology to achieve accurate clause matching and automated compliance judgment. Experimental results demonstrate that the model’s hybrid retrieval module significantly outperforms single retrieval methods, with an F<sub>1</sub>-score of 0.7342, Precision of 0.7429, and Recall of 0.7383. The model effectively resolves semantic ambiguities in complex policy scenarios, providing an accurate and practical compliance review solution for cross-border e-commerce platforms. This work offers valuable support for reducing enterprise risks and advancing the digital transformation of cross-border trade. © 2025 Copyright held by the owner/author(s).},
