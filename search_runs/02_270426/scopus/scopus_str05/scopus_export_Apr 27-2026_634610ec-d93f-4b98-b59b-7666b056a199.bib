@ARTICLE{Chu2025,
	author = {Chu, Shiwei and Liu, Jie},
	title = {Based on BERT-GPT-GNN converged architecture: intelligent generation engine for complex SQL queries in business intelligence},
	year = {2025},
	journal = {Discover Artificial Intelligence},
	volume = {5},
	number = {1},
	pages = {},
