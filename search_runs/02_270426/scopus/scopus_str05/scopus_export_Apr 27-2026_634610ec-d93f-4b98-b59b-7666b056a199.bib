@CONFERENCE{Rajendran20251530,
	author = {Rajendran, Ravi K. and Debnath, Biplob and Sankaradas, Murugan and Chakradhar, Srimat T.},
	title = {EcoDoc: A Cost-Efficient Multimodal Document Processing System for Enterprises Using LLMs},
	year = {2025},
	journal = {Proceedings of the Annual Meeting of the Association for Computational Linguistics},
	volume = {6},
	pages = {1530 - 1537},
