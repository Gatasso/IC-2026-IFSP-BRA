@CONFERENCE{Wang2025137,
	author = {Wang, Kai and Kong, Xianguang and Yin, Lei and Zhang, Yuqi and Hu, Qianyong and Jin, Xiaozheng},
	title = {Research on Framework of Data Rights Confirmation in Industrial Internet},
	year = {2025},
	journal = {2025 5th International Conference on Artificial Intelligence and Industrial Technology Applications, AIITA 2025},
	pages = {137 - 143},
	doi = {10.1109/AIITA65135.2025.11048126},
	url = {https://www.scopus.com/pages/publications/105012096033?origin=resultslist},
	affiliations = {School of Mechano-Electronic, Engineering, Xidian University, Xi'an, China; School of Intelligent Manufacturing and Control Engineering, Shanghai Polytechnic University, Shanghai, China; New York University, Brooklyn, NY, United States; Shaanxi Provincial Science and Technology Resource Coordination Center, Xi'an, China},
	abstract = {The rapid development and widespread application of Industrial Internet have made cross-entity flow, sharing, and integrated utilization of industrial data a necessary path for data valorization in the industrial sector. However, the incomplete mechanisms for industrial data rights management and the lack of refined classification and hierarchical management strategies severely hinder the in-depth exploration of data value. To address these challenges, this study designs an industrial data rights confirmation framework that integrates large language model (LLM) and blockchain technology, based on traditional Industrial Internet platform architectures. Utilizing Retrieval-Augmented Generation (RAG) technology centered on LLM, the framework parses and infers the rights, classification, and security levels of industrial data, enabling dynamic rights confirmation, classification and hierarchical management decisions. Simultaneously, blockchain technology is employed to store and maintain rights confirmation conclusions and management strategies on-chain, ensuring the trusted and traceability of rights information. The proposed technical solution achieves efficient rights confirmation and compliance-driven management decisions for multi-source heterogeneous industrial data, while also providing a foundation for Pursuing liability for infringement, profit distribution, and compliance audits, thereby safeguarding the legitimate rights and interests of enterprises.  © 2025 IEEE.},
