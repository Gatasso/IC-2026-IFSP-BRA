}

@CONFERENCE{Rad2025830,
	author = {Rad, Mohammadreza Shahbazi and Aghajani, Sepideh and Avestam, Mohammad Ali and Roham, Hamid and Yousefabad, Elham Kamouri},
	title = {AI-Driven Antifragile Knowledge Management System: Transforming ERP Simulated Disruptions into Learning Opportunities},
