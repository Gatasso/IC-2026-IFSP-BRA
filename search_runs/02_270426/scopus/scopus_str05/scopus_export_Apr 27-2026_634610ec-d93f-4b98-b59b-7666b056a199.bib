	keywords = {Artificial intelligence; Benchmarking; Classification (of information); Information retrieval; Question answering; Text processing; Agentic application; Chain of action; Enterprise data; LLM; Question Answering; Retrieval; Retrieval-augmented generation; Retrieval-augmented generation benchmark; Retrieval-augmented generation dataset; Semantic search; Semantics},
