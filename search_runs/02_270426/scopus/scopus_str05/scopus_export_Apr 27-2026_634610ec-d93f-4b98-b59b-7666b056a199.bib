@CONFERENCE{Chen2025320,
	author = {Chen, Hao and Bu, Xianglei and Tian, Shupeng},
	title = {Fiscal and Tax QA via Clause-Level Knowledge Graphs and Retrieval-augmented Large Language Models},
	year = {2025},
	journal = {Proceedings of 2025 8th International Conference on Computer Information Science and Artificial Intelligence, CISAI 2025},
	pages = {320 - 324},
	doi = {10.1145/3773365.3773416},
	url = {https://www.scopus.com/pages/publications/105026343729?origin=resultslist},
	affiliations = {State Grid Shanxi Electric Power Co. Ltd, Shanxi, Datong, China},
	abstract = {Power grid enterprises increasingly face the challenge of interpreting complex financial and taxation policies while providing practical operational guidance across diverse jurisdictions and tax categories. Existing methods suffer from imprecise keyword-based retrieval, and they have limited capability in generating structured guidance. To address these issues, we propose a Fiscal and Tax QA via Clause-Level Knowledge Graphs and Retrieval-Grounded Large Language Models. Specifically, we propose a clause-level knowledge graph retrieval method that combines semantic similarity with graph structure by encoding queries and clauses through transformer-based embeddings, retrieving top- candidate clauses via approximate nearest neighbor search, and re-ranking them with a legal consistency module that enforces domain-specific constraints. To generate actionable financial guidance grounded in verified statutes, we propose a retrieval-based LLM framework that produces structured and executable answers by constructing prompts from the re-ranked clauses together with step-by-step instructions, and by applying LoRA-based fine-tuning with light citation constraints to ensure both accuracy and interpretability. Finally, the experimental results demonstrate that our model achieves consistent improvements over baseline methods on two datasets: WebQSP (Hit1 improved by 11.2%, Hit3 by 6.7%, and Hit10 by 3.6%) and GridTax-QA (Hit1 improved by 5.7%, Hit3 by 4.4%, and Hit10 by 2.6%). Our framework advances retrieval and answer generation, providing a foundation for interpretable financial-taxation decision support. © 2025 Copyright held by the owner/author(s).},
	author_keywords = {Fine tuning; Fiscal and Tax; Knowledge Graph; LLMs; QA},
	keywords = {Computational linguistics; Graph structures; Graph theory; Graphic methods; Information management; Information retrieval; Knowledge graph; Nearest neighbor search; Semantics; Structured Query Language; Taxation; Fine tuning; Fiscal and tax; Grid enterprise; Knowledge graphs; Knowledge retrieval; Language model; LLM; Operational guidance; Power grids; QA; Decision support systems},
