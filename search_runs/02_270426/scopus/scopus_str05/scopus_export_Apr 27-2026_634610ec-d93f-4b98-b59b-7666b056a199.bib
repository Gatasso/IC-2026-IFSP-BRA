@CONFERENCE{Wu202645,
	author = {Wu, Shuang and Zhang, Lin and Fan, Xing-Rong and Ran, Jinshan and Zeng, Run and Liu, Bo},
	title = {Cross-border E-commerce Product Listing Compliance Identification by Integrating Large Language Models and Hybrid Retrieval Technology},
	year = {2026},
	journal = {BDIOT 2025 - Proceedings of 2025 9th International Conference on Big Data and Internet of Things},
	pages = {45 - 50},
