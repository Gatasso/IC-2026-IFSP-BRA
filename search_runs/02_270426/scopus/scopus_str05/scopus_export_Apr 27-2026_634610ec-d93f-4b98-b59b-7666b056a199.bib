@ARTICLE{Rustam2026631,
	author = {Rustam, Furqan and Obaidat, Islam and Di Monda, Davide and Jurcut, Anca Delia},
	title = {Few-Shot Retrieval-Augmented LLMs for Anomaly Detection in Network Traffic},
	year = {2026},
	journal = {Lecture Notes in Computer Science},
	volume = {16351 LNCS},
	pages = {631 - 642},
	doi = {10.1007/978-981-95-4434-9_32},
	url = {https://www.scopus.com/pages/publications/105023287764?origin=resultslist},
	affiliations = {School of Computer Science, University College Dublin, Dublin, Ireland; Department of CST, North Carolina A&T State University, Greensboro, United States; University of Napoli Federico II and IMT School of Advanced Studies Lucca, Naples, Italy},
	abstract = {Accurate anomaly detection is essential for protecting heterogeneous multi-environment (M-En) networks, where traditional enterprise traffic coexists with Internet of Things (IoT) flows. Existing machine learning-based anomaly detection approaches rely on extensive labeled data and frequent retraining, and therefore adapt poorly to unseen attack patterns and few-data settings. In this work, a Retrieval-Augmented Generation (RAG) pipeline is introduced in which Large Language Models (LLMs) are guided to classify malicious traffic under few-shot settings. Structured packet-level and statistical features are first rendered into natural-language prompts; dense sentence embeddings are then produced and indexed with FAISS (Facebook AI Similarity Search, an approximate-nearest-neighbour vector index) to construct a vector-based knowledge base. At inference time, the embedding of an unseen packet is used to retrieve a specified number of semantically similar, labeled examples, which are supplied as in-context examples to the LLM. This workflow enables learning over heterogeneous traffic without model fine-tuning, improves generalization, and yields human-readable explanations of each decision. When paired with MPNet embeddings and a context of 200 retrieved examples, the 4B-parameter Gemma3:4b model reaches 1.0 accuracy, while the 7B Mistral model achieves 0.98. Inference takes 23.51 s with Gemma3:4b and 66.7 s with Mistral for 50 samples, both running on a single NVIDIA GeForce RTX 3090 GPU. © The Author(s), under exclusive license to Springer Nature Singapore Pte Ltd. 2026.},
	author_keywords = {Anomaly Detection; LLMs; M-En Networks; Network Security; RAG},
	keywords = {Embeddings; Information retrieval; Internet of things; Knowledge based systems; Labeled data; Natural language processing systems; Nearest neighbor search; Network security; Pattern recognition; Telecommunication traffic; Anomaly detection; Embeddings; In networks; Language model; Large language model; Multi-environment network; Multi-environments; Networks security; Retrieval-augmented generation; Shot retrieval; Anomaly detection},
	correspondence_address = {F. Rustam; School of Computer Science, University College Dublin, Dublin, Ireland; email: furqan.rustam@ucdconnect.ie},
	editor = {Kim Y. and Miyaji A. and Tibouchi M.},
