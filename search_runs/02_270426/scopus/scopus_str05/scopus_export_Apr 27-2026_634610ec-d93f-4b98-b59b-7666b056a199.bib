	title = {Retrieval Augmented Generation (RAG) for Fintech: Agentic Design and Evaluation},
	year = {2025},
	journal = {2025 3rd International Conference on Foundation and Large Language Models, FLLM 2025},
	pages = {93 - 100},
	doi = {10.1109/FLLM67465.2025.11391155},
