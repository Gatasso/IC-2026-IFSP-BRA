	author = {Jeong, Jooyoung and Lee, Sang-Goo},
	title = {Permission-Aware RAG: Identity and Access Management (IAM)-Based Access Filtering in Multi-Resource Environments},
	year = {2025},
	journal = {IEEE Access},
	volume = {13},
	pages = {192819 - 192835},
