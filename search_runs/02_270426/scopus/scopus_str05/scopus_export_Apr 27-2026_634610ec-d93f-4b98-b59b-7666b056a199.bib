@CONFERENCE{Dhanya2025,
	author = {Dhanya, K.R. and Vijayan, N. and Ranjani, R.},
	title = {Smart Agents for Querying: A Multimodal Approach to Natural Language Querying of Diverse Data Sources},
	year = {2025},
	journal = {Conference Proceedings - 2025 IEEE Silchar Subsection Conference, IEEE SILCON 2025},
	pages = {},
