@CONFERENCE{Altinok2026343,
	author = {Altinok, Hatice and Tekgoz, Hilal and Erdogan, Halit and Uz, Harun},
	title = {A Comparative Analysis of Retrieval-Augmented Generation Architectures with Semantic Hashing for Enterprise Knowledge Systems},
	year = {2026},
	journal = {Proceedings - 5th International Conference on Informatics and Software Engineering, IISEC 2026},
	pages = {343 - 347},
	doi = {10.1109/IISEC69317.2026.11418525},
	url = {https://www.scopus.com/pages/publications/105036004867?origin=resultslist},
	affiliations = {Loodos Technology Inc., R&d Center, Istanbul, Turkey},
	abstract = {Large Language Models (LLMs) have significant potential to transform enterprise knowledge management. The Retrieval-Augmented Generation (RAG) architecture has become the industry standard for producing accurate, domain-specific responses while mitigating hallucinations. However, the retrieval stage in standard RAG implementations presents challenges in terms of latency, computational cost, and accuracy when scaling to large document collections. This paper presents a systematic comparative analysis of four distinct RAG retrieval architectures evaluated on a real-world enterprise wiki dataset containing 279 documents across 14 categories. The architectures examined include: (1) Dense Retrieval using FAISS, (2) Hybrid Retrieval combining FAISS with BM25, (3) Semantic Hashing-only retrieval, and (4) a novel two-stage hybrid model employing Semantic Hashing for candidate filtering followed by vector-based reranking. We evaluate these architectures using 84 domain-specific questions, measuring answer accuracy through semantic similarity, query latency, and memory consumption. Our experimental results demonstrate that the two-stage hybrid architecture achieves the highest accuracy rate of 82.14% with a mean response time of 2.96 seconds, outperforming both pure dense retrieval (78.57%) and hybrid BM25 approaches (64.29%). We provide detailed analysis of prompt engineering strategies that contributed to these results and discuss the trade-offs between retrieval speed, accuracy, and resource utilization for enterprise-scale RAG deployments. © 2026 IEEE.},
	author_keywords = {BM25; Enterprise Knowledge Systems; FAISS; Information Retrieval; Large Language Models; Retrieval-Augmented Generation; Semantic Hashing; Vector Search},
	keywords = {Architecture; Cost effectiveness; Enterprise resource management; Information retrieval; Information retrieval systems; Knowledge engineering; Knowledge organization; Memory architecture; Search engines; Semantics; Bm25; Comparative analyzes; Enterprise knowledge system; FAISS; Knowledge system; Language model; Large language model; Retrieval-augmented generation; Semantic hashing; Vector search; Economic and social effects},
