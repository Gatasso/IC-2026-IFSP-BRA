@CONFERENCE{Béchard2024228,
	author = {Béchard, Patrice and Ayala, Orlando Marquez},
	title = {Reducing hallucination in structured outputs via Retrieval-Augmented Generation},
	year = {2024},
	journal = {Proceedings of the 2024 Conference of the North American Chapter of the Association for Computational Linguistics: Human Language Technologies, NAACL 2024},
	volume = {6},
