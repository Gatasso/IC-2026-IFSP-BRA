@ARTICLE{Badurowicz2024175,
	author = {Badurowicz, Marcin and Skulimowski, Stanisław P. and Laskowski, Maciej},
	title = {FEASIBILITY OF USING LOW-PARAMETER LOCAL LLMS IN ANSWERING QUESTIONS FROM ENTERPRISE KNOWLEDGE BASE},
	year = {2024},
	journal = {Applied Computer Science},
	volume = {20},
