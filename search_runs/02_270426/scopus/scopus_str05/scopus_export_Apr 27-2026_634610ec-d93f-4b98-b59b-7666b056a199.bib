	affiliations = {POLIMI Graduate School of Management, Lombardy, Milan, 20156, Italy; Department of Management, Economics and Industrial Engineering, Politecnico di Milano, Lombardy, Milan, 20156, Italy; University of Toronto, Ontario, Toronto, M5S 1A1, Canada; Wuhan Dinyeah Safety and Environment Technology Group Co., Ltd,, Wuhan, Hubeio, 430074, China; SeerTech Consulting OU, Tallinn, 10151, Estonia},
	abstract = {Industrial safety management increasingly relies on decision support that must operate across organizations with different procedures, incentives, and regulatory exposure. We present a Graph-grounded Retrieval-Augmented Generation (G-RAG) method for S2B2C safety platforms, where the platform layer maintains shared knowledge and governance, enterprise units tailor it to assets and jurisdictions, and frontline crews execute task-level procedures. The method combines a Safety Knowledge Graph (Safety-KG) with text corpora and operational signals. It retrieves graph paths and text spans jointly, checks SHACL-like constraints before generation, and selects a budget-feasible control set that targets expected risk reduction while maintaining coverage across control layers. In a simulation study on large synthetic benchmarks, G-RAG improves evidence retrieval (nDCG@10), increases evidence sufficiency for generated claims, reduces compliance violations, and achieves higher expected risk reduction under fixed budgets than text-only and rule-based baselines. The output is audit-ready by design, with each control-level claim linked to a compact set of supporting paths and passages with provenance. © The Author(s) 2026. This article is licensed under a Creative Commons Attribution-NonCommercial-NoDerivatives 4.0 International, which permits the use, sharing, adaptation, distribution and reproduction in any medium or format, as long as appropriate credit to the original author(s) and the source is given by providing a link to the Creative Commons license.  https://creativecommons.org/licenses/by-nc-nd/4.0/.},
