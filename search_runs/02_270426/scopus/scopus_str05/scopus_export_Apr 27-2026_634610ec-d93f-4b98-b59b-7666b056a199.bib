@CONFERENCE{Venkatesan2026291,
	author = {Venkatesan, Vivek and Saha, Pranoy and Vasudevan, Girish and Balakumar, Gayathri and Balu, Gunasekar Pullur},
	title = {Policy-Aware RAG on the Lakehouse: Lineage-Driven Retrieval Over Apache Iceberg on S3 to Reduce Hallucination and Cost},
	year = {2026},
	journal = {2026 IEEE 16th Annual Computing and Communication Workshop and Conference, CCWC 2026},
	pages = {291 - 298},
	doi = {10.1109/CCWC67433.2026.11393771},
	url = {https://www.scopus.com/pages/publications/105035585941?origin=resultslist},
	affiliations = {United States},
	abstract = {Retrieval-Augmented Generation (RAG) systems have become essential for grounding large language model (LLM) responses in enterprise data. However, existing RAG pipelines often operate as ungoverned silos detached from enterprise data contracts, lineage, or compliance controls. This paper proposes a policy-aware RAG framework that integrates directly with Apache Iceberg tables stored on Amazon S3, governed through AWS Glue Catalog metadata and schema evolution. By embedding data at the Iceberg partition level and enforcing lineage-driven retrieval planning, the system guarantees that every retrieved document aligns with valid data contracts and historical context. A prototype implementation demonstrates measurable improvements over baseline RAG systems: +34% grounded-answer accuracy, -29% p90 retrieval latency, and -27% token usage, with a 0% policy violation rate. The architecture achieves this by unifying metadata tagging, vector indexing, and policy-based query planning into a single auditable and reproducible lakehouse pipeline. The evaluation confirms that policy-aware retrieval not only mitigates hallucination risk but also enhances cost efficiency and reproducibility, offering a scalable blueprint for trustworthy enterprisegrade generative AI systems. © 2026 IEEE.},
	author_keywords = {Amazon S3; Apache Iceberg; AWS Glue; data lineage; generative AI governance; policy-aware AI; retrieval-augmented generation},
	keywords = {Big data; Compliance control; Cost effectiveness; Distributed computer systems; Information retrieval; Information retrieval systems; Information systems; Metadata; Sea ice; Search engines; Amazon s3; Apache iceberg; AWS glue; Data contracts; Data lineage; Enterprise data; Generation systems; Generative AI governance; Policy-aware AI; Retrieval-augmented generation; Glues},
