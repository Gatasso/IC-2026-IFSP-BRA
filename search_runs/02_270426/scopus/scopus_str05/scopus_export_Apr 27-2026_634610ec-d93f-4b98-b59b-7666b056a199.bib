@CONFERENCE{Wang2025859,
	author = {Wang, Yanyan and Li, Jiaojiao and Xu, Kuang and Xu, Yin},
	title = {Constructing a Multi-source Heterogeneous RAG Knowledge Q&A Dataset in the Telecom Domain},
	year = {2025},
	journal = {2025 IEEE 5th International Conference on Computer Communication and Artificial Intelligence, CCAI 2025},
