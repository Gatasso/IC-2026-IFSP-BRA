@CONFERENCE{Mubarak2025,
	author = {Mubarak, M.},
	title = {AI-Driven Productivity in Energy: Automating Knowledge Retrieval & Routine Tasks},
	year = {2025},
	journal = {Society of Petroleum Engineers - ADIPEC 2025},
	pages = {},
	doi = {10.2118/229708-MS},
