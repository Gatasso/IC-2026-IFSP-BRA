@ARTICLE{Freyd202663,
	author = {Freyd, Thibaud and Peltzer, Raphael},
	title = {From ‘text soup’ to a trusted AI foundation; semanticising OSDU data for a multi-attribute future},
	year = {2026},
	journal = {First Break},
	volume = {44},
