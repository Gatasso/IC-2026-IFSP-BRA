}

@CONFERENCE{Kadkade2025168,
	author = {Kadkade, Varun and Mishra, Mayank and Nambiar, Manoj and Singhal, Rekha},
	title = {QueRA: Query Synthesis and Resource Access Modelling in RAG},
	year = {2025},
	journal = {2025 5th International Conference on AI-ML-Systems, AIMLSystems 2025},
	pages = {168 - 176},
	doi = {10.1109/AIMLSYSTEMS67835.2025.11330990},
	url = {https://www.scopus.com/pages/publications/105034900318?origin=resultslist},
	affiliations = {TCS Research, Mumbai, India},
	abstract = {Retrieval-Augmented Generation (RAG) systems integrate large language models with information retrieval components. These systems mark a shift from structured user interfaces to natural language interfaces (NLIs). This transition eliminates the predictable interaction patterns that traditional performance testing tools rely on to control content access distributions. In RAG systems, the unstructured nature of user queries hampers the ability to simulate required content access distributions; nevertheless, content access distribution remains a critical determinant of performance due to caching effects and the uneven popularity of content. To address this challenge, we make two primary contributions: (1) an optimization-driven query issuance mechanism that enables the simulation of required content access distributions during performance testing, and (2) query generation strategies that provide broad retrieval coverage of the knowledge base while reducing query generation costs by at least 20.9% compared to straightforward approaches. Constructing a synthetic test query set with wide coverage is essential for shaping the desired access distribution and for identifying performance bottlenecks across both frequently and infrequently retrieved content. Empirical evaluations also demonstrate that content access distributions, particularly in the presence of caching, have a substantial impact on system's performance metrics. By enabling testing across diverse operational scenarios, our framework supports robust, access distribution-aware performance evaluation. This capability is essential for performance testing of enterprise-grade RAG applications that must meet stringent service-level agreement (SLA) requirements. © 2025 IEEE.},
	author_keywords = {Performance Testing; Query Generation; RAG},
	keywords = {Information retrieval; Knowledge based systems; Query processing; Structured Query Language; Systems analysis; Access models; Generation systems; Interaction pattern; Language model; Natural language interfaces; Performance testing; Predictable interactions; Query generation; Resource access; Retrieval-augmented generation; Search engines},
