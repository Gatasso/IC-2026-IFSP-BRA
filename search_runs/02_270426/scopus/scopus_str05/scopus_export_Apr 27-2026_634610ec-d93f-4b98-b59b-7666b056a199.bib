@CONFERENCE{Tan202619380,
	author = {Tan, Jiejun and Dou, Zhicheng and Yu, Yan and Cheng, Jiehan and Liu, Lifeng and Xie, Jian and Wen, Ji-Rong},
	title = {HierSearch: A Hierarchical Enterprise Deep Search Framework Integrating Local and Web Searches},
	year = {2026},
	journal = {Proceedings of the AAAI Conference on Artificial Intelligence},
	volume = {40},
