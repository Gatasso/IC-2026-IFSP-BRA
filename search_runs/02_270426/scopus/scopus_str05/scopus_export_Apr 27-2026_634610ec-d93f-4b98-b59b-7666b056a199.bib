@CONFERENCE{Thanh20257,
	author = {Thanh, Dat Dang and Nguyen, Dung Ha and Thanh, Binh Nguyen},
	title = {Towards Intelligent Enterprise Assistants: Leveraging RAG to Connect LLMs with Structured Business Data},
	year = {2025},
