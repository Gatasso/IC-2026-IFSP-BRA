	title = {The double-edged sword: LLM operations (LLMOps) security in the cloud- a comprehensive review},
	year = {2026},
	journal = {Neurocomputing},
	volume = {680},
	pages = {},
	doi = {10.1016/j.neucom.2026.133313},
	url = {https://www.scopus.com/pages/publications/105033341538?origin=resultslist},
	affiliations = {College of Computer Science and Software Engineering, Shenzhen University, Shenzhen, 518060, China; Department of Information and Computing, University of Sufism and Modern Science, Bhitshah, Sindh, Matiari, 70140, Pakistan; School of Computing, Engineering and the Built Environment, University of Roehampton, London, United Kingdom; Department of Computer Science, College of Computer and Information Sciences, Jouf University, Al-Jouf, Sakaka, 72345, Saudi Arabia; Institute for Advanced Study in Nuclear Energy & Safety, Shenzhen University, Shenzhen, China; Department of Information Science and Technology, Beijing University of Chemical Technology, Beijing, China},
	abstract = {The rapid integration of Large Language Models (LLMs) into enterprise applications via cloud platforms has necessitated the emergence of LLM Operations (LLMOps)—a specialized discipline for managing the LLM lifecycle. While LLMOps streamlines development and maintenance, it introduces a complex and novel attack surface that traditional cybersecurity frameworks face significant challenges in addressing. This review paper provides a comprehensive analysis of the double-edged sword of LLMOps security within cloud environments. We systematically examine the LLMOps lifecycle to expose critical vulnerabilities, beginning at the API layer with sophisticated prompt injection and jailbreaking techniques that subvert model behavior. The analysis extends to the core infrastructure, examining the security of vector databases—a prime target for data exfiltration or poisoning—and the integrity of the retrieval-augmented generation (RAG) pipeline. Furthermore, we investigate the significant privacy and security risks associated with the fine-tuning phase in the cloud, where proprietary data used for adaptation becomes vulnerable to exposure or inference attacks. This paper argues that the interconnected nature of cloud-based LLMOps amplifies these threats, creating cascading risks across the entire system. By synthesizing current research and emerging threats, this review aims to establish a foundational security taxonomy for LLMOps and proposes a proactive, defense-in-depth strategy essential for securing the next generation of AI-driven applications in the cloud. The findings underscore an urgent need for robust security paradigms blueconstructed into the fabric of LLMOps practices. © 2026 Elsevier B.V.},
	author_keywords = {Cloud AI security; Data privacy; LLMOps security; Model extraction; Prompt injection; Threat modeling},
	keywords = {Application programming interfaces (API); Artificial intelligence; Cloud security; Life cycle; Network security; Cloud AI security; Cloud platforms; Cyber security; Enterprise applications; Language model; LLM operation security; Model extraction; Modeling operation; Prompt injection; Threat modeling; cloud computing; computer security; data base; data privacy; drug therapy; human; infrastructure; large language model; privacy; retrieval augmented generation; review; security; taxonomy; therapy; vulnerability; Data privacy},
	correspondence_address = {S. Ali; College of Computer Science and Software Engineering, Shenzhen University, Shenzhen, 518060, China; email: sijjadali2021@email.szu.edu.cn},
	publisher = {Elsevier B.V.},
