@ARTICLE{Wang202612,
	author = {Wang, Lin and Liu, Yinchun and Mao, Wentao},
	title = {Research on Chinese Factual Hallucination Benchmark Based on the Judian Data Open Platform; [基于聚典数据开放平台的中文事实性 幻觉基准测试研究]},
	year = {2026},
	journal = {Publishing and Printing},
	volume = {2026},
	number = {1},
	pages = {12 - 28},
	doi = {10.19619/j.issn.1007-1938.2026.00.012},
	url = {https://www.scopus.com/pages/publications/105034286368?origin=resultslist},
	affiliations = {Shanghai Century Publishing (Group) Co., Ltd., China},
	abstract = {In recent years, the rapid development of Large Language Models (LLMs) has driven significant progress in artificial intelligence technology. However, the phenomenon of hallucination in their generated content not only risks misleading users but also contributes to the degradation of the quality of online information source, triggering a cyclical risk of declining corpus quality. To systematically evaluate LLMs' capability to generate reliable factual content, this study constructs a Chinese-oriented factual hallucination benchmark aimed at enhancing model accuracy and providing foundational support for building a human-machine collaborative knowledge governance paradigm centered on credible and authoritative data. The research unfolds along two main lines: first, constructing a Chinese factual hallucination benchmark dataset based on reliable data sources; second, conducting systematic evaluation and result analysis of current mainstream Chinese LLM-based dialogue services. Leveraging the Judian Data Open Platform, this study constructed the SuperQA benchmark dataset comprising 5,200 Chinese factual question-answer pairs. During the construction process, multiple LLM-based agents were employed alongside predefined text-processing modules to automate data generation, filtering, and quality inspection. The final dataset was reviewed by human experts to ensure high quality. Based on the SuperQA benchmark, the study evaluated the dialogue services of 33 current mainstream LLMs. Key findings include: ① The rationality of this study's evaluation results was verified by comparing factual hallucination test results across different benchmarks; ② There is a positive correlation between the model's factual generation capability and its total parameter size; ③ There are differences in factual accuracy among models from different MaaS (Model as a Service) providers, with some models performing better than others; ④ Compared to Instruct models, deep-thinking models exhibit higher accuracy when generating factual content; ⑤ Some models maintain low hallucination rates with smaller parameter counts, offering advantages in local deployment costs; and ⑥ The factual generation capabilities of various models are generally weaker in the two disciplinary fields of literature-art and history-geography. During the testing process, the following phenomena were also observed: ① LLMs demonstrate a degree of self-assessment regarding the accuracy of their own generated content; ② Models struggle to accurately understand non-natural language encodings (e.g., years, CAS numbers, etc.), and tend to fabricate answers when dealing with such questions; and ③ When unable to answer a factual question, models tend to deny the existence or authenticity of that fact. Future work may focus on: ① using more intelligent LLMs to construct agents; ② constructing multimodal Chinese factual question-answer datasets; and ③ generating question-answer pairs by synthesizing multiple souce samples. The paper further discusses factors influencing factual accuracy in LLM outputs, analyzes causes of hallucination, and suggests that auxiliary measures such as Retrieval-Augmented Generation (RAG) technology and online search tools can be currently applied to effectively improve the accuracy of model-generated content at a lower cost. Based on this, the study argues that the high-quality data accumulated by the publishing industry will become a critical foundation for LLM applications. Only publishing enterprises with extensive high-quality data resources can build core competitiveness in the era of generative AI, ultimately becoming definers and leaders of the industry's future landscape. © 2026, Shanghai Publishing and Printing College. All rights reserved.},
	author_keywords = {artificial intelligence; benchmark testing; factual hallucination; Judian Data Open Platform; large language model; question-answer pair dataset},
	publisher = {Shanghai Publishing and Printing College},
	issn = {10071938},
	language = {Chinese},
	abbrev_source_title = {Publ. Print.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

