	title = {The AI-centered enterprise: Reshaping organizations with context aware AI},
	year = {2025},
	journal = {The AI-Centered Enterprise: Reshaping Organizations with Context Aware AI},
	pages = {1 - 199},
	doi = {10.1201/9781003541561},
