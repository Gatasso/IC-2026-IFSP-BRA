	author = {Huang, Li-Ming},
	title = {Multimodal Fusion and Dynamic Optimization of Enterprise-Level RAG Systems},
	year = {2025},
	journal = {CSAE 2025 - Proceedings of the 9th International Conference on Computer Science and Application Engineering},
	pages = {},
	doi = {10.1145/3772886.3772894},
	url = {https://www.scopus.com/pages/publications/105026178043?origin=resultslist},
	affiliations = {Sinopec Research Institute of Petroleum Engineering Co. Ltd., Beijing, China},
	abstract = {Against the backdrop of digital and intelligent transformation, multimodal data accumulated by enterprises has become a core asset. However, traditional Retrieval-Augmented Generation (RAG) systems are limited by pure text processing and static knowledge maintenance, making it difficult to meet enterprises' demands for knowledge comprehensiveness and timeliness. This paper focuses on the optimization of enterprise-level RAG systems, aiming to improve system performance through multimodal fusion and dynamic optimization technologies. On one hand, a cross-modal retrieval and semantic alignment mechanism is designed to achieve seamless integration of knowledge in forms such as text, images, and tables; an innovative attention-driven adaptive weight adjustment mechanism is introduced to replace manually preset parameters. On the other hand, a dynamic update engine based on incremental learning and knowledge graphs is constructed to address the problem of delayed knowledge updates and support real-Time updates. Experimental results show that on multimodal datasets in the equipment maintenance and chemical process fields, the proposed scheme in this paper achieves 79.1%-79.6% (Hit Rate@1), 84.5%-88.3% (Hit Rate@3), and 0.811-0.827 (Mean Reciprocal Rank, MRR), respectively, which is significantly superior to LLaVA-Interactive and MM-RAG. © 2025 Copyright held by the owner/author(s).},
