@ARTICLE{Bakir2025776,
	author = {Bakir, Robin and Müller, Maximilian and Bakir, Dennis},
	title = {Project Eskalator: Navigating the Innovation-Funding Maze in SMEs},
	year = {2025},
	journal = {Applied Human Factors and Ergonomics International},
	volume = {160},
	pages = {776 - 783},
