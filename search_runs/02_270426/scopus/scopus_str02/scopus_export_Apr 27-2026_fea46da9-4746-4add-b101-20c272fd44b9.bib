@ARTICLE{Giuntelli2026,
	author = {Giuntelli, Guido and Spreafico, Christian and Precorvi, Andrea and Russo, Davide},
	title = {Patent intelligence in the age of AI: Unlocking strategic insights through granular classification},
	year = {2026},
	journal = {World Patent Information},
