@CONFERENCE{Dimmelmeier202412,
	author = {Dimmelmeier, Andreas and Doll, Hendrik Christian and Schierholz, Malte and Kormanyos, Emily and Fehr, Maurice and Ma, Bolei and Beck, Jacob and Fraser, Alexander and Kreuter, Frauke},
