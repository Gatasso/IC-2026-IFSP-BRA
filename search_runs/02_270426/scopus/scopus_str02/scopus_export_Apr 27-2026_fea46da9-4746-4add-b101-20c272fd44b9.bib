@CONFERENCE{Malaeb2025,
	author = {Malaeb, Sarah and Jneid, Maroun and Saleh, Imad},
	title = {Developing a Semantic Innovation Capabilities Taxonomy Using Machine Learning, Generative AI, and NLP Techniques},
	year = {2025},
	journal = {2025 International Conference on Engineering Management of Communication and Technology, EMCTECH 2025 - Conference Proceedings},
	pages = {},
	doi = {10.1109/EMCTECH65814.2025.11220567},
	url = {https://www.scopus.com/pages/publications/105024858166?origin=resultslist},
	affiliations = {Université Paris 8 Vincennes-Saint-Denis, Laboratoire Paragraphe EA 349, Saint-Denis, 93526, France; Roadmap Partner Sarl, Beirut, Lebanon; Vincennes-Saint-Denis, France},
	abstract = {This study presents a semantically structured, AI-enhanced taxonomy of innovation capabilities that addresses the conceptual ambiguity, fragmentation, and lack of operational clarity in existing frameworks. Drawing from a dual corpus of 27 academic and institutional sources, we apply semantic embeddings, clustering and classification models, and retrieval-Augmented generation, combined with semantic inspection, to extract and structure 957 micro-capabilities across 14 validated innovation dimensions, including innovation development, leadership and culture, collaboration, digital transformation, strategic vision, knowledge management, organizational structure, financial management, corporate governance, and social engagement. The resulting six-Tier taxonomy integrates macro-And micro-capabilities with associated competencies, skills, and resources, ensuring semantic traceability and interoperability. Iterative refinement through cross-validation ensures conceptual integrity. Compared with ten reference frameworks, our model offers superior granularity, extensibility, and alignment with strategic, educational, and policy goals. It supports innovation maturity diagnostics, curriculum design, and integration into digital platforms bridging theory and AI-enabled implementation across digitally evolving ecosystems.  © 2025 IEEE.},
	author_keywords = {generative AI; innovation capability modeling; machine learning; natural language processing; semantic taxonomy},
	keywords = {Computation theory; Engineering education; Industrial management; Information systems; Knowledge management; Learning algorithms; Learning systems; Machine learning; Semantics; Taxonomies; Capability model; Capability taxonomies; Generative AI; Innovation capability; Innovation capability modeling; Language processing; Machine-learning; Natural language processing; Natural languages; Semantic taxonomies; Natural language processing systems},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {978-166546572-4},
	language = {English},
	abbrev_source_title = {Int. Conf. Eng. Manag. Commun. Technol., EMCTECH - Conf. Proc.},
