@CONFERENCE{Bala Saravanan2026,
	author = {Bala Saravanan, P. and Raja, Stephen and Hari Prasath, R.K. and Sushma, J. and Marimuthu, T.},
	title = {MAC: A Multi-Agent Hybrid Architecture for Causally-Grounded, Auditable, and Strategic Advice for SMEs},
	year = {2026},
	journal = {ICCIDS 2026 - 9th International Conference on Computational Intelligence in Data Science},
	pages = {},
	doi = {10.1109/ICCIDS69108.2026.11407682},
	url = {https://www.scopus.com/pages/publications/105036296233?origin=resultslist},
	affiliations = {Kalasalingam University, Department of Computer Science and Engineering, Krishnankoil, India},
	abstract = {Small and medium-sized enterprises (SMEs) continue to be a fundamental component of the global economy and representative of a large proportion of all businesses, SMEs still struggle to find affordable access to credible providers of data-driven strategy consulting services. Large language models, however, and due to their inability to perform deterministic calculations, evaluate unstructured financial data and reliably distinguish the difference between cause and correlation, make stakeholders hesitant to rely on the application of these models for making high-risk business decisions. This paper introduces a neuro-symbolic architecture for SMEs, referred to as the Multi- Agent Consultant (MAC), which provides causally grounded, audit ready, and generative information to SMEs through the use of this architecture. The MAC architecture is made up of three specialized agents. The Analyst agent utilizes an ontology- based contrastive learning approach to harmonize unstructured financial data. The Quant agent uses Vector Autoregression, Granger causality, and the PC algorithm to identify causal relationships between variables. Finally, the Partner agent is a constrained retrieval-augmented generation system that produces recommended strategies from only verified causal information. Results of experiments showed that the MAC architecture outperformed baseline monolithic large language models across both data harmonization and causal driver identification tasks. © 2026 IEEE.},
	author_keywords = {Causal Inference; Financial AI; Knowledge Graphs; Multi-Agent Systems; Neuro-Symbolic AI; Retrieval- Augmented Generation},
