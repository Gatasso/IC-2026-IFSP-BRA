}

@CONFERENCE{Mingyar2025282,
	author = {Mingyar, Michael and Odden, Tor Ole B. and Willoughby, Shannon},
	title = {Exploring Query-Driven Centroiding and Embedding Strategies for Automated Thematic Analysis in Physics Education},
