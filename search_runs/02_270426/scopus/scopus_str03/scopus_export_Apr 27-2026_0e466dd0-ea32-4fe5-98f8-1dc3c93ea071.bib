	title = {GRAM: Generative Retrieval Augmented Matching of Data Schemas in the Context of Data Security},
	year = {2024},
	journal = {Proceedings of the ACM SIGKDD International Conference on Knowledge Discovery and Data Mining},
	pages = {5476 - 5486},
