@CONFERENCE{Zheng2025156,
	author = {Zheng, Zhou and Xie, Wei and Xu, Huifang and Liang, Panfei and Yang, Yan},
	title = {Large Language Model Enhancement Through Multi-Domain Knowledge Integration and Semantic Retrieval in Power Systems},
	year = {2025},
	journal = {Proceedings of 2025 9th IEEE International Conference on Network Intelligence and Digital Content, IC-NIDC 2025},
	pages = {156 - 162},
	doi = {10.1109/IC-NIDC67200.2025.11390419},
	url = {https://www.scopus.com/pages/publications/105035150608?origin=resultslist},
	affiliations = {Fujian Yili Information Technology Co., Ltd, Fujian Yili Information Technology Co., Ltd, Fuzhou, China; Digital Technology Research Institute, State Grid Fujian Electric Power Research Institute, Fuzhou, China; China Electric Power Research Institute, Artificial Intelligence Affiliation Department, Beijing, China},
	abstract = {With the ongoing digital transformation across the power sector, large language models (LLMs) are increasingly expected to handle domain-specific tasks involving heterogeneous databases and technical vocabularies. To address this demand, we present KARF-Power, a novel framework that combines natural language to SQL (NL2SQL) generation with retrieval-augmented inference across multi-source power-related knowledge bases. Specifically, the framework translates natural language queries into structured database commands while leveraging text vectorization and semantic indexing to retrieve relevant context from specialized corpora such as marketing records and equipment management logs. The retrieved knowledge is then integrated into the LLM's decoding process, enabling context-aware response generation for downstream tasks such as multi-label classification and cross-database querying. This hybrid approach improves interpretability, enhances domain adaptation, and provides a scalable pathway for embedding expert knowledge into LLM-driven applications in the power domain. Extensive experiments on simulated enterprise-level datasets confirm the practical feasibility of our method, showcasing its potential to support real-time intelligent decision-making across diverse business scenarios.  © 2025 IEEE.},
	author_keywords = {Knowledge-Augmented Reasoning; Large Language Models; NL2SQL; Power Systems; Semantic Retrieval},
	keywords = {Classification (of information); Knowledge management; Marketing; Natural language processing systems; Query languages; Query processing; Semantics; Structured Query Language; Domain knowledge; Knowledge integration; Knowledge-augmented reasoning; Language model; Large language model; Multi-domains; NL2SQL; Power; Power system; Semantic retrieval; Search engines},
	correspondence_address = {H. Xu; China Electric Power Research Institute, Artificial Intelligence Affiliation Department, Beijing, China; email: xuhuifang@epri.sgcc.com.cn},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833159437-4},
	language = {English},
	abbrev_source_title = {Proc. IEEE Int. Conf. Netw. Intell. Digit. Content, IC-NIDC},
	type = {Conference paper},
