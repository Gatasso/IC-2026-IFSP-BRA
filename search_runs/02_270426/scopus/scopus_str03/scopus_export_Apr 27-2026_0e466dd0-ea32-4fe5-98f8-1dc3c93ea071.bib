@ARTICLE{Braga2026363,
	author = {Braga, Carlos Mario and Serrano, Manuel A. and Fernández-Medina, Eduardo},
	title = {Guided and Federated RAG: Architectural Models for Trustworthy AI in Data Spaces},
	year = {2026},
	journal = {Lecture Notes in Computer Science},
	volume = {16239 LNCS},
	pages = {363 - 374},
	doi = {10.1007/978-3-032-10489-2_31},
	url = {https://www.scopus.com/pages/publications/105022074645?origin=resultslist},
	affiliations = {University of Castilla La-Mancha, Ciudad Real, Spain},
	abstract = {The growing deployment of large language models (LLMs) in policy-sensitive and distributed environments raises concerns about hallucinations, semantic opacity, and lack of traceability, especially in regulated domains such as healthcare and finance. Retrieval-augmented generation (RAG) helps address these issues by grounding outputs in external sources, while data spaces (DSs) offer a governance-driven infrastructure for federated and sovereign data exchange. However, their integration remains underdeveloped, limiting the design of AI systems that are both explainable and compliant with regulatory demands. This paper analyzes three RAG–DSs integration models from the literature and introduces two new architectures, Guided RAG and Federated RAG, that directly address their structural limitations by combining coordination, data sovereignty, and trust in generative systems. Guided RAG and Federated RAG are formally specified using Business Process Model and Notation (BPMN), and all five models, together with a non-retrieval baseline, are analyzed across operational dimensions including transparency, traceability, and control delegation. This work establishes an architectural foundation for trustworthy generative AI operating under distributed governance constraints, with explicit guarantees of data sovereignty. The proposed framework supports systematic evaluation in federated settings and serves as a foundation for methodological refinement and regulatory alignment.   © The Author(s), under exclusive license to Springer Nature Switzerland AG 2026.},
	author_keywords = {Data spaces; RAG; Trustworthy AI},
	keywords = {Architecture; Data integration; Electronic data interchange; Semantics; AI systems; Architectural modeling; Data space; Distributed environments; External sources; Language model; Paper analysis; Retrieval-augmented generation; Space integrations; Trustworthy AI; Artificial intelligence},
	correspondence_address = {C.M. Braga; University of Castilla La-Mancha, Ciudad Real, Spain; email: carlosmario.braga1@alu.uclm.es},
	editor = {Martínez L. and Camacho D. and Yin H. and Dutta B. and Yera R. and Rodríguez Domínguez R.M. and Tallón-Ballesteros A.},
