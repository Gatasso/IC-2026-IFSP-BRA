@CONFERENCE{Arsal2025,
	author = {Arsal, Muhammad and Ashfaq, Hassan and Mahmood, Muhammad Ali and Ashfaq, Anas},
	title = {Towards Intelligent Tax Systems: Evaluating NLP Approaches for Pakistan's Fiscal Needs},
	year = {2025},
	journal = {2025 International Conference on Frontiers of Information Technology, FIT 2025},
	pages = {},
	doi = {10.1109/FIT67061.2025.11333725},
	url = {https://www.scopus.com/pages/publications/105033156618?origin=resultslist},
	affiliations = {Gik Institute of Engineering Sciences and Technology, Faculty of Computer Science and Engineering, Topi, Pakistan; College of Arts and Sciences, Cornell University, Ithaca, NY, United States},
	abstract = {Tax compliance and interpretation of fiscal regulations remain a major challenge for individuals and businesses in Pakistan, particularly due to the complexity and evolving nature of regional tax laws. While AI-powered systems offer a promising solution, existing approaches often fall short in delivering verifiable, contextually accurate, and user-tailored guidance, especially in linguistically diverse regions such as Punjab. This paper presents the design and evaluation of an AI-powered tax assistant that leverages three distinct architectures: a rule-based NLP system, a fine-tuned Large Language Model (LLM), and a Retrieval-Augmented Generation (RAG) pipeline. The proposed RAG-based approach integrates official tax documents with OpenAI embeddings and LangChain orchestration, ensuring multilingual support, source citation, and domain-specific accuracy. Extensive evaluation, including relevance scores, expert review, response latency, and user satisfaction, demonstrated the RAG model's superiority, achieving an average relevance score of 0.83, response times under 3 seconds, and 91% expert-rated accuracy. In contrast, the rule-based and fine-tuned LLM systems lacked either contextual flexibility or traceability. The study introduces a robust citation mechanism and offers a comparative analysis of the three approaches, highlighting RAG's effectiveness in delivering transparent, timely, and accurate tax assistance. These results underscore the transformative potential of retrieval-augmented frameworks in public sector automation and digital legal services. © 2025 IEEE.},
	author_keywords = {Chatbots; Large Language Models (LLMs); Legal AI; Multilingual AI; Natural Language Processing (NLP); Public Sector Automation; Retrieval-Augmented Generation (RAG); Rule-Based Systems; Tax Assistant},
	keywords = {Artificial intelligence; Automation; Computational linguistics; Computer architecture; Information systems; Laws and legislation; Taxation; Chatbots; Language model; Language processing; Large language model; Legal AI; Multilingual AI; Natural language processing; Natural languages; Public sector; Public sector automation; Retrieval-augmented generation; Rules based systems; Tax assistant; Natural language processing systems},
	correspondence_address = {M. Arsal; Gik Institute of Engineering Sciences and Technology, Faculty of Computer Science and Engineering, Topi, Pakistan; email: mohammadarsal12@gmail.com},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
