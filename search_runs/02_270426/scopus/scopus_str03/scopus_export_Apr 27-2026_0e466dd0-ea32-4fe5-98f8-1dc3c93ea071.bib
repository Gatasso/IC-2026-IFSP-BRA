@CONFERENCE{Zhang202634728,
	author = {Zhang, Jie and Tang, Bo and Shao, Wanzi and Wei, Wenqiang and Zhao, Jihao and Zhu, Jianqing and Li, Zhiyu and Xi, Wen and Lin, Zehao and Xiong, Feiyu and Tan, Yanchao},
	title = {TAdaRAG: Task Adaptive Retrieval-Augmented Generation via On-the-Fly Knowledge Graph Construction},
	year = {2026},
	journal = {Proceedings of the AAAI Conference on Artificial Intelligence},
	volume = {40},
	number = {41},
	pages = {34728 - 34736},
	doi = {10.1609/aaai.v40i41.40774},
	url = {https://www.scopus.com/pages/publications/105034730600?origin=resultslist},
	affiliations = {College of Computer and Data Science, Fuzhou University, Fuzhou, 350116, China; AIDS and SIAR, University of Science and Technology of China, Suzhou, 215123, China; MemTensor (Shanghai) Technology Co., Ltd, Shanghai, 201306, China; School of Information, Renmin University of China, Beijing, 100086, China; China Haisum Engineering Co., Ltd, Shanghai, 200031, China},
	abstract = {Retrieval-Augmented Generation (RAG) improves large language models by retrieving external knowledge, often truncated into smaller chunks due to the input context window, which leads to information loss, resulting in response hallucinations and broken reasoning chains. Moreover, traditional RAG retrieves unstructured knowledge, introducing irrelevant details that hinder accurate reasoning. To address these issues, we propose TAdaRAG, a novel RAG framework for on-the-fly task-adaptive knowledge graph construction from external sources. Specifically, we design an intent-driven routing mechanism to a domain-specific extraction template, followed by supervised fine-tuning and a reinforcement learning-based implicit extraction mechanism, ensuring concise, coherent, and non-redundant knowledge integration. Evaluations on six public benchmarks and a real-world business benchmark (NowNewsQA) across three backbone models demonstrate that TAdaRAG outperforms existing methods across diverse domains and long-text tasks, highlighting its strong generalization and practical effectiveness. © 2026, Association for the Advancement of Artificial Intelligence (www.aaai.org). All rights reserved.},
	keywords = {Domain Knowledge; Project management; Reinforcement learning; Context window; Domain specific; External knowledge; External sources; Fine tuning; Graph construction; Information loss; Knowledge graphs; Language model; Routing mechanism; Extraction},
