}

@CONFERENCE{Bhowmick2025318,
	author = {Bhowmick, Archisman and Singhal, Rekha},
	title = {OptiRAG: Optimized RAG configuration under performance constraints},
	year = {2025},
	journal = {2025 5th International Conference on AI-ML-Systems, AIMLSystems 2025},
	pages = {318 - 323},
	doi = {10.1109/AIMLSYSTEMS67835.2025.11330856},
	url = {https://www.scopus.com/pages/publications/105034867114?origin=resultslist},
	affiliations = {TCS Research, Kolkata, India; TCS Research, New York, United States},
	abstract = {Retrieval-Augmented Generation (RAG) systems offer flexibility through modular components-chunking, embedding, retrieval, and answer generation-each with many choices, huge configuration space, and tunable hyperparameters. The choices of methods and hyperparameters affect system performance greatly, resulting in the need of optimal selection. However, selecting optimal configurations remains a challenge, especially in the case of dynamic workloads, where configurations must adapt to meet per-user SLAs without compromising cost-efficiency or scalability. While most research on RAG optimizations emphasizes answer quality and automatic creation of RAG systems, real-world deployments demand attention to system-level metrics. We propose OptiRAG, a principled and systematic framework for performance-driven RAG system design. OptiRAG combines regression-based performance modeling with constraint-aware optimization to automatically select the most effective configuration across all RAG components based on workload characteristics and SLA requirements. OptiRAG adapts to changing user loads and performance constraints unlike heuristic or static approaches, ensuring robust operation across diverse deployment scenarios. We validate OptiRAG through extensive testing on multiple real-world business deployments. Across these use cases, the framework consistently identifies configurations that significantly improve system efficiency. In one high-load enterprise setting, OptiRAG achieved more than 2X improvement in latency and approximately 150X reduction in cost compared to a standard RAG baseline. This paper presents several case studies, demonstrating how OptiRAG enables scalable, cost-effective, and SLA-compliant RAG deployments in practice. © 2025 IEEE.},
	author_keywords = {LLM; RAG; System Optimization},
	keywords = {Artificial intelligence; Cost effectiveness; Heuristic methods; Industrial electronics; Multiobjective optimization; Configuration space; Embeddings; Generation systems; Hyper-parameter; LLM; Modular components; Optimisations; Performance constraints; Retrieval-augmented generation; System optimizations; Efficiency},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833157318-8},
	language = {English},
	abbrev_source_title = {Int. Conf. AI-ML-Syst., AIMLSyst.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; Conference name: 2025 5th International Conference on AI-ML-Systems, AIMLSystems 2025; Conference sponsors: ; Conference code: 220201; Conference date: 8 October 2025 through 11 October 2025}
}

@CONFERENCE{Mishra2025358,
	author = {Mishra, Sushanta Kumar and Dedani, Vivek and Khant, Aum and Keeriyadath, Sangeeth and Vaid, Amit},
	title = {D-CURE: Domain data Curation Using Refined Elements},
	year = {2025},
	journal = {2025 3rd International Conference on Foundation and Large Language Models, FLLM 2025},
	pages = {358 - 365},
	doi = {10.1109/FLLM67465.2025.11391042},
	url = {https://www.scopus.com/pages/publications/105035886646?origin=resultslist},
	affiliations = {State Street Corporation, AI India, Bangalore, India; State Street Corporation, AI India, Hyderabad, India},
	abstract = {In highly regulated financial domains, critical business knowledge resides in thousands of Standard Operating Procedure (SOP) documents in PDF/DOCX formats. However, existing retrieval-augmented generation (RAG) methods plateau at limited accuracy when processing custody and back-office documents. These documents involve domain-specific terminology, workflows, compliance rules, and high-stakes decisions, motivating an LLM fine-tuning approach. We found that curating training data for back-office processes (e.g., trade life-cycle events, settlement cycles, exception handling) demands a systematic, specialized workflow. To address this, we propose D-CURE (Domain data Curation Using Refined Elements), a reusable framework for large-scale, high-quality training-data curation. Given a document and predefined question types, D-CURE first extracts structured elements to generate optimized "original"Question & Answer (Q&A) pairs, then expands them via synthetic augmentation. Each synthetic Q&A undergoes a Chain-Of-Thought (CoT) reasoning filter - evaluating alignment, bias, coherence, and completeness - to select the highest-quality Q&A pairs. Finally, D-CURE recommends an optimal mix of original and synthetic Q&A for each question type, maximizing model generalization while controlling fine-tuning cost. Empirical evaluations on custody-domain documents show that models fine-tuned with D-CURE data using LoRA-X converge 20% faster, reduce training time by 25% and improve accuracy by 10%, leading to reduced operational risk and enhanced compliance support. D-CURE's modular design enables adaptation to other high-stakes, domain-specific applications. © 2025 IEEE.},
	author_keywords = {CoT filter; Data Curation; Fine-Tuning; LLMs; Q&A pairs},
	keywords = {Computer software reusability; Curing; Data accuracy; Distributed computer systems; Information retrieval; Information retrieval systems; Information systems; Life cycle; Tuning; Back office; Chain-of-thought filter; Data curation; Fine tuning; High quality; LLM; Question type; Question-answer pairs; Training data; Work-flows; Data curation},
	correspondence_address = {S.K. Mishra; State Street Corporation, AI India, Bangalore, India; email: SMISHRA47@StateStreet.com},
	editor = {Erenli K. and Guetl C. and Jararweh Y. and Jansen J.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833159409-1},
	language = {English},
	abbrev_source_title = {Int. Conf. Found. Large Lang. Model, FLLM},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; Conference name: 2025 3rd International Conference on Foundation and Large Language Models, FLLM 2025; Conference sponsors: IEEE; TU Graz; University of Applied Sciences BFI Vienna; Conference code: 221062; Conference date: 25 November 2025 through 28 November 2025}
}

