	title = {Enhancing Data Traceability: A Knowledge Graph Approach with Retrieval-Augmented Generation},
	year = {2024},
	journal = {7th International Seminar on Research of Information Technology and Intelligent Systems: Advanced Intelligent Systems in Contemporary Society, ISRITI 2024 - Proceedings},
	pages = {473 - 478},
