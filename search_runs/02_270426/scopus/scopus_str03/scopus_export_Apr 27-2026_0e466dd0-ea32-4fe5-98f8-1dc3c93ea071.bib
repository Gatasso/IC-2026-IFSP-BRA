@ARTICLE{Abras20253,
	author = {Abras, Jordan and Burnay, Corentin and Faulkner, Stéphane},
	title = {Can Generative AI Mitigate Strategic Decision-Making Complexity? An Empirical Exploration of RAG-Augmented Decision-Support Systems},
