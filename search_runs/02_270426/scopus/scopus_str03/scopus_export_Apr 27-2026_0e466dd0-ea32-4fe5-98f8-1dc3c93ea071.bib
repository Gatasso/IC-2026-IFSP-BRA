	year = {2026},
	journal = {Proceedings of Supercomputing Asia and International Conference on High Performance Computing in Asia Pacific Region Workshops, SCA/HPCAsia 2026 Workshops},
	pages = {361 - 369},
	doi = {10.1145/3784828.3785338},
	url = {https://www.scopus.com/pages/publications/105032082735?origin=resultslist},
	affiliations = {Xi'an University Of Finance And Economics, Xi'an, China; Shanghai Jiao Tong University, Shanghai, China; Riken Center For Computational Science, Kobe, Japan},
	abstract = {An increasing number of enterprises and research institutions seek to deploy Large Language Models (LLMs) locally to address domain-specific business and research problems. However, such deployment faces significant challenges due to high computational demands and unpredictable runtime behavior. Runtime is a critical performance metric that directly influences user latency, resource allocation, and system feasibility. Yet most prior studies emphasize throughput or energy consumption, while systematic runtime prediction across diverse task types remains underexplored. In this paper, we propose a runtime prediction framework for LLM deployment in resource-constrained environments. Our study focuses on the Qwen family of open-source models (7B, 14B, and 32B parameters) and systematically evaluates runtime across three representative task categories: LoRA fine-tuning, RAG & GraphRAG (graph-enhanced retrieval-augmented generation), and standard inference. Controlled experiments were conducted on multi-GPU A100 clusters, varying the number of GPUs, model size, data scale, batch size, and concurrency. Predictive models were constructed using polynomial feature expansion and ridge regression, with logarithmic transformations and non-negativity constraints to ensure accuracy and extrapolation stability. Results demonstrate strong predictive performance, with R2 values exceeding 0.9 and mean absolute percentage errors below 10% in most cases. To enhance practical usability, we further implement the proposed models as an online runtime prediction tool, available at https://johnkuo.github.io/Power-Consumption-LLMs/. This tool allows users to quickly estimate runtime under different deployment configurations, facilitating not only resource planning and performance optimization, but also serving as a foundational component for subsequent energy consumption prediction. Moreover, it provides practical guidance for users of cloud-based GPU services to select appropriate computational resources according to their workload scale and quality-of-service requirements. © 2026 Copyright held by the owner/author(s).},
	author_keywords = {GraphRAG; Inference; Large Language Models; LoRA Fine-Tuning; Runtime Prediction},
	keywords = {Behavioral research; Graphics processing unit; Green computing; Information management; Open source software; Open systems; Polynomials; Prediction models; Program processors; Quality control; Resource allocation; Tuning; Case-studies; Fine tuning; Graph-enhanced retrieval-augmented generation; Inference; Language model; Large language model; LoRA fine-tuning; Research institutions; Runtime prediction; Runtimes; Forecasting},
	publisher = {Association for Computing Machinery, Inc},
	isbn = {979-840072328-5},
	language = {English},
	abbrev_source_title = {Proc. Supercomput. Asia Int. Conf. High Perform. Comput. Asia Pac. Reg. Workshops, SCA/HPCAsia Workshops},
	type = {Conference paper},
	publication_stage = {Final},
