	year = {2025},
	journal = {SITA 2025 - 15th International Conference on Intelligent Systems: Theories and Applications},
	pages = {},
	doi = {10.1109/SITA67914.2025.11273548},
	url = {https://www.scopus.com/pages/publications/105030452322?origin=resultslist},
	affiliations = {Department of Data Analytics,, Operations and Decision (DATA), National Institute of Posts and Telecommunications - INPT, Rabat, Morocco},
	abstract = {Business intelligence went from static reports to real time analytics, while agentic artificial intelligence evolved to autonomous agents able to use call tools. Yet these parallel advancements rarely found a common ground in order to converge: today’s business intelligence dashboards still depend on analysts to interpret insights and trigger actions. Also, agentic artificial intelligence flows rarely integrate with enterprise business intelligence pipelines. This paper reviews and attempts to dig into this persistent gap. Building on our proof of concept internet of things decision support framework, we propose results that show that we can build architectures adapted for a business intelligence centric context. Sensor data is streamed via Message Queuing Telemetry Transport, then an agentic layer is implemented with Langchain and local large language models subscribes to the same data, enriches it through retrieval augmented generation for a domain specific vector store, and issues autonomously decisions back into the business intelligence ecosystem. In addition, we highlight the urge to examine if artificial intelligence agents can act like business analysts deciding which plots or visualizations are most appropriate for each use case to maximize insight delivery. Thus, dashboards transition from passive monitors to actionable control panels. The results show that merging advanced business intelligence with agentic artificial intelligence is technically feasible and operationally beneficial, it raises at the same time questions about security, governance, explainability and ethics. This study provides a concrete blueprint for closing the gap between business intelligence and agentic artificial intelligence and it outlines a research agenda for truly autonomous business analytics in industry settings. ©2025 IEEE.},
	author_keywords = {Agentic Artificial Intelligence; Autonomous Analytics; Business Intelligence; Internet of Things},
	keywords = {Advanced Analytics; Artificial intelligence; Autonomous agents; Competitive intelligence; Decision support systems; Intelligent agents; Process engineering; Agentic artificial intelligence; Autonomous analytic; Build architecture; Business-intelligence; Common ground; Decision support framework; Decisions makings; Modular architectures; Proof of concept; Real-time analytics; Internet of things},
