@CONFERENCE{Wei2025,
	author = {Wei, Yiqun and Xia, Pengcheng and Ni, Yiyang and Li, Jun},
	title = {Privacy-Preserving LLM-based RAG with Split Inference and Masked Privacy Recovery},
	year = {2025},
	journal = {2025 IEEE/CIC International Conference on Communications in China:Shaping the Future of Integrated Connectivity, ICCC 2025},
	pages = {},
	doi = {10.1109/ICCC65529.2025.11148675},
	url = {https://www.scopus.com/pages/publications/105017772884?origin=resultslist},
	affiliations = {Nanjing University of Science and Technology, School of Cyber Science and Engineering, Nanjing, 210094, China; Nanjing University of Science and Technology, School of Electronic and Optical Engineering, Nanjing, 210094, China; Nanjing University of Posts and Telecommunications, Jiangsu Key Laboratory of Wireless Communications, Nanjing, 210003, China; Jiangsu Second Normal University, Jiangsu Province Engineering Research Center of Basic Education Big Data Application, Nanjing, 210003, China; Southeast University, School of Information Science and Engineering, Nanjing, 210096, China},
	abstract = {With the development of 6G endogenous intelligence, retrieval-augmented generation (RAG) based on large language models (LLMs) becomes one of its key technologies due to its ability to empower 6G intelligent systems with enhanced knowledge reserves and context-aware decision-making capabilities. However, deploying LLMs on cloud servers poses privacy risks to users and businesses. To address this, we propose a privacy-enhanced retrieval-augmented generation framework (PE-RAG). It uses split inference by deploying the embedding and output layers of LLMs at the edge, preventing sensitive information in plain text from being stolen by attackers on untrusted cloud servers. In addition, we propose the privacy masking recovering knowledge base (PMR-KB), which masks privacy sensitive content in the knowledge base and recovers masked content in the inference results, thereby minimizing utility degradation while reducing privacy leakage risks. Our experiments show that the proposed framework achieves significant improvements over state-of-the-art approaches, reducing privacy leakage by 76.4% and enhancing inference utility by 80.0%.  © 2025 IEEE.},
	author_keywords = {large language models; privacy protection; retrieval-augmented generation; split inference},
