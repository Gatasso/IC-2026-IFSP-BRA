	pages = {},
	doi = {10.1088/1742-6596/3191/1/012091},
	url = {https://www.scopus.com/pages/publications/105035995708?origin=resultslist},
	affiliations = {Department of Computing and Information Sciences, UTAS, Ibri, Oman},
	abstract = {Recent advancements in Artificial Intelligence have led to an unprecedented integration of AI tools into daily life. Among these, generative AI tools like ChatGPT, powered by Large Language Models (LLMs), have demonstrated remarkable success and adaptability across various fields, including business, healthcare, education, and more. The ability of LLMs to understand natural language and generate human-like responses is particularly impressive, driving widespread adoption of such tools. In the education sector, students often encounter challenges in academic advising due to a lack of readily available, comprehensive information. This work explores a practical solution to this issue by leveraging a Graph RAG model to provide concise and informative responses derived from students’ academic transcripts. The approach involves identifying common questions that students typically have based on their academic history and using these questions as prompts for Retrieval-Augmented Generation (RAG) models. These models generate accurate, natural-language responses by combining RAG capabilities and graph-based reasoning techniques. The experimental results show that the Graph RAG models confirmed their capability to deliver accurate and contextually relevant responses to user queries. Further, this study vindicates use of the model in developing a software tool that aims to support both students and academic advisors for enhancing the overall academic advising experience. © 2026 Institute of Physics Publishing. All rights reserved.},
	author_keywords = {Academic Advising; Graph RAG; Large Language Model},
