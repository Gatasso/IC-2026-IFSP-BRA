   Jeong, Cheonsu, SAMSUND SDS, Dept AI Automat Team, Olymp Ro 125, Seoul, South Korea.},
EISSN = {2582-9793},
Keywords = {Embedding; Generative AI; LLM framework; RAG; Vector store},
Research-Areas = {Computer Science},
