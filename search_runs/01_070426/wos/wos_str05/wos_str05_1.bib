@article{ WOS:001662651700001,
Author = {Jiang, Zhuoxuan and Zhang, Tianyang and Bai, Shengguang and Lin, Lin and
   Zhang, Haotian and Xun, Yinong and Ren, Jiawei and Si, Wen and Zhang,
   Shaohua},
Title = {Towards enterprise-specific question-answering for IT operations and
   maintenance based on retrieval-augmented generation mechanism},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {307},
Month = {APR 25},
Abstract = {In the field of IT operations and maintenance, Question-Answering (QA)
   systems are very important for fault diagnosis, employee training,
   knowledge management and other aspects of providing high-quality
   services. While Large Language Models (LLMs) have significantly enhanced
   the performance of open-domain QA, the efficient handling of
   enterprise-exclusive corpora and the development of domain-specific high
   intelligent QA systems (e.g., QA for troubleshooting) remain
   underexplored in application settings. This paper proposes a
   comprehensive methodology based on Retrieval Augmented Generation (RAG)
   to facilitate the entire process of establishing such QA systems for IT
   operations and maintenance. Our methodology consists of two main
   components: (1) Offline Models Fine-tuning \& Data Vectorization and (2)
   Online QA System Process. In the first component, we design a general
   data preprocessing pipeline and employ a contrastive learning method
   with two negative sampling strategies, i.e., Homogeneous In-Batch
   Sampling (HIS) and Auxiliary Hard Negative Sampling (AHNS), to fine-tune
   the embedding model. We also design instruction templates to fine-tune
   the LLM using Continue Pre-Training (CPT) and Retrieval Augmented
   Fine-Tuning (RAFT). In the second component, we develop an efficient
   RAG-based QA system process for online deployment. We gather
   enterprise-specific data from the domain of cloud computing, and our
   extensive experiments on the data demonstrate that the proposed methods
   outperforms counterparts on various QA tasks which have different
   difficulty levels. The experiments also illustrate a practical
   application of the proposed methodology in real-world enterprise-level
   scenarios.},
