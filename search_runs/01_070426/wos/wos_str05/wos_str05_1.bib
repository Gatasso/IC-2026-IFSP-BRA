@article{ WOS:001719957300001,
Author = {Ali, Sijjad and Talpur, Dhani Bux and Humayun, Mamoona and Almufareh,
   Maraam Fahaad and Alwakid, Ghadah Naif and Yaqoob, Jahanzaib},
Title = {The double-edged sword: LLM operations (LLMOps) security in the cloud- a
   comprehensive review},
Journal = {NEUROCOMPUTING},
Year = {2026},
Volume = {680},
Month = {JUN 1},
Abstract = {The rapid integration of Large Language Models (LLMs) into enterprise
   applications via cloud platforms has necessitated the emergence of LLM
   Operations (LLMOps)-a specialized discipline for managing the LLM
   lifecycle. While LLMOps streamlines development and maintenance, it
   introduces a complex and novel attack surface that traditional
   cybersecurity frameworks face significant challenges in addressing. This
   review paper provides a comprehensive analysis of the double-edged sword
   of LLMOps security within cloud environments. We systematically examine
   the LLMOps lifecycle to expose critical vulnerabilities, beginning at
   the API layer with sophisticated prompt injection and jailbreaking
   techniques that subvert model behavior. The analysis extends to the core
   infrastructure, examining the security of vector databases-a prime
   target for data exfiltration or poisoning-and the integrity of the
   retrieval-augmented generation (RAG) pipeline. Furthermore, we
   investigate the significant privacy and security risks associated with
   the fine-tuning phase in the cloud, where proprietary data used for
   adaptation becomes vulnerable to exposure or inference attacks. This
   paper argues that the interconnected nature of cloud-based LLMOps
   amplifies these threats, creating cascading risks across the entire
   system. By synthesizing current research and emerging threats, this
   review aims to establish a foundational security taxonomy for LLMOps and
   proposes a proactive, defense-in-depth strategy essential for securing
   the next generation of AI-driven applications in the cloud. The findings
   underscore an urgent need for robust security paradigms blueconstructed
   into the fabric of LLMOps practices.},
