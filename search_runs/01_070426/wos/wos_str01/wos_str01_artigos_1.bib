@article{ WOS:001640740000005,
Author = {Jiang, Aiwen and Wang, Duan and Peng, Chao and Wang, Mingwen},
Title = {Relational reasoning image captioning via multi-agent
   retrieval-augmented generation},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2026},
Volume = {333},
Month = {JAN 30},
Abstract = {Recent advancements in training-free image captioning leverage
   multimodal large language models to extract visual details as contextual
   prompts for caption generation. However, existing approaches suffer from
   two critical limitations. (1) They often overemphasize on individual
   entity attributes while neglecting critical inter-entity relationships.
   (2) They fail to prioritize salient subjects over background content,
   disregarding linguistic prominence conventions. In this paper, we have
   proposed a novel relational reasoning image captioning framework to
   address them. Specifically, since inter-entity relationships are crucial
   for comprehensive scene understanding, to overcome the first limitation,
   we have novelly proposed to construct extensible entity interaction
   relationship memory for Retrieval-Augmented Generation. It enables the
   proposed model dynamically generate inter-entity relationships and
   adaptively expand novel interaction scenarios with minimal computational
   overhead. We have further proposed a multi-agent-based approach to
   detect and remove hallucination in the initially generated inter-entity
   relationships. As for the second limitation, to systematically evaluate
   the importance of objects, we have moreover proposed a novel
   significance scoring algorithm that measures the relative saliency of
   all image elements. Our proposed image captioning framework requires
   neither training nor fine-tuning. Experimental validation on public
   datasets demonstrates that our proposed model can achieve significant
   improvements in both semantic completeness and descriptive accuracy,
   delivering competitive performance with minimal hardware requirements,
   when compared to existing state-of-the-art baselines.},
