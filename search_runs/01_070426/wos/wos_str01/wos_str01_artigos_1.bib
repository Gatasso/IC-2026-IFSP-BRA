@article{ WOS:001683657600001,
Author = {Wang, Xinheng and Xie, Lun and Wang, Mengsheng and Wang, Zhiliang},
Title = {Textualized multimodal priors and gated causal explanations for emotion
   recognition in conversations: a unified LLM framework},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {311},
Month = {MAY 15},
Abstract = {Large language models (LLMs) have recently shown strong performance on
   Emotion Recognition in Conversations (ERC), but existing methods still
   underuse multimodal cues, overlook intra-and inter-speaker dynamics, and
   rarely model causal mechanisms explicitly. These limitations increase
   the risk of misclassification under cross-speaker dependencies,
   multi-sentence reasoning, and abrupt semantic shifts. We propose
   TEMPO-LLM, a framework that unifies textualized multimodal priors and
   gated causal explanations within an LLM. TEMPO-LLM uses the Big Five
   (OCEAN) personality model as a speaker-level prior over stable affective
   style, converts acoustic features into audio cue prompts (ACP), and
   summarizes facial expressions, body language, and posture into
   behavioral cue prompts (BCP). This design allows the LLM to incorporate
   acoustic and visual information through text-only inputs without
   architectural modifications. On top of these priors, we introduce
   GateRAG-CE, a gated retrieval-augmented generation module that, when
   activated, fuses in-dialogue evidence with commonsense causal knowledge
   from ATOMIC to produce causal prompts that fill implicit reasoning gaps.
   The dialogue context, OCEAN prior, ACP, BCP, and GateRAG-CE outputs are
   jointly fed into the LLM for emotion inference and calibration. With
   parameter-efficient fine-tuning on MELD and IEMOCAP, TEMPO-LLM achieves
   weighted-F1 scores of 70.10 and 71.76, respectively, outperforming
   multiple state-of-the-art baselines and other LLM-based ERC models.},
