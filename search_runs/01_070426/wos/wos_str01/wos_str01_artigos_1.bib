   Shen, Liu and Guo, Zhen and Pu, Siyue and Lin, Yan},
Title = {MedScaleRE-PF: a prompt-based framework with retrieval-augmented
   generation, chain-of-thought, and self-verification for scale-specific
   relation extraction in Chinese medical literature},
