@article{ WOS:001695196800001,
Author = {Lin, Jia and Chen, Chong and Wang, Tao and Wang, Zhuowei and Cheng,
   Lianglun},
Title = {A Multi-Agent and synergistic Knowledge Graph retrieval-augmented
   generation framework for intelligent maintenance},
Journal = {JOURNAL OF MANUFACTURING SYSTEMS},
Year = {2026},
Volume = {85},
Pages = {557-570},
Month = {APR},
Abstract = {As industrial equipment is increasingly applied in manufacturing, it is
   necessary to adopt advanced maintenance techniques to ensure stable
   equipment operation. Maintenance decision support is essential for
   industrial equipment, but information fragmentation and complex
   reasoning hinder its progress. To address these challenges, we propose
   MAKG (Multi-Agent and synergistic Knowledge Graph), a framework that
   synergizes Retrieval-Augmented Generation (RAG) with a multi-agent
   system for intelligent industrial equipment maintenance. The MAKG
   framework uses these Large Language Models (LLM) agents to work
   together, drawing information from a diverse knowledge base to produce
   coordinated responses to equipment faults. Our method focuses on
   fine-tuning the embedding models with domain-specific data. This
   approach avoids the high computational cost of re-training the entire
   LLM and improves performance in the specific industrial context. In the
   experimental study, the MAKG framework was validated using real-world
   industrial operation and maintenance data, achieving a reasoning
   accuracy of 90.1\% and demonstrating its potential for intelligent
   maintenance of industrial equipment. Code is available at
   https://github.com/LAM2360/MAKG\_demo/tree/ master.},
