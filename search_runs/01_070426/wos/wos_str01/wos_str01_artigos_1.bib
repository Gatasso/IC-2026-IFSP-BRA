@article{ WOS:001670088600001,
Author = {Yang, Dongju and Wang, Junming},
Title = {HiSem-RAG: A Hierarchical Semantic-Driven Retrieval-Augmented Generation
   Method},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2026},
Volume = {16},
Number = {2},
Month = {JAN 15},
Abstract = {Traditional retrieval-augmented generation (RAG) methods struggle with
   hierarchical documents, often causing semantic fragmentation, structural
   loss, and inefficient retrieval due to fixed strategies. To address
   these challenges, this paper proposes HiSem-RAG, a hierarchical
   semantic-driven RAG method. It comprises three key modules: (1)
   hierarchical semantic indexing, which preserves boundaries and
   relationships between sections and paragraphs to reconstruct document
   context; (2) a bidirectional semantic enhancement mechanism that
   incorporates titles and summaries to facilitate two-way information
   flow; and (3) a distribution-aware adaptive threshold strategy that
   dynamically adjusts retrieval scope based on similarity distributions,
   balancing accuracy with computational efficiency. On the domain-specific
   EleQA dataset, HiSem-RAG achieves 82.00\% accuracy, outperforming HyDE
   and RAPTOR by 5.04\% and 3.98\%, respectively, with reduced
   computational costs. On the LongQA dataset, it attains a ROUGE-L score
   of 0.599 and a BERT\_F1 score of 0.839. Ablation studies confirm the
   complementarity of these modules, particularly in long-document
   scenarios.},
