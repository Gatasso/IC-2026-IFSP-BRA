@article{ WOS:001628468100001,
Author = {Xiong, Yunxuan and Chen, Yuntao and Zhang, Hai},
Title = {ICR: A framework for resolving knowledge conflicts in
   retrieval-augmented generation},
Journal = {NEUROCOMPUTING},
Year = {2026},
Volume = {664},
Month = {FEB 1},
Abstract = {Retrieval-Augmented Generation (RAG) systems often exhibit irrational
   and inconsistent behavior when reconciling conflicts between internal
   parametric knowledge and externally retrieved evidence. This critical
   issue significantly undermines system reliability and practical
   applicability. Current approaches often lack a reliable and intelligent
   decision-making mechanism when confronted with such knowledge conflicts,
   struggling to effectively reconcile inconsistencies between information
   from different sources. To address this issue, this paper introduces the
   Internalized Conflict Resolution (ICR) framework. It systematically
   defines eight typical categories of knowledge conflict scenarios and
   leverages Direct Preference Optimization (DPO) for training. This
   process internalizes human-desired conflict resolution logic into the
   model's parameters, enabling it to autonomously call and execute
   appropriate solution strategies based on human instructions.Experimental
   results demonstrate that the ICR framework significantly enhances the
   model's robustness in decision-making and generalization capability in
   conflict scenarios, outperforming existing baseline methods on datasets
   such as TriviaQA and NQ. This study provides an effective solution for
   building stable and trustworthy RAG systems, facilitating the evolution
   of large language models from passive information processors into
   proactive, rational decision-makers.},
