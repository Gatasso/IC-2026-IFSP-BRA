@article{ WOS:001691787700001,
Author = {Kamalipour, Amir Abbas and Asadi, Shahrokh and Chimeh, Mohammad Mahyar
   Amiri},
Title = {From vectors to knowledge graphs: A comprehensive analysis of modern
   retrieval-augmented generation architectures},
Journal = {COMPUTER SCIENCE REVIEW},
Year = {2026},
Volume = {61},
Month = {AUG},
Abstract = {Large Language Models (LLMs) suffer from hallucination, a systemic
   weakness that erodes trust by producing con fident but factually
   incorrect content, especially in high-stakes settings.
   Retrieval-Augmented Generation (RAG) directly addresses this limitation
   by tightly coupling generation to verifiable, up-to-date evidence. This
   com prehensive survey introduces a unified four-stage taxonomy of
   Indexing, Retrieval, Fusion, and Generation that deconstructs modern RAG
   architectures and provides a common lens for comparing systems. Drawing
   on more than 300 references, we analyze the full spectrum from
   foundational Vector RAG to the multi-hop reasoning capa bilities of
   Graph RAG, and we chart emerging paradigms such as Agentic RAG,
   Multimodal RAG, Hybrid RAG, and reasoning-centric variants. Beyond
   architectural taxonomies, we provide a deep implementation-oriented
   treat ment of indexing and similarity search, including a practical
   comparison of leading vector databases and graph databases for
   real-world deployments. We further present a comprehensive benchmark
   comparison that unifies evaluation datasets and metrics for both
   vector-and graph-based pipelines, and we consolidate trade-offs across
   representative RAG strategies in a comparison of key approaches.
   Together, these contributions position RAG as a mature design pattern
   for building grounded, auditable AI systems and offer practitioners,
   graduate students, and researchers a structured roadmap from basic
   pipelines to advanced, evidence-based reasoning systems.},
