@article{ WOS:001631989600002,
Author = {Zou, Yingqi and Wang, Shaohan and Li, Guanyu and Ning, Bo},
Title = {MaRAG: a knowledge graph and retrieval-augmented framework for maritime
   accident analysis},
Journal = {OCEAN ENGINEERING},
Year = {2026},
Volume = {344},
Month = {JAN 15},
Abstract = {Maritime transportation underpins global trade and energy supply,
   however, growing fleet sizes, complex vessel systems, and evolving
   regulatory and environmental pressures necessitate more intelligent
   approaches to accident prevention, response, and analysis. Traditional
   knowledge management systems-reliant on expert experience and static
   databases-struggle with heterogeneous data, temporal-causal dynamics,
   and cross-disciplinary integration. Existing data-driven methods often
   lack structural grounding, reasoning-aware querying, and result
   traceability. To address these gaps, we propose MaRAG, a multi-agent
   framework that defines a new form of knowledge representation through a
   hierarchical, cascade-enhanced ontology and co-designs tailored
   retrieval and inference workflows. MaRAG integrates ontology-guided
   knowledge graph construction, Optimal Transport-based feature alignment,
   dual-database storage, and an intelligent, multi-paradigm retrieval
   mechanism. Experiments and case studies show that MaRAG significantly
   outperforms LLM-and RAG-based baselines in maritime accident
   Question-Answering and causal reasoning, achieving higher Exact Match,
   Precision, and F1 scores across varying knowledge graph scales. Analyses
   confirm its ability to reduce knowledge fragmentation and deliver a
   scalable, interpretable system for maritime safety decision-making.},
