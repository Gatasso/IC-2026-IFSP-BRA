@article{ WOS:001671038600002,
Author = {Vidyarthi, Aditi and Singh, Khoirom Motilal and Moirangthem, Dennis
   Singh},
Title = {SageRAG: Query rewriting for retrieval enhancement and
   retrieval-augmented generation for grounded responses in AI research
   assistance},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {308},
Month = {MAY 1},
Abstract = {In today's academic and technical landscape, researchers and learners
   often struggle to retrieve accurate, verifiable, and contextually sound
   information in response to open-ended or exploratory queries. While
   Large Language Models (LLMs) have proved significantly promising in
   natural language understanding and generation, they face critical
   limitations when employed in knowledge-intensive tasks in domains such
   as academic research, engineering fundamentals, computer science etc: 1)
   They are prone to hallucination and lack factual consistency. 2) They
   offer poor support for vague or ill-defined queries. 3) They seldom
   offer source citations or access to contemporary scholarly work.
   Contemporary Retrieval-Augmented Generation (RAG) methods partly
   mitigate these issues but often depend on static knowledge bases,
   limiting their adaptability to new or niche topics. We propose SageRAG,
   a domain-aware AI research assistant that delivers precise, grounded,
   and contextually rich responses. By integrating structured retrieval
   with adaptive generation, SageRAG enables reliable access to both
   foundational and emerging academic knowledge. It serves as a scalable,
   trustworthy solution for students, educators, and researchers seeking
   support in complex, evolving fields.},
