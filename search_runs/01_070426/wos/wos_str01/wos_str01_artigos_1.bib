@article{ WOS:001611233000002,
Author = {Zhang, Lanqian and Ning, Yan},
Title = {Improving construction contract question answering through embedding
   optimization and semantic chunking in large language models},
Journal = {ADVANCED ENGINEERING INFORMATICS},
Year = {2026},
Volume = {69},
Number = {C},
Month = {JAN},
Abstract = {Construction contract question answering (QA) is a knowledge-intensive
   task and requires timely responses to inquiries from multiple parties,
   but faces challenges in both accuracy and efficiency. Large Language
   Models (LLMs) excel at general-domain QA, but often show biases and
   hallucinations in specific domains. Although Retrieval-Augmented
   Generation (RAG) improves LLMs' performance with external knowledge, its
   effectiveness is limited due to the scarcity of domain-specific data and
   the poor segmentation and organization of documents. To address these
   challenges, this research proposes a domain-adapted RAG strategy for
   construction contracts (CC-RAG) to enhance QA performance. The core
   improvements of CC-RAG include two aspects. First, this research employs
   a hierarchical approach to transform normative construction contract
   documents into structured basic knowledge units. High-quality
   ``question-knowledge{''} pairs are then automatically generated using
   online LLMs. These pairs are used to fine-tune the embedding model for
   domain adaptation, improving semantic retrieval accuracy. Second,
   knowledge units are automatically segmented based on semantic
   similarity. They are organized using hierarchical clustering to form
   coherent chunk structures, improving both integrity and accessibility of
   the retrieved knowledge. The evaluation results show that CC-RAG
   achieves performance gains of 0.5\% to 20\% over base LLMs and
   traditional RAG strategies in construction contract QA tasks.
   Furthermore, CC-RAG can be deployed on a local 7B-parameter model while
   outperforming a 671B-parameter online model by 4 percentage points in QA
   accuracy. These findings demonstrate that CC-RAG improves QA
   performance. It also achieves a cost-effective balance of performance,
   offering a viable solution for deploying small-scale models in
   intelligent construction management.},
