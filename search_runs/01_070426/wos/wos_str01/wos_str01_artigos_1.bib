@article{ WOS:001707359300001,
Author = {Malik, Muhammad Shahid and Le, Van The and Ou, Yu-Yen},
Title = {Enhancing the classification of metal-binding residue in proteins with
   retrieval-augmented generation, protein language models, and deep
   learning},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {171},
Month = {MAY 1},
Abstract = {Metal ions are essential for protein structure, molecular recognition,
   and enzymatic catalysis, making accurate identification of metal-binding
   residues crucial for drug discovery, enzyme engineering, and
   metalloprotein research. Although computational approaches are scalable
   and cost-effective, residue-level metal-binding prediction remains
   challenging due to extreme class imbalance, where binding residues are
   outnumbered by non-binding ones, causing standard deep learning models
   to favor the majority class. We propose a novel framework that
   integrates Retrieval-Augmented Generation (RAG), Protein Language Models
   (PLMs), and a Positional Attention Transformer Network (PATN). Starting
   from 14,894 proteins curated from Littmann et al. Cluster Database at
   High Identity with Tolerance (CD-HIT) (<20\% sequence identity) yielded
   579 non-redundant metal-binding proteins, resulting in a
   binding-non-binding residue ratio of approximately 1:32. To overcome the
   limitations of sequence-based models, RAG is introduced as a dynamic
   oversampling strategy that explicitly incorporates structural context.
   For each query, the model retrieves and averages the top five most
   similar 15-residue ProtTrans embeddings from a curated database of 1948
   non-redundant metal-binding proteins (zinc, manganese, magnesium, and
   calcium; <30\% sequence identity), enriching local representations with
   binding-relevant contextual signals. The fused embeddings are
   subsequently processed by PATN for classification. The proposed model
   achieved an Area Under the Receiver Operating Characteristic Curve (AUC)
   of 0.8810 and a recall of 0.7729 on an independent test set, and further
   demonstrated strong generalization on 15 newly reported proteins (AUC =
   0.9586, recall = 0.896). Despite reduced precision, the method
   outperforms bindEmbed21 with a >200\% relative recall improvement,
   establishing an effective high-sensitivity screening tool for
   metal-binding site discovery.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
Address = {THE BOULEVARD, LANGFORD LANE, KIDLINGTON, OXFORD OX5 1GB, ENGLAND},
