@article{ WOS:001639998800004,
Author = {Wu, Yongliang and Wang, Kang},
Title = {Multi-model pseudo-document generation and reconstruction for hybrid
   query expansion},
Journal = {INFORMATION PROCESSING \& MANAGEMENT},
Year = {2026},
Volume = {63},
Number = {3},
Month = {APR},
Abstract = {Query expansion aims to bridge the vocabulary gap between queries and
   documents, enhancing retrieval effectiveness. However, traditional
   methods often exhibit insufficient diversity in contextual expansion and
   poor semantic relevance, undermining essential processes such as
   query-document relevance estimation and ranking accuracy, ultimately
   leading to suboptimal retrieval performance. To overcome these
   limitations, we propose the Multi-Model PseudoDocument Generation and
   Reconstruction for Hybrid Query Expansion (MPQE), a novel hybrid
   framework that exploits the complementary strengths of multiple large
   language models (LLMs) by generating and consolidating pseudo-documents
   for hybrid query expansion. Initially, pseudodocuments are produced by
   different LLMs, capturing diverse contextual nuances through their
   complementary capabilities. Subsequently, each document is segmented
   into semantic units, filtered via semantic clustering, and reconstructed
   into a concise pseudo-document. Finally, the original query is combined
   with the restructured document to form the expanded query. By
   integrating multiple LLMs' linguistic and semantic strengths, MPQE
   mitigates vocabulary and semantic mismatches, thereby enhancing
   retrieval effectiveness. Experimental results demonstrate that MPQE
   yields 3\%-17\% improvement in BM25 effectiveness on the MS MARCO and
   TREC DL benchmarks without model fine-tuning and achieves an average 3\%
   nDCG@10 gain across five out-of-domain datasets (DBpedia, NFCorpus,
   Scifact, Trec-Covid, Touche2020), underscoring its robustness and
   generalizability. Given our current literature survey, MPQE represents a
   promising research direction for enhancing retrieval-augmented systems
   through query expansion.},
