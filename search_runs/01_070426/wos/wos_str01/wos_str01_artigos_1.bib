@article{ WOS:001640101800001,
Author = {Malik, Muhammad Shahid and Hussain, Muhammad and Ho, Quang-Thai and Le,
   Van-The and Ou, Yu-Yen},
Title = {RAG-msCNN: predicting protein-DNA binding sites by integration of
   retrieval-augmented generation (RAG) with protein language models and
   the multi-scale separable convolutional neural network},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2026},
Volume = {115},
Month = {APR 15},
Abstract = {Background and objective: Protein function and molecular regulatory
   mechanisms require the precise identification of nucleic acid-binding
   residues. Although some more recent deep learning algorithms have
   advanced, it is still challenging to extract contextual information
   specific to residues from sequences. Methods: In this paper, we propose
   a novel deep learning architecture called RAG-msCNN that improves
   sequence representation by combining Retrieval-Augmented Generation
   (RAG) with Multi-Scale Separable Convolutional Neural Networks (msCNN).
   Our approach shows better generalization and robustness on benchmark
   DNA-and RNA-binding datasets even without structural input. Results: Our
   method improves performance on several benchmark datasets, such as TE46,
   TE181, and TE129, by combining protein language models with multi-scale
   feature learning and residue-specific RAG integration. Our framework is
   better than other methods, with an AUC of up to 99.9 \% and an F1 score
   of more than 91 \%. This shows that it can accurately and reliably find
   metal-binding sites. Conclusions: The framework is a scalable and robust
   solution for predicting residue-level interactions, and it generalizes
   well to both DNA and RNA interaction tasks. This work provides a strong
   and comprehensible tool for nucleic acid-binding prediction and protein
   functional annotation in situations with limited data or structured and
   unbalanced datasets.},
