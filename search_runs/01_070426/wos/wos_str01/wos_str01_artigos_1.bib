@article{ WOS:001490483700002,
Author = {Chen, Xiaodao and Liu, Yupeng and Han, Wei and Zheng, Xiongwei and Wang,
   Sheng and Wang, Jun and Wang, Lizhe},
Title = {A vision-language foundation model-based multi-modal retrieval-augmented
   generation framework for remote sensing lithological recognition},
Journal = {ISPRS JOURNAL OF PHOTOGRAMMETRY AND REMOTE SENSING},
Year = {2025},
Volume = {225},
Pages = {328-340},
Month = {JUL},
Abstract = {In recent decades, severe environmental pollution and resource scarcity
   have made it increasingly urgent to monitor the distribution and changes
   of surface geological environmental elements. As the main components of
   geological environmental elements, different types of lithology are
   characterized by their diversity, fragmented distribution, and ambiguous
   boundaries. Remote sensing images have further reduced the distinctions
   between different lithological categories, making remote sensing
   lithology interpretation more challenging compared to conventional
   remote sensing tasks. Data-driven deep learning methods struggle to
   match manual lithological interpretation due to the lack of large-scale,
   high-quality data. Recently, models like SAM and GPT have provided
   insights into building universal, generalizable AI models. However,
   these models face difficulties in handling multi-modal geological remote
   sensing data and cannot effectively organize fragmented and ambiguous
   geological knowledge, resulting in limited generalization capabilities
   in lithological interpretation. To effectively address the bottlenecks
   of existing foundation models and improve lithological interpretation
   performance, this paper proposes a Multi-modal Retrieval-Augmented
   Generation approach for geological lithology identification (Geo-MMRAG).
   Based on existing books, reports, and data, we establish a multi-modal
   geological remote sensing knowledge base and an efficient embedding
   representation. Furthermore, for any query images and text, this method
   conducts knowledge retrieval to establish relevant multi-modal knowledge
   prompts. The pre-trained foundation model will generate final
   lithological category predictions based on the prompts and queries.
   Extensive experiments conducted on two lithology datasets demonstrate
   that our method effectively integrates pre-trained remote sensing
   foundation models with expert knowledge, achieving significantly
   enhanced lithological interpretation without additional training costs.},
