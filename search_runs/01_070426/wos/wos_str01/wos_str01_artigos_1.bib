   Bauernhansl, Thomas, Univ Stuttgart, Inst Ind Fertigung \& Fabrikbetrieb IFF, Nobelstr 12, D-70569 Stuttgart, Germany.},
DOI = {10.1016/j.compind.2025.104330},
