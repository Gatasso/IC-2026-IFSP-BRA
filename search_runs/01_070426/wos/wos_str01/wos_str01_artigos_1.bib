@article{ WOS:001519069400001,
Author = {Jeong, Yeon-Bi and Seo, Hong-il and Kim, Yoo-Hwan and Kim, Won-Yeol},
Title = {Retrieval-augmented visual parcel invoice understanding transformer for
   address correction},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2025},
Volume = {158},
Number = {B},
Month = {OCT 22},
Abstract = {In automated postal and logistics operations, Visual Parcel Invoice
   Understanding technology (VPIU) addresses the challenging task of
   recognizing named entities such as addresses, names, and phone numbers.
   In particular, the VPIU performance is significantly reduced when the
   addresses are extracted. Therefore, we propose a novel
   Retrieval-augmented-VPIU model (Re-VPIU). The proposed Re-VPIU consists
   of a Document Understanding Transformer (DONUT) for information
   extraction and a Large Language Model (LLM) with Retrieval-Augmented
   Generation (RAG) for information correction. First, using an end-to-end
   approach, the DONUT extracts information regarding addresses, names, and
   phone numbers from the invoice images. Next, the RAG detects and
   corrects errors in the extracted address information according to the
   Korean address database and prompts. Proposed Re-VPIU model is the first
   application of RAG in the context of visual document understanding.
   Unlike traditional models, Re-VPIU does not require retraining to
   incorporate new address data, as it dynamically integrates external
   knowledge through retrieval. Furthermore, it enables both character- and
   word-level corrections simultaneously, leveraging the linguistic
   capabilities of LLMs. To validate the proposed method's effectiveness,
   several comparative experiments were conducted using a Korean invoice
   dataset. The experiments showed that the proposed method achieved an F1
   Score of 83.42 \% when evaluating the accuracy of the complete
   extraction, which was 12.17 \% higher than that of the current
   state-of-the-art model.},
