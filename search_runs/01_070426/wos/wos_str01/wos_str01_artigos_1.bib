@article{ WOS:001611121300002,
Author = {Peng, Sisi and Zhang, Wenlin and Li, Shunhang and Qu, Dan},
Title = {QR3AG: Dynamic Retrieval-Augmented Generation via Query-Response
   Relevance Threshold Judgement},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {299},
Number = {C},
Month = {MAR 1},
Abstract = {Large Language Models (LLMs) excel in general tasks but struggle with
   domain-specific and knowledge-intensive scenarios due to hallucinations,
   outdated knowledge and redundancy in retrieved content. While
   Retrieval-Augmented Generation (RAG) mitigates these issues by
   integrating external knowledge, existing methods rely on static
   retrieval strategies that indiscriminately inject information, ignoring
   critical factors such as retrieval accuracy and knowledge redundancy,
   which degrade response quality. To address this, we propose
   Query-Response Relevance Retrieval-Augmented Generation (QR3AG), a novel
   framework that dynamically determines retrieval necessity by evaluating
   the intrinsic relevance between LLM-generated responses and user
   queries. To determine the retrieval judgement threshold, we use a
   three-agent system (generator, debater, verifier) to automatically
   constructs high-quality retrieval judgment data (ReJudGE), balancing
   task diversity and label consistency. Experiments on four long-form
   datasets demonstrate QR3AG's superiority: the retrieval judgment
   accuracy increased by 7.5 \%, and the responses showed improvements of
   3.24 in BLEU-2 and 0.41 in ROUGE-2 scores, effectively enhancing the
   model's performance in task completion. In addition, QR3AG achieves a
   50.5 \% reduction in retrieval rate versus traditional RAG frameworks.
   QR3AG bridges the gap between static retrieval and dynamic knowledge
   integration, offering a scalable solution for real-time systems and
   low-resource environments.},
