   Iyenghar, Padma; Mansour, Zaher; Wuebbelmann, Juergen, Univ Appl Sci Osnabruck, Fac Engn \& Comp Sci, D-49076 Osnabruck, Germany.},
DOI = {10.1109/ACCESS.2025.3632528},
