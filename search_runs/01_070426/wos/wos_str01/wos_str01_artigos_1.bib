@article{ WOS:001707678000001,
Author = {Liang, Ming and Zhang, Luyao and Yan, Jun and Wang, Shanshan and Liu,
   Chengchen},
Title = {Natural language-driven water quality inversion using LLMs and cloud
   platforms},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {This study presents a water quality retrieval framework that combines
   natural language-driven large language models (LLMs) with Google Earth
   Engine, aiming to simplify traditional remote sensing monitoring by
   reducing its dependence on specialized knowledge and technical
   procedures. Through the integration of a retrieval-augmented generation
   (RAG) mechanism, the framework achieves strong performance in complex
   water quality tasks, with a task parsing consistency of 0.92, a spatial
   matching rate of 94\%, and a temporal matching rate of 93\%, markedly
   outperforming zero-shot and few-shot approaches. Evaluation on water
   quality semantic tasks shows that RAG achieves an accuracy of 0.72, a
   recall of 0.91, and an F1-score of 0.79 in classification tasks, as well
   as a mean reciprocal rank of 0.85, top-1 accuracy of 0.73, and top-3
   accuracy of 0.97 in ranking tasks, demonstrating the effectiveness of
   the framework in identifying key spatiotemporal constraints and
   prioritizing high-quality remote sensing data. The RAG-enhanced
   Qwen2.5-Coder model attains an executable code rate of 87\%,
   substantially improving the translation of natural language queries into
   operational water quality retrieval workflows. When combined with
   visualization and LLM-generated summaries, the average interpretability
   confidence score reaches 4.16, making the results accessible and
   reliable even for non-expert users. Overall, the framework reduces
   technical barriers, optimizes the use of remote sensing imagery, and
   provides a scalable solution for intelligent water quality monitoring
   and complex ecological applications.},
