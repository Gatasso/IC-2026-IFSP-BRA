@article{ WOS:001722043100001,
Author = {Wang, Qian and Ma, Hongyi and Hu, Jing and Dong, Xiuying and Zhang, Peng
   and Yao, Xu and Zhang, Chong and Chen, Yan},
Title = {Multi-agent cooperation for smart gas reservoir management},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {319},
Month = {JUL 5},
Abstract = {Traditional multi-modal large models (MLMs) often rely on rigid
   reasoning chains and static modality pipelines, limiting their
   flexibility, robustness, and domain adaptability in complex industrial
   environments. In smart gas reservoir systems operating as large-scale
   industrial IoT ecosystems, these limitations hinder reliable integration
   of heterogeneous sensing data and timely decision-making under dynamic
   operational constraints. To address these challenges, we propose
   Multi-Agent Cooperation for Smart Gas Reservoir Management (MASG), a
   modular multi-agent framework that enables interpretable, secure, and
   scalable decision workflows for multimodal industrial applications.
   Designed as a supervisory cognitive layer compatible with existing
   Industrial Control Systems (ICS) and legacy data platforms, MASG
   integrates seamlessly with operational infrastructure without disrupting
   underlying control architectures. MASG decomposes complex tasks into
   role-specialized agents with structured perception, memory,
   communication, planning, and execution capabilities, and incorporates
   Retrieval-Augmented Generation (RAG) to ensure factual grounding over
   domain knowledge. Beyond system design, we systematically investigate
   topology-aware multi-agent orchestration from a Quality-of-Service (QoS)
   perspective by quantitatively comparing centralized, hierarchical, and
   graph-based communication structures under unified evaluation protocols.
   Experimental results demonstrate that appropriate topology selection
   significantly improves reasoning consistency, communication efficiency,
   robustness to partial agent failure, and overall system scalability.
   MASG has been deployed in JiangHan Oilfield using proprietary datasets,
   validating its practical effectiveness for intelligent information
   retrieval, multimodal data integration, and real-time operational
   decision support.},
