@article{ WOS:001700663300001,
Author = {Venkatesh, Pruthvi Raj and Krishna, Radha},
Title = {OntoLLM: Enhancing LLM grounding and digression prevention with
   ontologies and knowledge graphs},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {314},
Month = {JUN 5},
Abstract = {Large Language Models face significant challenges in industrial
   conversational AI applications, particularly in maintaining context
   coherence and preventing topic digression across complex, domain
   conversations. Traditional Retrieval-Augmented Generation systems
   struggle with semantic disambiguation when similar content exists across
   different documents, leading to cross-contamination in extended
   conversations. This paper introduces OntoLLM, a novel framework that
   integrates ontologies and knowledge graphs with LLMs to address these
   limitations. OntoLLM employs a unified knowledge graph integration
   approach that bridges structured domain knowledge with unstructured
   document content through innovative ``Question{''} nodes, enabling
   precise semantic disambiguation. The framework incorporates dual query
   handlers for structured and unstructured information retrieval, along
   with ontology-guided related question generation to prevent
   conversational drift. We evaluate OntoLLM across four industrial
   datasets spanning exploration plans, pipeline management, employee
   policies, and motor manuals. Experimental results demonstrate
   substantial improvements where OntoLLM achieves 91-93\% precision@5
   compared to 63-71\% for baseline systems, BLEU-4 scores of 87.8-92.3
   versus 72.1-79.8 for standard RAG, and maintains 63\% better context
   preservation with steering effectiveness exceeding 73\% across
   multi-turn conversations. Ablation studies reveal that unified knowledge
   graph integration provides the most critical contribution, with its
   removal causing 20 percentage point drops in precision and 15.3 point
   decreases in BLEU-4 scores.These findings establish OntoLLM as a robust
   solution for deploying reliable, context-aware conversational AI systems
   in complex industrial environments.},
