@article{ WOS:001711098700007,
Author = {Nithyashree, M. and Nadgir, Krupa P. and Prithiviraj, N. and Padmasali,
   Manasvini G. and Hegde, Deeksha and Shetty, Jyoti and Vinod, A. R.},
Title = {Multimodal Urban Heat Island Mitigation via Knowledge Reasoning and
   Geospatial Optimization},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {35182-35195},
Abstract = {Urban Heat Island (UHI) mitigation requires scientifically grounded and
   spatially actionable strategies that move beyond descriptive assessment
   toward prescriptive urban design. However, existing approaches offer
   limited support for generating location-specific, optimised cooling
   solutions. To address this gap, this paper presents a dual-mode
   framework that integrates passive knowledge-driven recommendations with
   active geospatial Land Use/Land Cover (LULC) optimisation for
   data-informed urban cooling. The passive mitigation pathway employs a
   Hybrid Retrieval-Augmented Generation (RAG) pipeline that fuses dense
   and sparse retrieval over a curated corpus of peer-reviewed research and
   policy literature, enabling evidence-based and domain-validated textual
   recommendations for generalised UHI mitigation strategies. Complementing
   this, the active pathway integrates computer vision, graph-based
   learning, and evolutionary optimisation to generate optimised LULC
   suitability maps of the region of interest for targeted cooling up to 3
   degrees C. A Genetic Algorithm (GA) guided by a Graph Neural Network
   (GNN) evolves the spatial configurations to maximise thermal efficiency
   while maintaining urban functionality. Despite the inherent complexity
   of urban micro-climates, the trained GNN attained an R-2 score of 0.387
   and an RMSE of 0.793, enabling reliable comparative evaluation of
   alternative mitigation scenarios. For a representative case study, a 2
   degrees C cooling objective was achieved for Bengaluru through a 32\%
   increase in strategically allocated green cover, while preserving urban
   infrastructure and spatial coherence. The entire framework is deployed
   as a web-based geospatial intelligence platform, featuring an
   interactive 3D visualisation engine for rendering GA-optimised
   landscapes, quantitative dashboards for assessing the mitigation
   effectiveness, and an integrated suite of insight tools offering
   city-to-city comparative analysis, country-wise hotspot identification,
   and automated report generation. Overall, this work presents an
   end-to-end, scalable solution that equips urban planners, policymakers,
   and researchers with actionable intelligence to build more
   climate-resilient cities.},
