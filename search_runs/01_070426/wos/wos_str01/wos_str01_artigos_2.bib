   Schulz, Tim; Moeller, Ralf, Univ Lubeck, Inst Informat Syst, Lubeck, Germany.
   Luttermann, Malte; Moeller, Ralf, German Res Ctr Artificial Intelligence DFKI, Lubeck, Germany.},
DOI = {10.1007/s13218-024-00850-z},
EarlyAccessDate = {JUL 2024},
ISSN = {0933-1875},
EISSN = {1610-1987},
Research-Areas = {Computer Science},
