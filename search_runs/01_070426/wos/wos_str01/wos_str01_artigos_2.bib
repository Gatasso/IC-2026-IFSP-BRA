@article{ WOS:001705559600001,
Author = {Zhang, Limao and Huang, Jiaxin and Chen, Chao and Ma, Ling and Luo,
   Yongqiang},
Title = {Spatio-temporal detection of building carbon emission anomalies using
   adaptive encoder-decoder deep learning},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {358},
Month = {MAY 1},
Abstract = {Anomalous energy consumption in buildings leads to substantial resource
   waste and significantly increases carbon emissions. However, existing
   technologies struggle to effectively detect anomalous carbon emission
   time series due to complex spatial distribution and uncertainty in
   energy usage patterns. To address this challenge, this study proposes a
   dual-branch anomaly detection framework based on an adaptive
   encoder-decoder architecture. The encoder integrates BiGRU and
   multi-scale CNN modules to capture spatio-temporal dependencies, while
   the decoder combines GRU and multi-head attention to predict hourly
   carbon emissions. A dynamic thresholding mechanism is further employed
   to adaptively identify anomalies. In addition, an intelligent
   interaction system integrating a large language model with a
   retrieval-augmented generation mechanism is developed to provide
   tailored decarbonization strategies based on detected anomalies. The
   proposed framework is validated through the collected data from a
   commercial building in China, achieving F1-scores of 0.835 and 0.903 for
   point and collective anomalies, respectively, with a false positive rate
   below 0.009. The interaction system responds to user queries and
   delivers actionable decarbonization recommendations. This work
   contributes a novel, interpretable, and end-to-end architecture that
   jointly captures multi-scale patterns and contextual factors of building
   operations, enabling more precise anomaly detection and
   human-in-the-loop low-carbon decision-making.},
