@article{ WOS:001720894600001,
Author = {Situ, Runwei and Cai, Yi},
Title = {Self-improving multi-agent framework for zero-shot multimodal
   information extraction},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {318},
Month = {JUL 1},
Abstract = {Zero-shot multimodal information extraction (MIE) aims to extract
   structured information from multimedia content without relying on
   annotated data, posing significant challenges due to minimal human
   intervention. Recent efforts adapt large language models (LLMs) to this
   task, leveraging their strong generalization capabilities. While
   promising, two key limitations remain: (i) most methods rely on
   single-turn or multi-turn interactions with a single LLM, which struggle
   with complex schemas, long input contexts, and nuanced instruction
   following; and (ii) demonstration retrieval is often based on shallow
   semantic similarity, neglecting entity-level relevance and misleading
   LLMs during inference. To address these challenges, we propose a
   self-improving multi-agent system (SIMAS) for zero-shot MIE. SIMAS
   comprises three specialized LLM-based agents: (i) a task-agnostic
   demonstration selector that retrieves entity-aware samples from
   unlabeled corpora, (ii) an machine reading comprehension (MRC)-based
   self-annotator that formulates annotation as a multiple-choice question
   answering (QA) task and employs a multi-agent debate (MD) mechanism for
   improved reliability, and (iii) a retrieval-augmented code generation
   predictor that reformulates MIE as structured code generation problems,
   guided by the self-annotated demonstrations. By distributing complex MIE
   problem across cooperative agents, SIMAS mitigates performance
   degradation from overloading a single agent and stimulates the
   self-learning capabilities of LLMs. Experiments on six benchmarks show
   that SIMAS consistently achieves state-of-the-art zero-shot performance,
   and remarkably, surpasses fine-tuned models trained on large-scale
   labeled data in three benchmarks.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
Address = {THE BOULEVARD, LANGFORD LANE, KIDLINGTON, OXFORD OX5 1GB, ENGLAND},
Type = {Article},
