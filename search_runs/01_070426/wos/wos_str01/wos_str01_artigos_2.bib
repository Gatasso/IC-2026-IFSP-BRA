@article{ WOS:001485423000001,
Author = {Naderi, Hossein and Shojaei, Alireza},
Title = {Large-Language model (LLM)-Powered system for Situated and Game-Based
   construction safety training},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {283},
Month = {JUL 15},
Abstract = {Construction sites are inherently hazardous, with worker behavior being
   a major contributor to accidents. While safety training is crucial for
   reducing unsafe actions, traditional methods often lack situational
   learning, overload workers, use one-size-fits-all approaches, and
   struggle linking theory to practice. This study proposes an interactive
   construction safety training framework powered by large language models
   (LLMs) and built over the foundation theories of situated and game-based
   learning. The framework has four main components: (1) a knowledge
   database of verified safety data; (2) an LLM processor generating
   hazardous scenarios and feedback; (3) situated and game-based elements
   like challenges, responses, and rewards; and (4) a frontend interface. A
   proof-of-concept prototype was successfully implemented, showcasing the
   feasibility and applicability of the platform. The system's outputs were
   evaluated using an automatic side-by-side evaluation approach. Initial
   results validate our proposed solution's ability to simulate
   personalized and realistic hazardous situations that engage safety
   learners to decide based on their safety understanding and then learn
   safety regulations through feedback. This platform can enhance training
   engagement, retention, and real-world safety behaviors. Our solution
   introduces an extensible template integrating pedagogical theories and
   AI capabilities to advance contextualized learning beyond construction
   safety training.},
