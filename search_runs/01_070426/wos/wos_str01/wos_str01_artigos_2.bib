@article{ WOS:001630707400001,
Author = {Yu, Gang and Ju, Ruibin and Sugumaran, Vijayan and Liu, Haizhu},
Title = {Lightweight multimodal LLM-empowered dual-agent collaboration for
   reliable defect detection and maintenance recommendation in tunnel
   infrastructure},
Journal = {RELIABILITY ENGINEERING \& SYSTEM SAFETY},
Year = {2026},
Volume = {268},
Month = {APR},
Abstract = {Accurate identification of tunnel defects and maintenance
   recommendations are crucial for resilient tunnel operations and
   sustainable urban underground development. Although numerous automated
   systems have been developed for tunnel defect detection, existing
   approaches struggle with limited semantic understanding, poor
   interpretability, and difficulty generating standard-compliant
   decisions. To address these challenges, this study proposes a
   lightweight multimodal LLM-empowered dual-agent collaboration framework
   for tunnel infrastructure maintenance, with three core innovations that
   advance existing research: (1) Modular Decoupling of Detection and
   Reasoning: We explicitly separate visual defect recognition (via a
   fine-tuned Qwen2.5-VL-7B vision-language model) from
   regulatory-compliant maintenance reasoning (via a LightRAG-enhanced
   agent), solving the interpretability and traceability limitations of
   end-to-end tunnel AI systems. (2) Cost-Efficient Training \& Lightweight
   Deployment: Using 4-bit quantization (Unsloth framework) and LoRA, we
   fine-tune the 7B-parameter model at similar to USD \$5 per session
   (Google Colab Pro+) and enable real-time operation on consumer-grade
   GPUs (e.g., NVIDIA RTX 4050), eliminating reliance on high-end
   proprietary hardware. (3) LightRAG-Powered Standards-Compliant
   Reasoning: The LightRAG module integrates clause-level knowledge graphs
   and hybrid vector-graph retrieval, ensuring maintenance recommendations
   strictly adhere to national/ regional standards (e.g., JT/T 790-2023)
   and mitigating LLM hallucination risks. This dual-agent design enhances
   tunnel resilience by enabling interpretable, scalable, and
   compliance-driven maintenance, with experimental validation on 8928
   Shanghai tunnel images confirming superior performance over baseline
   models by ROUGE-1 (0.8342), ROUGE-2 (0.7389), BLEU (0.68), and semantic
   similarity (0.9830) scores.},
