@article{ WOS:001510367300001,
Author = {Lin, Yuhao and Guo, Wenya and Zhang, Ying and Yang, Chengyi and Li,
   Zengxiang},
Title = {Prompt Compression based on Key-Information Density},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {284},
Month = {JUL 25},
Abstract = {Prompt compression refers to refining the retrieval outputs, providing
   more compact prompts for the downstream LLMs. Existing Prompt
   compression methods commonly require supervised training, which means
   more calculating consumption and less capability across diversified
   scenarios. Furthermore, they lack sufficient awareness of downstream
   scenarios, leading to deficiencies in the downstream generation. In this
   paper, we propose a model named Key Information Comp-ressor (KIComp),
   which can compress prompts more precisely without extra training.
   Specifically, to increase the proportion of the key information in the
   final prompt, KIComp concludes a coarse-to-fine compression: (i) We
   propose document-level Key information density scores for coarse-grained
   compression, which measure the key information density of a document
   based on its similarity to the downstream query and its utility judged
   by the model. Documents with low Key information density scores will be
   filtered out. With the coarse-grained compression, documents can be
   filtered and ranked based on their key information density. (ii) The
   fined-grained compression pays attention to the token-level key
   information density, which is the difference between the results
   generated with and without the specific query. With the fined-grained
   compression, redundant and non-informative tokens could be deleted
   accurately. We conduct experiments over the NaturalQuestions benchmark
   for RAG scenarios and the LongBench-E benchmark for long-text
   multitasks. The results show the proposed approach can reduce 75\% of
   prompt tokens in the RAG scenario, and the accuracy after prompt
   compression is higher compared to other compression methods. On the
   LongBench-E, the proposed approach achieves performance close to the
   complete prompt while using only 1/6 of the original prompt tokens.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
