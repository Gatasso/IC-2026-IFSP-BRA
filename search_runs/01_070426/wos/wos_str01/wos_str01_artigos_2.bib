Address = {VAN GODEWIJCKSTRAAT 30, 3311 GZ DORDRECHT, NETHERLANDS},
Type = {Article; Early Access},
Language = {English},
Affiliation = {Ji, YJ (Corresponding Author), Zhejiang Univ, Sch Mech Engn, State Key Lab Fluid Power \& Mechatron Syst, Hangzhou 310030, Zhejiang, Peoples R China.
   Ji, YJ (Corresponding Author), Zhejiang Univ, Zhejiang Key Lab Adv Equipment Mfg \& Measurement T, Hangzhou 310030, Peoples R China.
