@article{ WOS:001569428300001,
Author = {Schreiber, Amir and Schreiber, Ilan},
Title = {Removing unknowns: Gen-AI as a cybersecurity interactive advisor for
   human experts},
Journal = {INFORMATION AND COMPUTER SECURITY},
Year = {2026},
Volume = {34},
Number = {1},
Pages = {187-208},
Month = {JAN 20},
Abstract = {PurposeArtificial intelligence (AI) technologies offer new opportunities
   to detect and address unknown cybersecurity threats. This study aims to
   examine how AI augments human expertise in safeguarding information
   systems using an interactive AI
   conversation.Design/methodology/approachThe authors use the retrieval
   augmented generation approach for enhancing cyber intelligence driven by
   its ability to provide accurate, timely and contextually relevant
   responses. The authors have built a working application based on
   real-life security data sources and tested it through constructed
   expert-AI conversations. It enables users to ask ``How?{''} about the
   data sources informing each AI-generated response.FindingsThe authors
   have simulated full advisory sessions where the AI guided the
   cybersecurity human expert step by step in assessing the threat
   landscape, generating coherent and accurate outputs validated by
   external experts. The authors recommend the optimal AI model type and
   its fine-tuned parameters.Research limitations/implicationsThis study
   lays the groundwork for further research, allowing for refinement by
   integrating additional resources, such as near-real-time alerts from
   external or internal sources and other AI models.Practical
   implicationsThe AI-powered advisor significantly streamlines threat
   detection and mitigation to help organizations' experts respond more
   efficiently to attacks.Social implicationsUsing cybersecurity, an AI
   advisor can lead to a safer digital environment for both organizations
   and society, given the pervasive nature of AI in everyday
   life.Originality/valueUnlike previous studies, the authors used the
   Rumsfeld matrix to frame questions within cybersecurity uncertainty
   domains, simulating AI responses and reducing barriers. This approach
   reveals crucial model characteristics and fine-tuning parameters that
   significantly enhance AI outcomes.},
