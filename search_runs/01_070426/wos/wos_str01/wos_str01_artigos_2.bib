@article{ WOS:001718853700001,
Author = {Kusuma, Ridho Surya and Ashraf, Erum and Manickam, Selvakumar and
   Karuppayah, Shankar},
Title = {SENTISEC: Combining keyword heuristics and sentiment modeling for
   AI-powered threat detection},
Journal = {TURKISH JOURNAL OF ELECTRICAL ENGINEERING AND COMPUTER SCIENCES},
Year = {2026},
Volume = {34},
Number = {2},
Pages = {164-184},
Abstract = {This work presents SENTISEC, a hybrid LLM-based threat detection
   framework that classifies security logs by combining keyword heuristics,
   domain-adapted sentiment scoring, and Retrieval-Augmented Generation
   (RAG). The SENTISEC system achieves an initial overall accuracy of
   93.67\%, 91.46\% macro recall, 89.07\% macro F1 and 95.15\% threat
   recall, with the false-positive rate maintained at 1.68\%. The
   methodology combines strict keyword and IOC matching, domain-specific
   DistilBERT adaptation, hybrid BM25-MiniLM retrieval with BGE reranking,
   adaptive quantile-based threshold calibration, and SHAP-based
   explainability. Comparative experiments against keyword-only,
   sentiment-only, classical ML models, and DistilBERT-only baselines show
   that SENTISEC consistently improves both TP and TN discrimination,
   particularly under semantically noisy and imbalanced log conditions. The
   principal error mode (benign logs incorrectly flagged as threats) is
   mitigated through calibrated FP/TN thresholds, contextual co-occurrence
   checks, and weighted fusion of rule, sentiment, and semantic signals.
   SHAP analysis further reveals that RAG semantic embeddings exert the
   strongest influence on threat decisions, supported by sentiment logits
   that refine ambiguous cues and rule-based signals that anchor explicit
   IOC matches. By unifying symbolic evidence and deep semantic reasoning
   under a transparent calibration and explanation scheme, SENTISEC
   provides an adaptive, interpretable, and operationally deployable
   solution for spyware-oriented system-log analysis.},
