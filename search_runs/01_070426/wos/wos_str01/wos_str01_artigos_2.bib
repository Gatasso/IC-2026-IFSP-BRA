@article{ WOS:001538419000001,
Author = {Guo, Tiezheng and Wang, Chen and Liu, Yanyi and Tang, Jiawei and Li, Pan
   and Xu, Sai and Yang, Qingwen and Gao, Xianlin and Li, Zhi and Wen,
   Yingyou},
Title = {Leveraging inter-chunk interactions for enhanced retrieval in large
   language model-based question answering},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {650},
Month = {OCT 14},
Abstract = {Retrieving external knowledge and prompting large language models with
   relevant information is an effective paradigm to enhance the performance
   of question-answering tasks. However, in multi-document question
   answering tasks, existing studies often evaluate the relevance of each
   paragraph to the question independently. This approach can lead to
   issues such as missing context and ambiguous references in the knowledge
   retrieved, ultimately hindering the reasoning capabilities of large
   language models. To address this limitation, we propose a novel
   retrieval framework called IIER in this study, which leverages
   Inter-chunk Interactions to Enhance Retrieval. In IIER, we transform
   independent documents into a unified Chunk-Interaction Graph by
   constructing edges that integrate structural, keyword, and semantic
   information between chunks. This graph effectively completes potential
   reasoning paths between chunks and provides additional contextual
   information to guide enhanced retrieval. Additionally, we design the
   Evidence Chain Retriever, which iteratively searches the graph for
   supporting evidence by jointly encoding semantic and topological
   information. Through this mechanism, the retriever is able to generate
   prompts enriched with comprehensive context and reasoning evidence
   chains, thereby improving the accuracy of large language models'
   reasoning. Extensive experiments conducted on multiple datasets
   demonstrate that IIER significantly improves retrieval performance and
   enhances the reasoning capabilities of large language models in MDQA
   tasks. Specifically, IIER outperforms strong baseline models guided by
   large language models, achieving accuracy improvements of 9.6 \% on the
   2WikiMQA and 6.0 \% on the HotpotQA.},
