@article{ WOS:001498346600007,
Author = {Jency, I. and Kumar, R. P. Anto},
Title = {FinQuaXBot: enhancing trust and security in personalized investment and
   tax forecasting using homomorphic encryption and meta-reinforcement
   learning with explainability},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {287},
Month = {AUG 25},
Abstract = {The rise of automated financial consulting systems, or robo-advisors,
   powered by Machine Learning and data analytics, has revolutionized
   personalized financial advice. However, key challenges such as market
   volatility, data privacy concerns, and the opacity of AI-driven
   recommendations hinder their adoption and user trust. To address these
   limitations, we propose FinQuaXBot, an innovative framework that
   combines cutting-edge technologies to enhance security, adaptability,
   and transparency in personalized investment and tax forecasting.
   FinQuaXBot utilizes homomorphic encryption through the
   Cheon-Kim-Kim-Song (CKKS) scheme, along with Secure Multi-Party
   Computation (SMPC), enabling the secure processing of encrypted
   financial data. This ensures privacy protection while still allowing for
   efficient, real-time analysis and decision-making. To enhance
   adaptability to market dynamics, the system integrates
   Retrieval-Augmented Generation (RAG) with MetaReinforcement Learning
   (Meta-RL), which allows the bot to continuously learn and optimize its
   strategies from new, incoming data. This enables FinQuaXBot to provide
   highly personalized financial advice that evolves with market trends.
   Furthermore, to improve transparency and explainability, the framework
   incorporates SHAPout, which integrates TimeSHAP for deep insights into
   sequential decision-making and Attention Rollout for explaining the
   relevance of individual input features. These mechanisms provide users
   with clear, interpretable reasons behind the bot's recommendations,
   building trust and understanding. Experimental evaluations show that
   FinQuaXBot achieves up to 95 \% prediction accuracy, robust
   generalization with out-of-distribution accuracy of 90 \%, and
   consistent investment strategy improvements, evidenced by a median ISC
   score increase of 0.81. Through these innovations, FinQuaXBot offers a
   secure, adaptive, and transparent solution for personalized financial
   consulting, overcoming the key challenges faced by traditional
   robo-advisors.},
