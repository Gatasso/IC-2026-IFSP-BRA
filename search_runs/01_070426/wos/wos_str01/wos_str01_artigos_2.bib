@article{ WOS:001708173300030,
Author = {Almutairy, Fayha and Almutairi, Shahad and Abdullah, Milaf and Salman,
   Sara},
Title = {SmartLaw Advisor: AI-Powered Legal Consultation and Contract Analysis
   for Saudi Arabia},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {32638-32654},
Abstract = {The complexity of local laws and the scarcity of affordable legal
   support in Saudi Arabia make discerning legal issues a challenge. The
   scarcity of Arabic digital assistants and the absence of innovative
   platforms compatible with Saudi legislation compound this challenge. We
   present an innovative virtual legal advisory platform to enhance access
   to legal help using state-of-the-art language models. The system is
   designed around two main functions: 1) a legal chatbot built on Google's
   Gemini 1.5, with a standard RAG (Retrieval-Augmented Generation)
   pipeline and a custom Arabic legal corpus based on official Saudi
   regulations; and 2) a contract analysis system that extracts and
   classifies Arabic legal documents to determine their compliance with
   national law. With a simple RAG formulation, the model retrieves
   relevant legal texts via semantic matching and produces precise,
   regulation-aligned answers without needing to retrain it. The system was
   evaluated on 150 legal questions across ten domains and tested on 50
   real contract drafts. Gemini outperformed models such as GPT-4, GPT-3.5,
   Command-A, and ALLaM in terms of accuracy (98.67\%), response speed, and
   expert evaluation. This work demonstrates how AI can provide affordable
   and efficient legal advice in Arabic and contribute to Saudi Arabia's
   digital transformation and Vision 2030. The system was further validated
   using a legally verified Saudi corpus and an expert-reviewed dataset
   comprising 150 legal questions and 50 contract samples, ensuring
   methodological rigor and dataset reliability.},
