@article{ WOS:001725319000001,
Author = {Teng, Liangyu and Ni, Wei and Song, Liang and Shi, Jun and Li, Yanfei},
Title = {Towards Self-Evolving Agents: A Dual-Process Framework for Continual
   Context Refinement},
Journal = {ELECTRONICS},
Year = {2026},
Volume = {15},
Number = {6},
Month = {MAR 16},
Abstract = {Large Language Models (LLMs) have become essential for interactive AI
   systems, yet they remain fundamentally static after deployment: they
   cannot update their parameters from interaction feedback and often
   repeat the same mistakes across long interaction streams. We propose
   Dual-Process Agent (DPA), a framework for continual context refinement
   that enables learning without modifying a frozen model backbone.
   Inspired by dual-process theory from cognitive science, DPA decomposes
   each interaction episode into two complementary processes: a fast System
   1 that retrieves compact, relevant context from an explicit long-term
   memory and generates responses, and a slow System 2 that reflects on
   outcomes and writes curated updates back into memory. To prevent memory
   degradation over extended interactions, DPA maintains bulletized memory
   entries with utility statistics and employs a conservative curator gate
   that filters generic, redundant, or conflicting insertions. Experiments
   on six diverse benchmarks demonstrate that DPA consistently outperforms
   vanilla prompting and competitive baselines on both GPT-5.1 and
   Llama-3.1-8B backbones, achieving the best overall performance across
   multiple reasoning and knowledge-intensive tasks.},
Publisher = {MDPI},
Address = {MDPI AG, Grosspeteranlage 5, CH-4052 BASEL, SWITZERLAND},
Type = {Article},
Language = {English},
Affiliation = {Song, L (Corresponding Author), Fudan Univ, Coll Intelligent Robot \& Adv Mfg, Shanghai 200433, Peoples R China.
   Teng, Liangyu; Ni, Wei; Song, Liang, Fudan Univ, Coll Intelligent Robot \& Adv Mfg, Shanghai 200433, Peoples R China.
   Shi, Jun; Li, Yanfei, China State Construct Engn Hong Kong Ltd, Hong Kong, Peoples R China.},
DOI = {10.3390/electronics15061232},
Article-Number = {1232},
