@article{ WOS:001716363700001,
Author = {Lin, Yu-Hsun and Lee, Chu-Hsuan and Chang, Chen-Chi},
Title = {Human-Centered AI for EcoMuseum Experience Enhancement: A RAG and
   UGC-Based Cultural Tour Chatbot Design},
Journal = {INTERNATIONAL JOURNAL OF HUMAN-COMPUTER INTERACTION},
Year = {2026},
Month = {2026 MAR 13},
Abstract = {With the advancement of Large Language Models (LLMs) and
   Retrieval-Augmented Generation (RAG) technology, balancing contextual
   adaptability with interactive coherence has become a significant
   challenge in designing intelligent cultural guide systems. Adopting
   Human-Centered AI (HCAI) as its core design principle, this study
   develops an interactive cultural guide system that combines the RAG
   mechanism with an LLM, implemented within the context of the Hakka
   EcoMuseum. To construct a multi-source knowledge base, the system
   integrates three heterogeneous knowledge sources-real-time web
   information, local cultural documents, and User-Generated Content. In
   the system's process flow, after a user submits a natural language query
   via a web interface, an LLM module automatically determines the query's
   semantics and classifies it into one of three predefined scenarios:
   Real-time Attraction Information Query (Scenario 1), Historical and
   Cultural Guidance Question (Scenario 2), or User Experience and
   UGC-Based Response (Scenario 3). The system then invokes the
   corresponding data source based on the scenario type to generate a
   response, ensuring contextual appropriateness and knowledge
   traceability. For the empirical evaluation, representative test
   questions were designed to compare the performance of our proposed
   system against three mainstream models: ChatGPT, Gemini, and
   Perplexity.ai. To validate the system's performance, this study employed
   both ANOVA and SUS analyses. The ANOVA results revealed significant
   differences among systems in tasks involving cultural interpretation and
   UGC-based responses, confirming the RAG-LLM model's superior ability to
   handle semantic reasoning and cultural contextualization. In contrast,
   the real-time attraction information scenario showed no significant
   difference, consistent with its dependence on factual web data.
   Complementary SUS testing with participants demonstrated high usability
   and consistent satisfaction across user groups, supporting the system's
   practicality and human-centered design. The research findings validate
   that the synergistic operation of structured, multi-source corpora and a
   RAG-LLM mechanism can effectively enhance a system's understanding of
   cultural context, content accuracy, and interaction fluency. This
   outcome provides a valuable reference for future work in automated
   corpus processing, multimodal information integration, and
   cross-cultural research and aids in the digital presentation of
   EcoMuseum content, thereby improving the interactive quality and user
   experience of cultural sites.},
