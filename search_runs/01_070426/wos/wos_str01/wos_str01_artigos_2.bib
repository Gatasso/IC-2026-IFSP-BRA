@article{ WOS:001637280300001,
Author = {Yang, Boai and Peng, Jiapai and Tang, Shiyi and Tan, Jiani and Zhou,
   Fengbo and Cui, Shenglan and Qu, Wei and Li, Tao and Liu, Fang and Wang,
   Dong},
Title = {Co-DIRECT: A knowledge-augmented multi-agent framework for interactive
   drama script generation},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {303},
Month = {MAR 25},
Abstract = {Drama script generation is a challenging yet valuable task with
   applications in film, gaming, and digital storytelling. Current LLM-and
   agent-based methods achieve some narrative coherence but often suffer
   from content homogenization, limited creativity, and underdefined human
   roles. To address these issues, we propose Co-DIRECT, a human-AI
   co-creation framework that positions a human director as a central
   collaborator in a Director-in-the-Loop (DiL) paradigm and employs a
   multi-agent structure: a Writer Agent constructs narrative arcs, an
   Actor Agent performs context-aware dialogues, and a Critic Agent
   evaluates consistency and emotional expressiveness. An ontology-driven
   knowledge graph extracts narratological principles from classical
   scripts to guide plot development and iterative refinement. Extensive
   evaluations show that Co-DIRECT outperforms strong baselines in
   narrative coherence, emotional depth, content diversity, and script
   structure. These results highlight the benefits of combining
   narratological knowledge, multi-agent collaboration, and DiL human
   guidance for controllable and creative script generation.},
