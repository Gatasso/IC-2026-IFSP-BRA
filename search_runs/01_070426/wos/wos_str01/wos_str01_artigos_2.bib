@article{ WOS:001625223900005,
Author = {Lahiri, Archit and Modi, Namay and V. Jawahar, Y. and Varalakshmi, M.
   and Mohideen, Peer},
Title = {Recursive-match prompting to enhance LLM-powered conversational AI
   capabilities in the judicial system},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {331},
Month = {DEC 3},
Abstract = {Legal systems around the world are widely perceived as complex and
   challenging to navigate, creating a psychological barrier that deters
   individuals from seeking justice due to fears of potential harm or
   entanglement. As a result, many are discouraged from pursuing legal
   recourse. We propose a legal advisor chatbot for the Indian legal
   system, currently implemented for consumer law, to bridge this knowledge
   gap by providing actionable information and guidance accessible to the
   average citizen. Existing solutions do not effectively address the
   challenge of sifting through the vast corpus of available legal
   information. They lack mechanisms to determine relevant precedents which
   is crucial for providing meaningful context and accurate advice to
   users. To achieve this, we introduce a novel approach called
   Recursive-Match Prompting (RM prompting), which iteratively refines user
   queries through a dialogue-based interaction. By leveraging a database
   of Landmark cases and performing cyclic information matching, the
   chatbot incrementally collects information about the user case to
   provide relevant legal precedents and guidance. We deep dive into the
   existing cases to find the matching precedent and provide accurate
   advice to users. Our approach empowers users with limited legal
   knowledge with accurate, context-sensitive advice, thereby lowering the
   entry barriers to accessing justice. We evaluate the effectiveness of RM
   prompting by using EM (Exact-Match) and F1 score and observe an
   improvement of 20\%. We measure the overall chatbot performance in terms
   of user-retention using average conversation turns. Furthermore, we have
   done a performance survey with 4 legal experts verifying the accuracy of
   the chatbot.},
