@article{ WOS:001635231800001,
Author = {Deng, Qiao and Chen, Zhiwen and Liu, Yufei and Zhu, Zheng and Xu, Jiamin
   and Jiang, Zhaohui and Chua, K. J.},
Title = {Graph-constrained association rule mining-based energy efficiency
   diagnosis method for HVAC systems with knowledge-enhanced large language
   model},
Journal = {BUILDING AND ENVIRONMENT},
Year = {2026},
Volume = {289},
Month = {FEB 1},
Abstract = {Heating, ventilation, and air-conditioning (HVAC) systems consume a
   large share of building energy and di rectly affect occupant comfort.
   Current energy-efficiency diagnostics depend mainly on expert-defined
   rule sets or large-scale data-driven models, which face limited
   scalability, heavy reliance on labeled data, and opaque decision-making.
   To this end, this paper proposes a novel graph-constrained association
   rule mining-based en ergy efficiency diagnosis method for HVAC systems
   with knowledge-enhanced large language model (LLM). First, an
   association graph encoding system topology, thermodynamic couplings, and
   control dependencies is con structed. It imposes neighborhood
   constraints in the association rule mining process, sharply reducing the
   search space and computational cost. Subsequently, through the
   retrieval-augmented generation mechanism, domain knowledge such as
   design parameters, domain expertise, and maintenance records is input
   into the LLM to auto matically evaluate the effectiveness of each
   candidate rule and classify them, providing interpretable diagnostics.
   The experimental verification of the HVAC system operation data of a
   large occupied office building shows that the proposed method reduces
   the number of candidate rules by more than 95.10 \%, and the energy
   efficiency diagnosis accuracy reaches 89.08 \%.},
Publisher = {PERGAMON-ELSEVIER SCIENCE LTD},
