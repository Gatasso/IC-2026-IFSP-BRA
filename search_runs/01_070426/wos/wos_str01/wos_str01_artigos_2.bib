   Kim, Hyeyoon; Noh, Yeonsoo; Park, Jonghyeok; Park, Minjeong; Yang, Byungwook; Jung, Yoonsuh, Korea Univ, Dept Stat, 145 Anam Ro Seongbuk Gu, Seoul 02841, South Korea.},
DOI = {10.5351/KJAS.2025.38.4.571},
