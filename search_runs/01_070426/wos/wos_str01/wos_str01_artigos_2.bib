@article{ WOS:001620353700008,
Author = {Miao, Runsheng and Wu, Tao and Zhang, Zhenyu},
Title = {Graph RAG-based fault diagnosis for train bogies using knowledge graphs
   and large language model},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {331},
Month = {DEC 3},
Abstract = {Fault diagnosis of high-speed train bogies is vital for safety and
   comfort but is hindered by the hidden, coupled, and nonlinear nature of
   faults, as well as the limitations of vibration-based and deep learning
   methods in interpretability and generalization. This study proposes a
   Graph Retrieval-Augmented Generation (Graph RAG)-based diagnosis
   framework that integrates Knowledge Graphs (KGs) and Large Language
   Models (LLMs) to enable explainable, domain-specific reasoning.
   Following a four-stage pipeline: (1) Data preprocessing standardizes and
   filters multimodal fault records; (2) LLM-driven KG construction
   extracts implicit fault relationships from unstructured maintenance
   logs, enriched with domain expertise via prompt engineering; (3) Graph
   encoding and retrieval transform the KG into structured graph
   embeddings, enabling precise subgraph retrieval based on query vectors;
   and (4) Diagnostic inference leverages retrieved contexts for accurate,
   traceable fault classification. In real-world bogie fault dataset tests,
   the method outperforms strong baselines (MGNN, MPFCF and MSP-RAG) with a
   Weighted F1 improvement of +2.47 \% and Top-10 Accuracy gains of +3.26
   \%, while achieving 92.67 \% attribution consistency, indicating
   superior causal reasoning transparency. These results demonstrate that
   the proposed framework not only improves diagnostic accuracy but also
   addresses the longstanding need for interpretability and adaptability in
   railway maintenance, offering a scalable solution for other
   safety-critical industrial applications.},
