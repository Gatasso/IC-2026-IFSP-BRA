@article{ WOS:001702911300002,
Author = {Du, Lintao and Yang, Chenghao and Yan, Jianwei},
Title = {Decoding the continuum of architectural intention and public perception
   in industrial heritage regeneration: A multimodal social media data
   analysis},
Journal = {HABITAT INTERNATIONAL},
Year = {2026},
Volume = {170},
Month = {APR},
Abstract = {Public perceptions derived from social media data increasingly shape the
   social sustainability and inclusivity of Industrial Heritage
   Regeneration (IHR). However, the correspondence between public
   perspectives and the professional intentions of architects, planners,
   and critics remains under-examined, often leading to a misalignment
   between design rationales and public lived experience. To address this
   gap, this study developed a multimodal analytic framework applied to the
   Taoxichuan urban design project in Jingdezhen. A comprehensive corpus is
   assembled, integrating academic literature, critical reviews, media
   coverage, and user-generated multimodal content from diverse social
   media platforms. The research framework combines Large Language Models
   (LLMs) and Retrieval-Augmented Generation (RAG) for semantic analysis,
   alongside specialized deep learning models for text mining, topic
   modeling, emotion detection, and image classification. The decoding
   results of unsupervised content and supervised indicators identifies
   zones of convergence and divergence between public and professional
   narratives regarding Taoxichuan, enabling a nuanced appraisal of success
   factors, points of dissatisfaction, and broader implications for IHR
   practice. The contribution is twofold: methodologically, the study
   offers a replicable, data-driven approach for evaluating IHR;
   theoretically, it demonstrates the importance of robust feedback loops
   between professional and public perspectives as a basis for more
   inclusive regeneration strategies. Ultimately, these findings provide
   actionable guidance for urban designers and policymakers seeking more
   equitable, community-engaged, and sustainable regeneration.},
