@article{ WOS:001691081900037,
Author = {Mac Dube, Busisani and Fonou-Dombeu, Jean Vincent},
Title = {A Review of State-of-the-Art Deep Learning Models for Knowledge Graphs},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {20260-20286},
Abstract = {Deep Learning (DL) has revolutionized Knowledge Graph (KG) construction
   and reasoning in the recent past. The integration of DL models with KGs
   has shown potential to offer numerous benefits in KG creation,
   completeness, analysis and applications. However, there is a lack of
   comprehensive reviews on the latest DL models designed explicitly for
   KGs. This paper addresses these gaps by thoroughly reviewing
   state-of-the-art DL models for KGs and their applications in leading
   areas such as question answering and recommender systems. Furthermore,
   this review paper provides a comprehensive overview of recent
   advancements in DL models applied to KGs. This review aims to deepen the
   understanding of the use of DL in KGs and investigate how DL can further
   enhance their effectiveness and utility across diverse domains. The
   reviewed models include translation-based models such as TransE, TransH,
   and TransR, Neural/Matrix factorization models such as ConvE, DistMult,
   TuckER and RotatE, GNN models such as R-GCN, GAT, GGNN, Large Language
   Models (LLMs) such as KG-BERT, KG-LLaMA, LLM4VKG, KoPA, and CPKGC,
   Retrieval-Augmented Generation (RAG) models such as Graph-RAG and
   Cold-RAG and multimodal KG (MMKG) models such as MKGAT and MMKDGAT in
   the context of KGs. The review highlights key features and the
   effectiveness of these models in addressing domain-specific challenges,
   providing insights into their potential to advance KG research. We
   highlight key trends, including the rise of GNNs and hybrid LLM-KG
   systems, and identify unresolved challenges like dynamic KG updates and
   multimodal integration. The strengths and limitations of these models
   are also discussed in detail, along with their areas of application
   within the context of KGs.},
