@article{ WOS:001719660200001,
Author = {Yin, Baolin and Fang, Xuming and Wang, Xianbin},
Title = {Toward Cognitive Autonomy in UAV Networks: Empowering Intelligence with
   Multi-Modal Large Language Models},
Journal = {IEEE COMMUNICATIONS MAGAZINE},
Year = {2026},
Month = {2026 },
Abstract = {As unmanned aerial vehicle (UAV) networks become increasingly critical
   for diverse applications such as disaster response and commercial
   services, the demand for situation-aware UAV network operation continues
   to rise. Traditional UAV network operations are typically context-
   unaware, resulting in limited adaptability to rapidly changing
   environments. To cope with this challenge, we propose a cognitively
   autonomous framework for UAV networks empowered by multi-modal large
   language models (MMLLMs). The proposed framework integrates
   environmental cognition, intelligent decision- making, feedback
   optimization, and domain knowledge comprehension enhanced through
   retrieval-augmented generation (RAG). By leveraging heterogeneous
   onboard sensors, UAVs collect multi-modal data, enabling real-time
   environment cognition and achieving semantic- and intent-level
   comprehension via MMLLMs. Furthermore, advanced deep reinforcement
   learning (DRL) techniques are incorporated, facilitating adaptive
   decision-making and dynamic network control under varying conditions.
   The embedded RAG capability allows seamless integration of the latest
   domain-specific knowledge, including recent research findings, technical
   standards, and environmental prior knowledge. Feedback optimization
   continually refines network policies based on real-time evaluations,
   ensuring adaptability to evolving network dynamics. Simulation results
   show that our proposed framework substantially enhances UAV network
   performance and autonomy.},
