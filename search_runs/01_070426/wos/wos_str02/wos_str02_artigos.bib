@article{ WOS:001503376300001,
Author = {Pattabiraman, Kalyanaraman and Sachin, Arockia and Lokeshkumar, R.},
Title = {Enhancing business intelligence through NLP and contextual AI synergy},
Journal = {ENGINEERING RESEARCH EXPRESS},
Year = {2025},
Volume = {7},
Number = {2},
Month = {JUN 30},
Abstract = {Organizations are now overwhelmed with data, posing challenges for
   several small business owners and managers who lack IT competence to
   understand. They sometimes have difficulties in obtaining information
   or, at best, understanding the organization's vast databases owing to
   technological issues and system complexity. This article introduces an
   innovative BI solution tailored for business experts to oversee complex
   structured SQL databases, extensive sales reports, and company laws and
   paperwork. The current application integrates technological advancements
   such Retrieval-Augmented Generation (RAG), Chain of Thought, and Natural
   Language to SQL (NL2SQL) to enhance user engagement with data through
   dialogue. They can analyze sales trends, policy details, define precise
   language, and simply compare data across many databases. The integration
   of advanced technology diminishes barriers to database access, enabling
   more easy, effective, and intelligible information retrieval for users
   in corporate entities. This project offers a unique and accessible
   business intelligence solution tailored for end-users without
   significant IT knowledge, aimed at improving decision-making and
   operational efficiency.},
