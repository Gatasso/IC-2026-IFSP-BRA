	abbrev_source_title = {IFIP Netw. Conf., IFIP Netw.},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; Conference name: 23rd International Federation for Information Processing on Networking Conference, IFIP Networking 2024; Conference date: 3 June 2024 through 6 June 2024; Conference code: 201875}
}

@CONFERENCE{Şahin2024,
