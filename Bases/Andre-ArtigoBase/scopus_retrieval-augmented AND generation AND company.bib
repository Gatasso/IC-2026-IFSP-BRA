@ARTICLE{Chen2025,
	author = {Chen, Lun-Chi and Pardeshi, Mayuresh Sunil and Liao, Yi-Xiang and Pai, Kai-Chih},
	title = {Application of retrieval-augmented generation for interactive industrial knowledge management via a large language model},
	year = {2025},
	journal = {Computer Standards and Interfaces},
	volume = {94},
	doi = {10.1016/j.csi.2025.103995},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85219499545&doi=10.1016%2fj.csi.2025.103995&partnerID=40&md5=142aabb43da5fdeeb012ed4c345e446e},
	affiliations = {College of Engineering, Tunghai University, Taichung, Taiwan; School of Computer Sciences, UPES, Dehradun, India; AI Center, Tunghai University, Taichung, Taiwan},
	abstract = {Industrial data processing and retrieval are necessary for adoption in Industry 5.0. Large Language Model (LLMs) revolutionize natural language process (NLP) but face challenges in domain-specific applications due to specialized terminology and context. Artificial Intelligence (AI) assistants for industrial-related work enquiry and customer support services are necessary for increasing demand and quality of service (QoS). Our research aims to design a novel customized model with a retrieval-augmented generation (RAG)-based LLM as a sustainable solution for industrial integration with AI. The goal is to provide an interactive industrial knowledge management (IIKM) system that can be applied to technical services: assisting technicians in the search for precise technical repair details and company internal regulation searches: personnel can easily inquire about regulations, such as business trips and leave requirements. The IIKM model architecture consists of BM25 and embedding sequence processing in the chroma database, where the top k-chunks are selected by the BAAI ranker to respond effectively to the queries. A group of documents of 234 MB size and pdf, pptx, docx, csv and txt formats are used for the experimental analysis. The designed interactive knowledge management system has a mean reciprocal rank (MRR) of 88 %, a recall of 85 % and a mean average precision (mAP) of 75 % in technical service. The internal regulatory documents have a generation-based retrieval evaluation prediction of recall of 91.62 %, MRR of 97.97 % and mAP of 91.12 %. We conclude with insights gained and experiences shared from IIKM deployment with Sakura incorporation, highlighting the importance of the hybrid approach integrating RAG-based generative pretrained transformer (GPT) models for customized solutions. © 2025 The Author(s)},
	author_keywords = {Interactive industrial knowledge management system; Large language models; Retrieval-augmented generation},
	keywords = {Competition; Crushed stone plants; Metadata; Domain-specific application; Interactive industrial knowledge management system; Knowledge management system; Language model; Large language model; Mean reciprocal ranks; Natural language process; Related works; Retrieval-augmented generation; Technical service; Human resource management},
