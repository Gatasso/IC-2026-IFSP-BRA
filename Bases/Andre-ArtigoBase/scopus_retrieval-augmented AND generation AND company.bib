@CONFERENCE{Toftdahl2024455,
	author = {Toftdahl, Jens Christian and Shahin, Kamrul Islam and Hylle, Thomas},
	title = {Enhancing Data Retrieval with Custom Embedding Models and ChatGPT},
	year = {2024},
	journal = {IEEE International Conference on Software Quality, Reliability and Security, QRS},
	pages = {455 – 461},
	doi = {10.1109/QRS62785.2024.00052},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85206389109&doi=10.1109%2fQRS62785.2024.00052&partnerID=40&md5=64ea78ff071654c0ee0a9d73ad7a9f08},
	affiliations = {Jens Christian Toftdahl, Fyn, Odense, Denmark; Kamrul Islam Shahin, Fyn, Odense, Denmark; Thomas Hylle, City, Midtjutland, Hedensted, Denmark},
	abstract = {This research aims to study data fragmentation and inaccessibility challenges due to large company growth such as with Eltronic A/S. A real use case is being experimented upon, using the proposed methodology. The devised solution is a search platform that utilizes a fine-tuned embedding model trained on company data to index and fetch relevant information. The model was trained using the HuggingFace Sentence transformer library. The training loss utilised is Multiple Negatives Ranking Loss on augmented data, generated using ChatGPT. Combining the embedding model with the integration of ChatGPT allows for a more seamless way of performing information search. In this study, a fine-tuning model on internal company data increases the Top-1 Retrieval errors by 10 % compared to other state-of-the-art models. The solution also increases employees' ability to find relevant information compared to the company's previous solution. © 2024 IEEE.},
	author_keywords = {Applied Machine Learning; Embedding Models; Fine-tuning; Natural Language Processing (NLP); Retrieval Augmented Generation (RAG)},
	keywords = {Natural language processing systems; Search engines; Applied machine learning; Data fragmentation; Data retrieval; Embedding model; Embeddings; Fine tuning; Language processing; Natural language processing; Natural languages; Retrieval augmented generation; Embeddings},
	correspondence_address = {K.I. Shahin; Kamrul Islam Shahin, Odense, Fyn, Denmark; email: kish@mmmi.sdu.dk},
