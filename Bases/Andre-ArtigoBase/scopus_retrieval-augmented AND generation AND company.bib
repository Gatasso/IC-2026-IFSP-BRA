@CONFERENCE{Shukla2024,
	author = {Shukla, Varsha and Parker, Geoffrey G},
	title = {Building Custom Large Language Models for Industries: A Comparative Analysis of Fine-Tuning and Retrieval-Augmented Generation Techniques},
	year = {2024},
	journal = {ICAAEEI 2024 - 1st International Conference of Adisutjipto on Aerospace Electrical Engineering and Informatics: Shaping the Future Work for the Aerospace Technology in Science, Engineering, and Industry in the Disruptive Era},
	doi = {10.1109/ICAAEEI63658.2024.10899129},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105000637208&doi=10.1109%2fICAAEEI63658.2024.10899129&partnerID=40&md5=b80c0d22e524fa9c512cbe2a7cc470e9},
	affiliations = {Thayer School of Engineering, Dartmouth College, Hanover, NH, United States},
	abstract = {In this study, we delve into the development and optimization of custom Large Language Models (LLMs) tailored for specific industrial applications, concentrating on two predominant adaptation techniques: fine-tuning and Retrieval-Augmented Generation (RAG). We employ a rigorous, mathematically-driven approach to compare the efficacy of these methodologies, using a dual dataset derived from TACIT Company, which specializes in the tacit knowledge of retiring workforce documentation, and Sight Machine, which focuses on manufacturing process data. Our evaluation framework uses three metrics: Accuracy, calculated as the ratio of correctly predicted instances to total predictions; Adaptability, which measures the model's performance stability when exposed to novel, evolving datasets; and Industry Relevance, assessed through expert-based qualitative scoring converted to quantitative analysis. This comprehensive comparative analysis not only quantifies the performance differences between finetuning and RAG but also explores the computational dynamics and potential synergies when implementing these models. Additionally, we address the ethical considerations and practical implications of deploying LLMs in sensitive industries, framing these technologies within the context of operational integrity and data governance. The outcome of this research aims to guide stakeholders in selecting and optimizing LLM strategies that align with specific industrial needs, balancing technical efficiency, and ethical standards.  © 2024 IEEE.},
	author_keywords = {Accuracy Metrics; Computational Dynamics; Data Governance; Ethical AI; Fine-Tuning; Industry Applications; Industry Relevance; Large Language Models; Model Adaptability; Operations Research; Performance Optimization; Retrieval-Augmented Generation},
	keywords = {Data accuracy; Data integrity; Ethical technology; Accuracy metric; Computational dynamics; Data governances; Ethical AI; Fine tuning; Industry applications; Industry relevance; Language model; Large language model; Model adaptability; Operation research; Performance optimizations; Retrieval-augmented generation; Operations research},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833150793-0},
	language = {English},
	abbrev_source_title = {ICAAEEI - Int. Conf. Adisutjipto Aerosp. Electr. Eng. Informatics: Shap. Future Work Aerosp. Technol. Sci., Eng., Ind. Disruptive Era},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; Conference name: 1st International Conference of Adisutjipto on Aerospace Electrical Engineering and Informatics, ICAAEEI 2024; Conference date: 11 December 2024 through 12 December 2024; Conference code: 207285}
}

@CONFERENCE{Kefalas2024660,
	author = {Kefalas, Dimitris and Christakis, Sokratis and Fdida, Serge and Makris, Nikos and Syrigos, Ilias and Passas, Virgilios and Korakis, Thanasis},
	title = {slAIces: an LLM Chatbot for Simplifying Experiments with the SLICES-RI},
	year = {2024},
	journal = {2024 IFIP Networking Conference, IFIP Networking 2024},
	pages = {660 – 665},
	doi = {10.23919/IFIPNetworking62109.2024.10619821},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85202430672&doi=10.23919%2fIFIPNetworking62109.2024.10619821&partnerID=40&md5=ea27cd39c10e50c10ebb555b866da7f6},
	affiliations = {Laboratoire LiP6/CNRS, Sorbonne University, Paris, France; University of Thessaly, Dept. of Electrical and Computer Engineering, Greece; Centre for Research and Technology Hellas, CERTH, Greece},
	abstract = {SLICES-RI is the outcome of several years of evolution of the concept of a networking test platform, that has recently transformed into a scientific instrument for the assessment of new research challenges in the Digital Infrastructures domain. Making large-scale scientific instruments easily accessible has always been challenging, often hindered by the complexity of the underlying platforms, the size and diversity of resources and the low-level settings that experimenters need to configure. Emerging technologies such as artificial intelligence(AI) have ignited a wave of innovation, inspiring companies, professionals, and researchers to incorporate chatbot assistants into their projects. These assistants revolutionize user experience by simplifying access to information and resources, significantly increasing productivity and presenting a familiar interface. In this work, we introduce slAIces, an LLM-based chatbot specifically designed to ease access to the SLICES-RI. slAIces utilizes the Generative Pre-trained Transformer(GPT) GPT-4 model to create a sophisticated Retrieval Augmented Generation(RAG) system. This system provides external knowledge by leveraging a properly preprocessed dataset, which includes documentation from SLICES-RI and all integrated testbeds. The contribution of this study lies in its methodology and recommendations for enriching the information on the test platform to enhance the quality of the service provided. We demonstrate that this chatbot significantly reduces the learning curve for new experimenters to become acquainted with the infrastructure. It exposes the appropriate level of abstraction, enabling experimenters to conduct complex experiments mobilizing the extensive and diverse resources available within a large-scale infrastructure like SLICES-RI.  © 2024 IFIP.},
	author_keywords = {chatbot; GPT; LLM; RAG; Research Infrastructure; SLICES},
	keywords = {Abstracting; Instrument scales; Instrument testing; Chatbots; Digital infrastructures; Generative pre-trained transformer; LLM; Research challenges; Research infrastructure; Retrieval augmented generation; Scientific instrument; SLICES; Test platforms},
	correspondence_address = {D. Kefalas; Laboratoire LiP6/CNRS, Sorbonne University, Paris, France; email: dkefalas@uth.gr; S. Christakis; Laboratoire LiP6/CNRS, Sorbonne University, Paris, France; email: schristakis@uth.gr; S. Fdida; Laboratoire LiP6/CNRS, Sorbonne University, Paris, France; email: serge.fdida@lip6.fr},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {978-390317663-8},
