Title = {Engineering LLM Powered Multi-Agent Framework for Autonomous CloudOps},
Booktitle = {2025 IEEE/ACM 4TH INTERNATIONAL CONFERENCE ON AI ENGINEERING-SOFTWARE
   ENGINEERING FOR AI, CAIN},
Year = {2025},
Pages = {201-211},
Note = {4th International Conference on AI Engineering Software Engineering for
