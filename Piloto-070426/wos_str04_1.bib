@inproceedings{ WOS:001327094200042,
Author = {Toftdahl, Jens Christian and Shahin, Kamrul Islam and Hylle, Thomas},
Book-Group-Author = {IEEE},
Title = {Enhancing Data Retrieval with Custom Embedding Models and ChatGPT},
Booktitle = {2024 IEEE 24TH INTERNATIONAL CONFERENCE ON SOFTWARE QUALITY, RELIABILITY
   AND SECURITY, QRS},
Series = {IEEE International Conference on Software Quality Reliability and
   Security},
Year = {2024},
Pages = {455-461},
Note = {24th IEEE International Conference on Software Quality, Reliability and
   Security (QRS), Univ Cambridge, Churchill Coll, Cambridge, ENGLAND, JUL
   01-05, 2024},
Organization = {IEEE; IEEE Comp Soc},
Abstract = {This research aims to study data fragmentation and inaccessibility
   challenges due to large company growth such as with Eltronic A/S. A real
   use case is being experimented upon, using the proposed methodology. The
   devised solution is a search platform that utilizes a fine-tuned
   embedding model trained on company data to index and fetch relevant
   information. The model was trained using the HuggingFace Sentence
   transformer library. The training loss utilised is Multiple Negatives
   Ranking Loss on augmented data, generated using ChatGPT. Combining the
   embedding model with the integration of ChatGPT allows for a more
   seamless way of performing information search. In this study, a
   fine-tuning model on internal company data increases the Top-1 Retrieval
   errors by 10\% compared to other state-of-the-art models. The solution
   also increases employees' ability to find relevant information compared
   to the company's previous solution.},
