@article{ WOS:001571925100001,
Author = {Wen, Haolin and Wang, Songyi and Liang, Xin and Li, Bingjie and Hu,
   Wanshu and Luo, Xing},
Title = {Version 5.4.18-AI-KM: Knowledge enhancement with RAG and workflow},
Journal = {SOFTWAREX},
Year = {2025},
Volume = {31},
Month = {SEP},
Abstract = {The latest version of the AI-KM system integrates multiple Large
   language models (LLMs) and Retrievalaugmented generation (RAG)
   technology based on Ollama, supporting vectorization and intelligent
   processing of Markdown documents. It provides intelligent retrieval and
   Question and Answer (Q\&A) within knowledge bases, along with a scalable
   workflow engine that significantly improves the accuracy of
   domain-specific knowledge queries. The system also features enhanced
   knowledge visualization and user interface, greatly improving usability
   and enabling flexible adaptation to various business scenarios. It has
   been successfully deployed in applications such as classroom
   demonstrations, teaching assistance, equipment information management,
   and regulation consulting, making it suitable for educational,
   corporate, and research environments.},
