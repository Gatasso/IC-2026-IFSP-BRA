Title = {Discovery Omnia: Dynamic RAG for Enhanced Patent Analysis and Systematic
   Innovation},
Booktitle = {WORLD CONFERENCE OF AI-POWERED INNOVATION AND TRIZ METHODOLOGY, TRAI
   2025, PT I},
