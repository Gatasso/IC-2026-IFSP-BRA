   Hongji},
Editor = {Senn, W and Sanguineti, M and Saudargiene, A and Tetko, IV and Villa, AEP and Jirsa, V and Bengio, Y},
Title = {ChiMDQA: Towards Comprehensive Chinese Document QA with Fine-Grained
   Evaluation},
Booktitle = {ARTIFICIAL NEURAL NETWORKS AND MACHINE LEARNING-ICANN 2025, PT III},
