@inproceedings{ WOS:001501395000001,
Author = {Pondel, Maciej and Chomiak-Orsa, Iwona and Sobinska, Malgorzata and
   Grzelak, Wojciech and Kotwica, Artur and Malowiecki, Andrzej and Luczak,
   Kamila and Grenczuk, Andrzej and Busch, Peter and Chudan, David and
   Berka, Petr},
Editor = {Hernes, M and Watrobski, J and Rot, A},
Title = {AI Tools for Knowledge Management - Knowledge Base Creation via LLM and
   RAG for AI Assistant},
Booktitle = {EMERGING CHALLENGES IN INTELLIGENT MANAGEMENT INFORMATION SYSTEMS, ECAI
   2024-IMIS WORKSHOP. VOL 2},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
Volume = {1218},
Pages = {3-15},
Note = {2024 Workshop on Intelligent Management Information Systems-IMIS,
   Santiago de Compostela, SPAIN, OCT 19-24, 2024},
Abstract = {AI assistants allow the automation of routine tasks performed by humans,
   thereby supporting the optimization of business processes within
   enterprises. By leveraging large language models (LLMs), they help
   retrieve relevant content and knowledge to undertake activities within
   business processes. Assistants also aid in preparing content
   constituting the output of individual steps in business processes. The
   development of an assistant using generative artificial intelligence to
   support and automate student service processes in the dean's office work
   area is a very innovative solution. It should be noted that this area of
   the university's activities has not used advanced technological
   solutions so far. Thus, the special contribution of the article is to
   explore such a possibility and develop a prototype solution. This
   article aims to show how efficiently create a knowledge base for an
   AI-powered assistant. For this paper, processes refer to questions
   answering from students at the Wroclaw University of Economics and
   Business. As part of a practical study, a database of 350 sample
   questions generated by actual students was collected, which was then
   analyzed using language models, which then identified key topics in the
