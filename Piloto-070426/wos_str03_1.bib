   Hoang, Mia, Georgia Inst Technol, Coll Comp, Atlanta, GA 30332 USA.
   Madisetti, Vijay K., Georgia Inst Technol, Sch Cybersecur \& Privacy, Atlanta, GA 30332 USA.},
DOI = {10.1109/ACCESS.2026.3670064},
ISSN = {2169-3536},
Keywords = {Benchmark testing; Databases; Retrieval augmented generation; Structured
   Query Language; Pipelines; Business; Training; Toy manufacturing
   industry; Large language models; Electronic mail; Text-to-SQL; natural
   language interfaces; query ambiguity resolution; retrieval-augmented
   generation; curriculum learning; group relative policy optimization;
   unanswerability detection; large language models; agentic AI; database
