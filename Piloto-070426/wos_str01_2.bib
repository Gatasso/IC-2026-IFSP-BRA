ISBN = {978-0-7844-8598-9},
Keywords = {Large Language Models (LLM); Retrieval Augmented Generation (RAG);
   ChatGPT; Civil Engineering; RS2; Settle3; settlement analysis;
   fine-tuned models; APIs with OpenAI.},
