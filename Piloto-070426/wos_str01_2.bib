@inproceedings{ WOS:001695196200007,
Author = {Wu, Shuang and Fan, Xing-Rong and Zeng, Run and Zhang, Lin and Ran,
   Jinshan and Liu, Bo},
Book-Group-Author = {ACM},
Title = {Cross-border E-commerce Product Listing Compliance Identification by
   Integrating Large Language Models and Hybrid Retrieval Technology},
Booktitle = {2025 9TH INTERNATIONAL CONFERENCE ON BIG DATA AND INTERNET OF THINGS,
   BDIOT 2025},
Year = {2025},
Pages = {45-50},
Note = {9th International Conference on Big Data and Internet of Things-BDIOT,
   Chongqing, PEOPLES R CHINA, NOV 07-09, 2025},
Organization = {University of Saint Joseph (Macao)},
Abstract = {Accurately identifying whether cross-border e-commerce product listings
   comply with regulations is essential for reducing business risks,
   ensuring the orderly growth of cross-border trade, and promoting a
   standardized global e-commerce market. However, current methods on
   cross-border e-commerce platforms heavily rely on manual reviews, which
   face challenges such as low accuracy, inefficiency, and difficulty in
   retrieving relevant policy documents. To address these challenges, this
   paper proposes a novel compliance identification model framework for
   cross-border e-commerce product listings that integrates Large Language
   Models and hybrid retrieval technology (LLM-HRT-CEPCI). The model
   combines Large Language Models, multi-level policy vector database
   construction, hybrid retrieval, and retrieval-augmented generation
   technology to achieve accurate clause matching and automated compliance
   judgment. Experimental results demonstrate that the model's hybrid
   retrieval module significantly outperforms single retrieval methods,
   with an F 1-score of 0.7342, Precision of 0.7429, and Recall of 0.7383.
   The model effectively resolves semantic ambiguities in complex policy
   scenarios, providing an accurate and practical compliance review
   solution for cross-border e-commerce platforms. This work offers
   valuable support for reducing enterprise risks and advancing the digital
   transformation of cross-border trade.},
