@article{ WOS:001570483600013,
Author = {Wang, Jingyu and Guo, Lingqi and Wu, Jianyu and Yan, Caijun and Sun,
   Haifeng and Zhang, Lei and Zhuang, Zirui and Qi, Qi and Liao, Jianxin},
Title = {Hierarchical Index Retrieval-Driven Wireless Network Intent Translation
   With LLM},
Journal = {IEEE TRANSACTIONS ON MOBILE COMPUTING},
Year = {2025},
