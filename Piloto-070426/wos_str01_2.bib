@inproceedings{ WOS:001661448300697,
Author = {Wang, Yucheng and Yu, Jifan and Daniel Zhang-Li and Lim, Joy Jia Yin and
   Tu, Shangqing and Li, Haoxuan and Liu, Zhiyuan and Liu, Huiqin and Hou,
   Lei and Li, Juanzi and Xu, Bin},
Book-Group-Author = {ACM},
Title = {EduCraft: A System for Generating Pedagogical Lecture Scripts from
   Long-Context Multimodal Presentations},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
