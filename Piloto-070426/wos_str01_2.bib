@article{ WOS:001533583300001,
Author = {Shelke, Vishakha and Patil, Manas and Pareek, Jatin and Popat, Parth and
   Chauhan, Dhruv and Pandey, Jatin},
Title = {Transformative drug research using augmented generative AI},
Journal = {INTELLIGENT DECISION TECHNOLOGIES-NETHERLANDS},
Year = {2025},
