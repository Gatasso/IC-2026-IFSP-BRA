@inproceedings{ WOS:001553213900033,
Author = {Hodges, Frank M. and Pullela, Sundareswar and Cohen, Guy and Mulgund,
   Akshay and Roach, Jared C. and Ramsey, Stephen A.},
Editor = {Bellazzi, R and Herrero, JMJ and Sacchi, L and Zupan, B},
Title = {Using AI to Improve Diagnosis and Treatment of Rare Diseases: A Chat
   Agent for Equitable and Accessible Healthcare},
Booktitle = {ARTIFICIAL INTELLIGENCE IN MEDICINE, AIME 2025, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
