@inproceedings{ WOS:001661448300316,
Author = {Wen, Zimo and Hu, Hanwen and Fang, Nan and Qian, Shiyou and Cao, Jian},
Book-Group-Author = {ACM},
Title = {DANet: A RAG-inspired Dual Attention Model for Few-Shot Time Series
   Prediction},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
Year = {2025},
Pages = {3302-3311},
Note = {34th Conference on Information and Knowledge Management-CIKM, SOUTH
   KOREA, NOV 10-14, 2025},
Organization = {Association for Computing Machinery; The ACM Special Interest Group on
   Hypertext and the Web; ACM Special Interest Group on Information
   Retrieval; Korea Tourism Organization; Seoul Metropolitan Government},
Abstract = {Practical applications often require forecasting the future states of
   short time series (STS) using multiple related long time series (LTS) as
   auxiliary data, a process known as few-shot prediction. The primary
   challenge, given the limited data on STS, is effectively capturing the
   pattern similarities between STS and LTS. Current methods, despite
   notable advancements, primarily focus on transferring pattern
   characteristics from LTS to STS without explicitly addressing their
   similarities at various levels. To overcome this limitation, we propose
   a novel few-shot time series forecasting model called DANet. Drawing on
   the Retrieval-Augmented Generation (RAG) framework in large language
   models, DANet retrieves long and short sequences from LTS that closely
   resemble STS, thereby enhancing prediction accuracy while simultaneously
   reducing uncertainty through this retrieval process. First, we define
   two metrics to quantify pattern similarities between STS and LTS,
   addressing the issue of different representations of the same pattern
   due to variations in sequence length. Second, we propose a
   dual-attention mechanism which embeds the two similarities metrics to
   extract and integrate long and short sequences from LTS across variable
   and temporal levels for generating predictions. Our experiments across
   six scenarios show that DANet significantly outperforms six
   state-of-the-art (SOTA) methods.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
