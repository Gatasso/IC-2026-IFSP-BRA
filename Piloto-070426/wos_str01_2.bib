@inproceedings{ WOS:001329132500006,
Author = {Muehlburger, Herbert and Wotawa, Franz},
Book-Group-Author = {IEEE},
Title = {FaultLines - Evaluating the Efficacy of Open-Source Large Language
   Models for Fault Detection in Cyber-Physical Systems},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE TESTING,
   AITEST},
Series = {IEEE International Conference on Artificial Intelligence Testing},
Year = {2024},
Pages = {47-54},
Note = {6th IEEE International Conference on Artificial Intelligence Testing
   (AITest) as a part of the IEEE International Congress on Intelligence
   and Service-Oriented Systems Engineering (CISOSE), Shanghai, PEOPLES R
   CHINA, JUL 15-18, 2024},
Organization = {IEEE; IEEE Comp Soc; Zhejiang Univ, Shanghai Inst Advance Study Inst;
   Shanghai Jiao Tong Univ; Penny Pans Grp, ZGC Forum \& Exhibit; Shanghai
   Minkun Hlth Serv Grp},
Abstract = {Cyber-physical systems are integral to the infrastructure of global
   communication and transportation networks, which makes it crucial to
   detect faults, prevent cyber attacks, and ensure operational safety.
   Although machine learning techniques, including large language models
   (LLMs), have been explored for fault detection, the efficacy of
   open-source LLMs remains underexplored. In this work, we assess the
   capabilities of eight open-source LLMs in identifying faults in
   cyber-physical systems using a simulation dataset from monitoring an
   electrified vehicle's battery management system. By applying pretrained
   LLMs without fine-tuning and incorporating retrieval augmented
   generation (RAG) techniques alongside textual encoding methods, our
   study aims to explore the potential of open LLMs in fault detection. Our
   results show that open LLMs can effectively identify faults, with
   Mistral outperforming alternative models such as Mixtral, codellama, and
   Gemma in precision, recall, and F1-score metrics. Furthermore, our
   results highlight the importance of textual encoding strategies in
   enhancing the fault detection capabilities of LLMs, which possess a
   degree of explanatory power with respect to the detected anomalies. This
   work demonstrates the feasibility of using open LLMs for fault detection
   in cyber-physical systems and opens avenues for future research to
   enhance fault detection and fault localization.},
