@article{ WOS:001715639900001,
Author = {Wang, Ziqi and Yang, Tianyu and Wang, Xin and Zhang, Yuxuan and Qiu,
   Huaxiao and Feng, Jianzhou},
Title = {DRGO:dynamic retrieval and generation optimization based on fine-grained
   confidence evaluation},
Journal = {JOURNAL OF INTELLIGENT INFORMATION SYSTEMS},
Year = {2026},
Month = {2026 MAR 16},
Abstract = {Large Generative Models have been widely used in various fields;
   however,the accuracy and reliability of its generated results still face
   significant challenges. Retrieval-augmented Generation (RAG) effectively
   improves generation performance by incorporating external knowledge, but
   existing methods suffer from issues of retrieval redundancy and noise
   interference, which lead to increased error rates and reduced relevance
   in generated content. To address this issue, this paper proposes a
   Dynamic Retrieval-Generation Optimization (DRGO) method based on
   fine-grained confidence evaluation. DRGO dynamically determines the
   necessity of retrieval through sentence-level confidence evaluation,
   thereby reducing unnecessary retrieval operations. Specifically, DRGO
   first generates multiple candidate answer sets through multiple sampling
   and decomposes the reference answer into sentence-level independent
   units for quantitative confidence evaluation. For low-confidence
   content, an efficient retrieval strategy guided by factual content is
   designed, which extracts key factual components from the generated
   content for targeted retrieval, further optimizing the completeness and
   reliability of the generated content. Experiments on multiple reasoning
   datasets (e.g., OpenBookQA, ARC-Challenge, ARC-Easy, CommonsenseQA, PIQA
   and FEVER) demonstrate that, compared to the strongest baseline methods,
   DRGO improves average accuracy by approximately 2.02\%, achieving
   comparable or even better results than iterative retrieval methods while
   maintaining the efficiency of single-step retrieval.},
