@inproceedings{ WOS:001572100200200,
Author = {Carraro, Tommaso and Singh, Brijraj and Pedanekar, Niranjan},
Book-Group-Author = {ACM},
Title = {Large Language Model-based Recommendation System Agents},
Booktitle = {PROCEEDINGS OF THE NINETEENTH ACM CONFERENCE ON RECOMMENDER SYSTEMS,
   RECSYS2025},
Year = {2025},
Pages = {1340-1342},
Note = {19th Conference on Recommender Systems-RECSYS-Annual, Prague, CZECH
   REPUBLIC, SEP 22-26, 2025},
Organization = {Association for Computing Machinery},
Abstract = {A Large Language Model-based agent is an AI assistant that makes use of
   advanced Tool Calling (TC) and Retrieval Augmented Generation (RAG)
   techniques to access external tools (e.g., Python code, databases). This
   allows the agent to consult additional sources of information that are
   complementary to its pre-trained knowledge. By doing so, re-training or
   fine-tuning of the LLM each time new knowledge becomes available can be
   avoided, as the assistant can access this information thanks to the
   available tools. In this demo, we investigate this idea in the
   Recommendation Systems (RSs) scenario. In particular, we design an AI
   assistant for recommendation that can access (i) a pre-trained
   recommender system, (RSs) a database, and (ii) a vector store. The demo
   shows how the assistant is able to interact with these tools to reply to
   complex recommendation and explanation queries that require reasoning on
   the tool's results. To the best of our knowledge, this is the first
   attempt at designing LLM-based recommendation system agents. The code
   for this demo paper is available at this URL1.},
