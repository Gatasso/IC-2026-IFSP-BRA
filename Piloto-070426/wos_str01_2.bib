@inproceedings{ WOS:001211835200036,
Author = {Rony, Md. Rashad Al Hasan and Sahoo, Soumya Ranjan and Khan, Abbas Goher
   and Friedl, Ken E. and Sudhi, Viju and Suess, Christian},
Editor = {Goharian, N and Tonellotto, N and He, Y and Lipani, A and McDonald, G and Macdonald, C and Ounis, I},
Title = {Incorporating Query Recommendation for Improving In-Car Conversational
   Search},
Booktitle = {ADVANCES IN INFORMATION RETRIEVAL, ECIR 2024, PT V},
Series = {Lecture Notes in Computer Science},
Year = {2024},
Volume = {14612},
Pages = {304-312},
Note = {46th European Conference on Information Retrieval (ECIR), Glasgow,
   SCOTLAND, MAR 24-28, 2024},
Organization = {Univ Glasgow; British Comp Soc, Informat Retrieval Specialist Grp},
Abstract = {Retrieval-augmented generation has become an effective mechanism for
   conversational systems in domain-specific settings. Retrieval of a wrong
   document due to the lack of context from the user utterance may lead to
   wrong answer generation. Such an issue may reduce the user engagement
   and thereby the system reliability. In this paper, we propose a
   context-guided follow-up question recommendation to internally improve
   the document retrieval in an iterative approach for developing an in-car
   conversational system. Specifically, a user utterance is first
   reformulated, given the context of the conversation to facilitate
   improved understanding to the retriever. In the cases, where the
   documents retrieved by the retriever are not relevant enough for
   answering the user utterance, we employ a large language model (LLM) to
   generate question recommendation which is then utilized to perform a
   refined retrieval. An empirical evaluation confirms the effectiveness of
   our proposed approaches in in-car conversations, achieving 48\% and 22\%
   improvement in the retrieval and system generated responses,
   respectively, against baseline approaches.},
