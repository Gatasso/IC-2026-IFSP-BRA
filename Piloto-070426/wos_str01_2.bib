@inproceedings{ WOS:001706225500126,
Author = {Xu, Feng and Qian, Jianguo and Chen, Jiachen and Huang, Yinqiang and
   Chen, Shixuan and Wang, Dexin and Dai, Yuanjun},
Book-Group-Author = {IEEE},
Title = {Research on Dispatching Incident Management Based on the Synergy of
   Multimodal Knowledge Graph and Large Language Model},
Booktitle = {2025 8TH INTERNATIONAL CONFERENCE ON POWER AND ENERGY APPLICATIONS,
   ICPEA},
Series = {International Conference on Power and Energy Applications},
Year = {2025},
Pages = {722-727},
Note = {8th International Conference on Power and Energy
   Applications-ICPEA-Annual, Shanghai, PEOPLES R CHINA, OCT 23-25, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; IEEE Power and
   Energy Society; Shanghai Jiao Tong University},
Abstract = {The management of power grid dispatching accidents is hindered by
   complex, multimodal information and the inherent limitations of
   standalone AI technologies. While Knowledge Graphs (KGs) offer
   structured reasoning, they often lack flexibility. Conversely, Large
   Language Models (LLMs) can suffer from factual hallucinations and a lack
   of domain-specific grounding. To address these challenges, we propose
   MMKG-RAG, a collaborative decision-making framework that synergizes a
   Multi-Modal Knowledge Graph (MMKG) with a Multi-Modal Large Language
   Model (MLLM). Our approach first constructs a domain-specific MMKG by
   fusing three knowledge sources: structured facts extracted from
   technical texts, grid topology modeled by Graph Neural Networks (GNNs),
   and visual features from equipment imagery identified by YOLOv8 and
   CLIP. Subsequently, a collaborative reasoning mechanism based on
   Retrieval-Augmented Generation (RAG) performs hybrid retrieval from a
   Neo4j graph database and a ChromaDB vector store. This dual- retrieval
   process provides the MLLM with both precise factual grounding and rich
   semantic context, effectively steering it to generate high-quality,
   factually consistent dispatching advice. Experimental results validate
   that our proposed framework significantly outperforms baseline models in
   text generation quality and factual accuracy, demonstrating its
   potential for effective application in real-world accident management.},
