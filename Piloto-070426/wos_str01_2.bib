@inproceedings{ WOS:001668797600003,
Author = {Bianchini, Filippo and van den Heuvel, Willem-Jan and Marinacci, Matteo
   and Mecella, Massimo and Rossi, Jacopo and Tamburri, Damian A.},
Editor = {Aiello, M and Barzen, J and Dustdar, S and Leymann, F},
Title = {Talk Smart, Stay Safe: Intelligent Conversational Agents for Urban
   Security},
Booktitle = {SERVICE-ORIENTED COMPUTING, SUMMERSOC 2025},
Series = {Communications in Computer and Information Science},
Year = {2026},
Volume = {2602},
Pages = {37-56},
Note = {19th Symposium and Summer School on Service Oriented
   Computing-SummerSOC, GREECE, JUN 16-21, 2025},
Abstract = {This paper introduces the Safe-Cities Chatbot, a novel conversational AI
   system designed to support urban security planning and emergency
   management, with a focus on complex cross-border scenarios. The system
   integrates Retrieval-Augmented Generation (RAG) techniques with
   domain-specific knowledge from the Security Vulnerability Assessment
   (SVA) framework, enabling context-aware assistance for security
   professionals. Unlike existing solutions, the chatbot was developed and
   evaluated using a real-world test Piazza Transalpina, a public square on
   the Italian-Slovenian border incorporating local regulatory constraints,
   spatial dynamics, and multi-agency coordination challenges. The chatbot
   supports three core functions: guiding users through structured security
   assessments, offering event-specific planning advice, and simulating
   emergency scenarios tailored to the location. We detail the systems
   architecture, its contextual reasoning strategies, and the simulation
   engine design. Our results demonstrate the potential of AIdriven
   conversational tools to enhance situational awareness, improve
   preparedness, and facilitate security planning across jurisdictions a
   growing need in the face of new urban threats and regulatory
   requirements such as the NIS2 directive.},
