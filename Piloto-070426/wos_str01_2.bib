@inproceedings{ WOS:001600160000017,
Author = {Zhao, Marilyn and Mao, Helena and Zhu, Emily and Chen, Stephanie and
   Gonzalez, Carlos and Li, Youyi and Wang, Jingning and Nganga, Abigail
   and Shi, Ella and Kong, Emma and Su, Yanfang and Sun, Yu},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Policy Pulse: Bridging the Gap Between Scientific Research and Public
   Accessibility Through Generative AI and Summarization Models},
Booktitle = {2025 8TH INTERNATIONAL CONFERENCE ON SOFTWARE AND SYSTEM ENGINEERING,
   ICOSSE},
Year = {2025},
Pages = {99-104},
Note = {8th International Conference on Software and System
   Engineering-ICOSSE-Annual, Nice, FRANCE, APR 04-06, 2025},
Abstract = {The complexity and inaccessibility of scientific research papers often
   create a significant barrier between the scientific community and the
   general public, hindering effective communication and delaying informed
   policymaking. Policy Pulse addresses this gap by utilizing a
   Retrieval-Augmented Generation (RAG) model to transform complex research
   papers into concise, comprehensible policy briefs. The model processes
   research documents through three main stages: preprocessing, retrieval,
   and generation, leveraging technologies like vector embeddings and large
   language models to produce high-quality summaries. Experiments
   demonstrated that Policy Pulse captures core semantic insights
   effectively, achieving high BERT scores compared to alternatives like
   OpenAI and Google Gemini, despite lower ROUGE-L scores indicating room
   for improvement in surface-level precision. The solution prioritizes
   intellectual property protection, user customization, and accessibility
   by maintaining a reading level suitable for non-experts. Challenges
   include processing efficiency, ethical considerations in usage, and
   limitations in multilingual capabilities. Future development aims to
   enhance interactivity, address feedback integration, and expand
   multilingual support to improve global applicability. Policy Pulse
   presents a novel approach to bridging the divide between science and
   society, fostering informed policymaking and public engagement.},
