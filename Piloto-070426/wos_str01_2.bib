@article{ WOS:001687339700003,
Author = {Zhou, Yigeng and Li, Wu and Lu, Yifan and Wang, Yequan and Liu, Xuebo
   and Wang, Wenya and Yu, Jun and Zhang, Min and Li, Jing},
Title = {Mitigating Context-Memory Conflicts in LLMs Through Dynamic Cognitive
   Reconciliation Decoding},
Journal = {IEEE TRANSACTIONS ON AUDIO SPEECH AND LANGUAGE PROCESSING},
Year = {2026},
Volume = {34},
Pages = {1004-1015},
Abstract = {Large language models accumulate extensive parametric knowledge through
   pre-training. However, knowledge conflicts occur when outdated or
   incorrect parametric knowledge conflicts with external knowledge in the
   context. Existing methods address knowledge conflicts through
   contrastive decoding, but in conflict-free scenarios, static approaches
   disrupt output distribution. Other dynamic decoding methods attempt to
   measure the degree of conflict but still struggle with complex
   real-world situations. In this paper, we propose a two-stage decoding
   method called Dynamic Cognitive Reconciliation Decoding (DCRD), to
   predict and mitigate context-memory conflicts. DCRDfirst analyzes the
   attention map to assess context fidelity and predict potential
   conflicts. Based on this prediction, the input is directed to one of two
   decoding paths: (1) greedy decoding, or (2) context fidelity-based
   dynamic decoding. This design enables DCRDto handle conflicts
   efficiently while maintaining high accuracy and decoding efficiency in
   conflict-free cases. Additionally, to simulate scenarios with frequent
   knowledge updates, we constructed ConflictKG, a knowledge conflict QA
   benchmark. Experiments on four LLMs across six QA datasets show that
   DCRDoutperforms all baselines, achieving state-of-the-art performance.},
