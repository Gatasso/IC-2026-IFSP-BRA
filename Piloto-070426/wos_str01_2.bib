   Arslan, Muhammad, Univ West England, Sch Architecture \& Environm, Coldharbour Lane, Bristol BS16 1QY, England.
   Arslan, Muhammad; Cruz, Christophe, Univ Bourgogne, Lab Interdisciplinaire Carnot Bourgogne ICB, Dijon, France.
   Munawar, Saba, Natl Univ Comp \& Emerging Sci NUCES, Elect Telecommun Engn Dept, Islamabad, Pakistan.},
DOI = {10.1080/12460125.2024.2410040},
EarlyAccessDate = {OCT 2024},
