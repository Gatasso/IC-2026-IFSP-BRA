Language = {English},
Affiliation = {Xue, YW (Corresponding Author), Hitachi Ltd, Res \& Dev Grp, Tokyo, Japan.
   Xue, Yawen; Tsunokake, Masaya; Koreeda, Yuta; Sogawa, Yasuhiro, Hitachi Ltd, Res \& Dev Grp, Tokyo, Japan.},
