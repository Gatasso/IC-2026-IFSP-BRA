@inproceedings{ WOS:001706214300048,
Author = {Denuri, T. T. L. and Ragukanthan, S. and Wijesekara, W. A. D. N. and
   Prageeth, M. D. and Silva, A. T. P. and Attanayaka, L.},
Editor = {Shyama and Piyatilake and Thanuja and Kaushalya, S and Kavishka, T and Madhuwanthi, T},
Title = {Archelon AI: Programming Assistant for Legacy Codebases},
Booktitle = {2025 10TH INTERNATIONAL CONFERENCE ON INFORMATION TECHNOLOGY RESEARCH,
   ICITR},
Series = {International Conference on Information Technology},
Year = {2025},
Note = {10th International Conference on Information Technology
   Research-ICITR-Annual, Colombo, SRI LANKA, DEC 08-11, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Maintaining and upgrading legacy software systems poses a growing
   challenge due to poor documentation, increased system complexity, and a
   shortage of developers skilled in older languages like Perl. This paper
   presents Archelon AI, a domain specific programming assistant designed
   to improve developer productivity and system maintainability. The system
   comprises of two main components: a chat assistant and an IDE
   integration plugin for Visual Studio Code. Archelon AI is powered by a
   fine-tuned Qwen2.5 Coder 3B instruct model on the Perl Programming
   Language. It supports natural language prompts for code generation,
   explanation, and error debugging. The system enhances response and
   accuracy by incorporating relevant context from user-provided PDFs, web
   links, and GitHub repositories using Retrieval Augmented Generation
   (RAG) with vector databases. Along with context-awareness, the chat
   assistant supports session- based interactions which enhances the
   conversation organization and continuity. The IDE plugin supports
   context-aware code suggestions, ghost text generation, alternative
   implementations, a real-time error detection. Together these features
   deliver accurate, context-sensitive assistance that streamlines
   development workflows in outdates codebases. Archelon AI demonstrates
   the potential of integrating large language Models (LLMs) and modern AI
   infrastructure to support legacy programming environments effectively.},
