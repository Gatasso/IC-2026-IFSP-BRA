@inproceedings{ WOS:001706337700437,
Author = {Wang, Puzhou and Pan, Haixia and Bo, Jiale},
Book-Group-Author = {IEEE},
Title = {IR-DED:An Adaptive Retrieval-Augmented Generation Framework Supporting
   Iterative Reasoning and Instruction Denoising},
Booktitle = {2025 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS, IJCNN},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2025},
Note = {2025 International Joint Conference on Neural Networks-IJCNN, Rome,
   ITALY, JUN 30-JUL 05, 2025},
Organization = {PONTIFICAL GREGORIAN UNIVERSITY; International Neural Network Society;
   Institute of Electrical and Electronics Engineers Inc; IEEE
   Computational Intelligence Society; Sapienza University Rome; Intesa
   Sanpaolo Bank; IEEE Power and Energy Society},
Abstract = {Retrieval-Augmented Generation (RAG) demonstrates significant potential
   in enhancing the accuracy and factual consistency of language models by
   incorporating non-parametric knowledge from external knowledge bases.
   However, existing frameworks face three key challenges: 1.Existing
   active retrieval methods rely on single, rigid standards and are prone
   to misalignment between queries and retrieved results. 2.For noisy
   retrieval results, current re-ranking approaches based on cross-entropy
   loss optimization are overly sensitive to imbalanced data, and obtaining
   supervised denoising data is prohibitively expensive. 3.For complex
   questions, current decomposition strategies fall short in effectively
   addressing knowledge-intensive tasks. To address these challenges, We
   proposes an iterative augmentation framework that integrates dynamic
   routing with instruction-based denoising. First, the framework extends
   the criteria for query complexity and retrieves relevant results based
   on hypothetical document alignment. Second, the model employs
   instruction-following synthesis principles to achieve denoising during
   the re-ranking process. Finally, the framework incorporates
   pseudo-question generation to iteratively decompose and process complex
   queries. Experiments on diverse and multi-hop question-answering tasks
   demonstrate state-of-the-art performance with this approach.},
