@inproceedings{ WOS:001669970000060,
Author = {Gautam, Yogesh and Jebelli, Houtan},
Editor = {Akinci, B and Berges, M and Jazizadeh, F and Menassa, CC and Yeoh, J},
Title = {Retrieval Augmented Generation (RAG)-Based Personalized Feedback for
   Construction Worker Well-Being},
Booktitle = {COMPUTING IN CIVIL ENGINEERING 2024: SUSTAINABILITY, RESILIENCE, SAFETY,
   AND EDUCATION},
Year = {2024},
Pages = {559-567},
Note = {2024 International Conference on Computing in Civil Engineering-I3CE,
   Carnegie Mellon University, Pittsburgh, PA, JUL 28-31, 2024},
Abstract = {Recent strides in wearable sensor technology and artificial intelligence
   have opened unprecedented avenues for monitoring the health of
   construction workers on-site. Despite these technological advancements,
   a critical challenge persists in efficiently communicating real-time
   health information to workers. This study bridges this gap by
   introducing a natural language-based system tailored for providing
   personalized health status feedback to on-site construction workers.
   Employing a generative pre-trained transformer (GPT) model integrated
   into a retrieval augmented generation (RAG) pipeline, the system crafts
   individualized messages by integrating data from wearable sensors,
   machine learning models, and regulatory guidelines. Consequently, the
   system delivers confidential, context-sensitive feedback to construction
   workers on-site along with corresponding risk mitigation strategies. The
   accuracy of the system was evaluated using various performance metrics,
   achieving a BLEU score of 0.75, a BERT score of 0.3, and a sentence
   embedding score of 0.9. The findings demonstrated promising results,
   providing workers with accurate and effective feedback regarding their
   health status. This innovative communication approach not only addresses
   a critical research gap but also establishes a new benchmark for
   personalized feedback systems within the construction industry.
   Ultimately, this advancement can contribute to enhancing worker
   awareness and fostering a safer and more inclusive construction work
   environment.},
