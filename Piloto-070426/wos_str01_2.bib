@inproceedings{ WOS:001511154403060,
Author = {Fu, Jia and Qin, Xiaoting and Yang, Fangkai and Wang, Lu and Zhang, Jue
   and Lin, Qingwei and Chen, Yubo and Zhang, Dongmei and Rajmohan, Saravan
   and Zhang, Qi},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {AutoRAG-HP: Automatic Online Hyper-Parameter Tuning for
   Retrieval-Augmented Generation},
Booktitle = {FINDINGS OF THE ASSOCIATION FOR COMPUTATIONAL LINGUISTICS: EMNLP 2024},
Year = {2024},
Pages = {3875-U995},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {Recent advancements in Large Language Models have transformed ML/AI
   development, necessitating a reevaluation of AutoML principles for the
   Retrieval-Augmented Generation (RAG) systems. To address the challenges
   of hyper-parameter optimization and online adaptation in RAG, we propose
   the AutoRAG-HP framework, which formulates the hyperparameter tuning as
   an online multi-armed bandit (MAB) problem and introduces a novel
   two-level Hierarchical MAB (Hier-MAB) method for efficient exploration
   of large search spaces. We conduct extensive experiments on tuning
   hyper-parameters, such as top-k retrieved documents, prompt compression
   ratio, and embedding methods, using the ALCE-ASQA and Natural Questions
   datasets. Our evaluation from jointly optimization all three
   hyper-parameters demonstrate that MAB-based online learning methods can
   achieve Recall@5 approximate to 0.8 for scenarios with prominent
   gradients in search space, using only similar to 20\% of the LLM API
   calls required by the Grid Search approach. Additionally, the proposed
   Hier-MAB approach outperforms other baselines in more challenging
   optimization scenarios. The code will be made available at
   https://aka.ms/autorag.},
