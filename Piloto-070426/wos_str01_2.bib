@inproceedings{ WOS:001706371900087,
Author = {Wang, Sihan and Wang, Kai and Zeng, Peng and Li, Dong and Yang, Jiayin
   and Zhang, Shusheng and Cao, Liqun},
Book-Group-Author = {IEEE},
Title = {A Large Model for Integrated Diagnosis, Prognosis, and Decision-Making
   in Intelligent Operation and Maintenance},
Booktitle = {2025 7TH INTERNATIONAL CONFERENCE ON SYSTEM RELIABILITY AND SAFETY
   ENGINEERING, SRSE},
Year = {2025},
Pages = {543-548},
Note = {7th International Conference on System Reliability and Safety
   Engineering-SRSE, Changchun, PEOPLES R CHINA, NOV 20-23, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; National
   University of Singapore; Shenyang Institute of Automation, CAS; Harbin
   Institute of Technology},
Abstract = {The field of Industrial Prognostics and Health Management (PHM) has long
   been divided between two competing paradigms: accurate yet opaque signal
   models and knowledgeable yet unreliable large language models (LLMs).
   Specialized signal models excel in targeted applications such as fault
   diagnosis and remaining useful life (RUL) prediction, yet they cannot
   provide holistic maintenance guidance. In contrast, general-purpose LLMs
   possess strong reasoning capabilities but remain prone to
   domain-specific hallucinations, limiting their reliability in industrial
   environments. To bridge this gap, this paper introduces a unified
   framework based on a collaborative large-small model architecture. The
   core of our approach semantically aligns high-precision signal models
   with an LLM-driven decision layer. Furthermore, to ground the LLM in
   domain-specific knowledge, we incorporate a retrieval-augmented
   generation (RAG) mechanism, which dynamically queries a structured
   knowledge base during the decision-making process. The proposed
   framework thus provides an integrated large-model solution in which
   diagnosis, prognosis, and maintenance decisions are coherently unified,
   thereby paving the way for autonomous intelligent operation and
   maintenance.},
