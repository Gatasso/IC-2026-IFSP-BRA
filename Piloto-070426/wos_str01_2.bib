@inproceedings{ WOS:001413988900044,
Author = {Wang, Qiyang and Wu, Ling -I and Li, Guoquiang},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {PIRTRE-C: A Two-Stage Retrieval and Reranking Enhanced Framework for
   Improving Chinese Psychological Counseling},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON MEDICAL ARTIFICIAL INTELLIGENCE,
   MEDAI 2024},
Year = {2024},
Pages = {337-347},
Note = {2024 International Conference on Medical Artificial Intelligence,
   Chongqing, PEOPLES R CHINA, NOV 15-17, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The rapid evolution of modern society and the pervasive high-stress
   lifestyle have led to an increasing incidence of mental health
   challenges. Anxiety, depression, and stress management have become
   prevalent issues requiring attention, highlighting the importance of
   psychological counseling. Large language models (LLMs) have demonstrated
   remarkable proficiency in understanding and generating natural language
   texts, making them versatile tools in the realm of mental health.
   However, current LLMs often provide generic responses during
   psychological counseling sessions, reflecting a lack of depth in
   understanding and empathy. Moreover, they struggle to identify potential
   psychological disorders in users during interactions and to formulate
   professional treatment strategies. Retrieval augmented generation (RAG)
   improves text generation by integrating insights from external knowledge
   repositories, thereby enhancing the accuracy and fidelity of generated
   responses. In this study, we introduce PIRTRE-C (Psychological
   Information Retrieval and Reranking for Enhanced Cognition), a framework
   designed to address these limitations. PIRTRE-C begins by retrieving
   pertinent knowledge from a corpus of psychology-related data. Then, a
   re-ranker is employed to sequence the retrieved texts based on
   relevance. Finally, by utilizing the acquired information through
   contextual assimilation, our objective is to enable LLMs to provide more
   empathetic and professional responses to inquiries in psychological
   counseling.},
