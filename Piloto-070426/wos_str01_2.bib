Title = {Integrating Vector Stores and Information Retrieval for Analysis
   Literature Data on Mycobacterium tuberculosis: experience
   feedback},
Booktitle = {2025 5TH IEEE MIDDLE EAST AND NORTH AFRICA COMMUNICATIONS CONFERENCE,
   MENACOMM},
