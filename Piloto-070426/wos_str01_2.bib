Editor = {Gervasi, O and Murgante, B and Garau, C and Karaca, Y and Taniar, D and Rocha, AMAC and Apduhan, BO},
Title = {A Generative AI Based Architecture for Data Seeding in Software Testing},
Booktitle = {COMPUTATIONAL SCIENCE AND ITS APPLICATIONS-ICCSA 2025, PT II},
