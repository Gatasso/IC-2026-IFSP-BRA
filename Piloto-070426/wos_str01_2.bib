@inproceedings{ WOS:001706214300049,
Author = {Fernando, Sehara Arunodya and Meegama, Lahiruni and Dananjana, Ashini
   and Laavanjan and Kulawansa, K. A. Dilini T. and Janith, Shashika and
   Ekanayake, Lesly and Nihaaj, N. M. M.},
Editor = {Shyama and Piyatilake and Thanuja and Kaushalya, S and Kavishka, T and Madhuwanthi, T},
Title = {Document Analysis Software for Construction Domain: DoCon AI},
Booktitle = {2025 10TH INTERNATIONAL CONFERENCE ON INFORMATION TECHNOLOGY RESEARCH,
   ICITR},
Series = {International Conference on Information Technology},
Year = {2025},
Note = {10th International Conference on Information Technology
   Research-ICITR-Annual, Colombo, SRI LANKA, DEC 08-11, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The construction industry relies heavily on extensive documentation
   throughout all project phases, yet most organizations continue to manage
   these documents manually, leading to delays, errors, disputes, and
   reduced productivity. Existing digital solutions offer only limited
   AI-based capabilities and fail to provide comprehensive support for
   document analysis, comparison, versioning, and contextual information
   retrieval. To address these limitations, this research presents DoConAI,
   an AI-powered document analysis and management system designed
   specifically for the construction domain. DoConAI integrates advanced
   technologies-including Large Language Models, Retrieval-Augmented
   Generation (RAG), OCR, FAISS-based semantic search, and intelligent
   analytics-to automate document categorization, summarization,
   comparison, cost prediction, and report generation. The system further
   incorporates a context-aware chatbot capable of responding using project
   documents, general knowledge, and multi-level fallback mechanisms.
   Developed using Next.js, FastAPI, and MongoDB, and deployed across web
   and mobile platforms, DoConAI enables real-time access, efficient
   document handling, and enhanced decision-making for all stakeholders.
   Evaluation through expert testing confirms that DoConAI significantly
   improves accuracy, usability, and workflow efficiency compared to
   existing construction management systems. The solution demonstrates the
   transformative potential of AI-driven document intelligence in
   modernizing construction project workflows.},
