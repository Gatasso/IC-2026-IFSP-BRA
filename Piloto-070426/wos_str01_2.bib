Title = {RAG Based Product Review Summarization and Faithfulness Evaluation},
Booktitle = {TRENDS AND APPLICATIONS IN KNOWLEDGE DISCOVERY AND DATA MINING, PAKDD
   2025 WORKSHOPS},
