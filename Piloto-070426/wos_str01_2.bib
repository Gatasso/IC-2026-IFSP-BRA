@article{ WOS:001630245200004,
Author = {Fan, Tao and Wang, Hao and Zhao, Yuehua and Zhou, Shu and Shi, Bin},
Title = {When MLLMs Meet ICH: A visual retrieval-augmented generation-based
   method for intangible cultural heritage image recognition-take Shadow
   Puppetry as a case},
Journal = {INFORMATION PROCESSING \& MANAGEMENT},
Year = {2026},
Volume = {63},
Number = {3},
Month = {APR},
Abstract = {Designing the precise Intangible Cultural Heritage (ICH) image
   recognition model is beneficial for the public to perceive and
   understand ICH. Existing related studies mainly employ the supervised
   learning method while facing challenges of the dependency on extensive
   labeled data with high quality and limited scalability for recognizing
   new categories. The emergence of Multimodal Large Language Models
   (MLLMs) brings new opportunities due to the intrinsic intensive
   knowledge but how to harness the capability for domain-specific task is
   the challenge. Based on that, we propose the Visual Retrieval-Augmented
   Generation-based Method (VRAGM) for ICH image recognition, which is
   composed of the optimized retriever, demonstration augmentation, and
   generation, through improving the visual embedding model with finetuning
   strategy, introducing the top-K similar and unsimilar images based on
   the visual semantic similarity, and injecting the domain expert
   knowledge. The proposed method is not only evaluated on the constructed
   ICH image dataset (Shadow Puppetry) but the public Architectural
   Heritage Elements dataset for the verification of robustness and
   generalization. The experimental results showcase the superiority of the
   proposed method compared with strong baseline models. The findings
   indicate that the proposed optimized retriever method significantly
   enhances retrieval quality, the incorporation of top-K similar and
   unsimilar images enables model to learn contrastive visual features
   thereby bolstering the performance, and the injection of domain expert
   knowledge improves the model's capability to comprehend and perceive the
   domain task as demonstrated by empirical experimental results and
   ablation studies. To the best of our knowledge, we are the first to
   introduce MLLMs and explore visual RAG method in the domain of culture
   heritage image recognition.},
