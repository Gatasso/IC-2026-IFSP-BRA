   Iraqi, Youssef and Mekouar, Loubna},
Editor = {Olney, AM and Chounta, IA and Liu, Z and Santos, OC and Bittencourt, II},
Title = {Investigating the Predictive Potential of Large Language Models in
   Student Dropout Prediction},
Booktitle = {ARTIFICIAL INTELLIGENCE IN EDUCATION, PT II, AIED 2024},
