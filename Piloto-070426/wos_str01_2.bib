@inproceedings{ WOS:001690442800062,
Author = {Giri, Animesh and Nagaraj, Shree Vidya and Shetty, Shreela Sukumar and
   Ammalajeri, Shreya},
Book-Group-Author = {IEEE},
Title = {Enhancing Campus Recruitment Readiness Through a RAG-Based System
   Integrating Query Caching and Resume Profiling},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON ELECTRONICS, COMPUTING AND
   COMMUNICATION TECHNOLOGIES, CONECCT},
Series = {IEEE International Conference on Electronics Computing and Communication
   Technologies},
Year = {2025},
Note = {11th International Conference on Electronics Computing and Communication
   Technologies-CONECCT-Annual, INDIA, JUL 10-13, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Campus placement preparation often lacks personalization, making it
   challenging for students to receive relevant guidance. To address this,
   an intelligent system leveraging Retrieval Augmented Generation (RAG)
   and Large Language Models (LLMs) is proposed to deliver context-aware
   support. The system utilizes ``BAAI/bge-small-en-v1.5{''} for efficient
   retrieval and ``Groq LLaMA3-70B 8192{''} for high-quality response
   generation. Retrieval efficiency is enhanced through a caching mechanism
   that stores frequently asked queries (FAQ), reducing redundancy and
   improving response time. A structured query-handling approach adapts
   retrieval parameters based on student's preparation phase, ensuring that
   responses remain relevant at different stages of readiness.
   Additionally, a RAG-powered Resume Analyser evaluates candidate profiles
   by comparing resumes with job descriptions, generating tailored
   recommendations for career improvement. To further support technical
   preparation, a coding assistant facilitates problem-solving in Data
   Structures and Algorithms (DSA) through real-time problem retrieval and
   AI-driven explanations. The system achieved a relevancy score of 89.3\%,
   faithfulness of 92\%, and an advice accuracy of 81\%. Experimental
   results indicate significant improvements in response accuracy,
   processing efficiency, and user engagement, demonstrating the system's
   potential to enhance campus placement readiness effectively.},
