@inproceedings{ WOS:001611618300288,
Author = {Fang, Jinyuan and Meng, Zaiqiao and Macdonald, Craig},
Editor = {Che, W and Nabende, J and Shutova, E and Pilehvar, MT},
Title = {KiRAG: Knowledge-Driven Iterative Retriever for Enhancing
   Retrieval-Augmented Generation},
Booktitle = {PROCEEDINGS OF THE 63RD ANNUAL MEETING OF THE ASSOCIATION FOR
   COMPUTATIONAL LINGUISTICS, VOL 1: LONG PAPERS},
Year = {2025},
Pages = {18969-18985},
Note = {63rd Association for Computational Linguistics Meeting-ACL-Annual,
   Vienna, AUSTRIA, JUL 27-AUG 01, 2025},
Abstract = {Iterative retrieval-augmented generation(iRAG) models offer an effective
   approach for multihop question answering (QA). However, their retrieval
   processes face two key challenges: (1) they can be disrupted by
   irrelevant documents or factually inaccurate chain-of-thoughts; (2)
   their retrievers are not designed to dynamically adapt to the evolving
   information needs in multi-step reasoning, making it difficult to
   identify and retrieve the missing information required at each iterative
   step. Therefore, we propose KiRAG1, which uses a knowledge-driven
   iterative retriever model to enhance the retrieval process of iRAG.
   Specifically, KiRAG decomposes documents into knowledge triples and
   performs iterative retrieval with these triples to enable a factually
   reliable retrieval process. Moreover, KiRAG integrates reasoning into
   the retrieval process to dynamically identify and retrieve knowledge
   that bridges information gaps, effectively adapting to the evolving
   information needs. Empirical results show that KiRAG significantly
   outperforms existing iRAG models, with an average improvement of 9.40\%
   in R@3 and 5.14\% in F1 on multi-hop QA datasets.},
