@inproceedings{ WOS:001534830800021,
Author = {Yang, Shuting and Liu, Zehui and Mayer, Wolfgang and Ding, Ningpei and
   Wang, Ying and Huang, Yu and Wu, Pengfei and Li, Wanli and Li, Lin and
   Zhang, Hong-Yu and Feng, Zaiwen},
Editor = {Barhamgi, M and Wang, H and Wang, X},
Title = {ShizishanGPT: An Agricultural Large Language Model Integrating Tools and
   Resources},
Booktitle = {WEB INFORMATION SYSTEMS ENGINEERING-WISE 2024, PT IV},
