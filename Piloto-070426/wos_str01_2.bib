@article{ WOS:001701727900001,
Author = {Sahu, Nosad and Baburajan, Reshma and Saravanane, Narayanane},
Title = {TAXObot: A Chatbot for the taxonomy of marine organisms},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {315},
Month = {JUN 10},
Abstract = {Taxonomic research is central to biodiversity science but remains
   constrained by limited expert availability, fragmented identification
   resources, and the high cost of species-level classification. Although
   large language models (LLMs) offer promise for accelerating knowledge
   access, their direct application to taxonomy is hindered by
   hallucinations, weak grounding, and poor handling of fine-scale
   diagnostic traits. We introduce TAXObot, a taxonomy-centred
   retrieval-augmented generation (RAG) system designed to support marine
   organism identification through evidence-grounded, interactive querying
   of diagnostic characters. TAXObot integrates a semi-structured,
   species-anchored knowledge base comprising 500 marine species across
   multiple taxonomic groups, curated from primary literature and
   authoritative databases. A section-aware chunking strategy preserves
   species-level coherence, producing over 6,000 structured text segments
   optimised for semantic retrieval. We evaluate the system using a
   benchmark of 2,500 curated queries spanning general description,
   diagnostic inference, taxonomic verification, and morphological
   generation. Retrieval performance reaches a Best@5 of 0.88 and Recall@10
   of 0.54 using contrastive, domain-optimised embeddings, with minimal
   sensitivity to retrieval depth. When paired with a high-capacity LLM,
   TAXObot achieves near-expert-level performance on fine-grained
   diagnostic queries, with correctness scores exceeding 4.9/5 and
   exact-match accuracy above 93\%, while hallucination rates are reduced
   to below 1\% for species identification tasks. Comparative evaluation
   across multiple LLMs further reveals that generation-time evidence
   conditioning is critical for nomenclatural precision. By explicitly
   aligning knowledge representation with taxonomic structure, TAXObot
   demonstrates how retrieval design and embedding strategy directly
   influence reliability in scientific AI systems, offering a scalable
   pathway for integrating AI into modern biodiversity research workflows.},
