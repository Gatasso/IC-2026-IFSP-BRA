@inproceedings{ WOS:001471757600078,
Author = {Rasaq, Lukmon and Yadav, Om Prakash and Siddula, Madhuri and Walthall,
   Rhonda},
Book-Group-Author = {IEEE},
Title = {Large Language Models Maintenance Approach for Commercial/Fleets},
Booktitle = {2025 ANNUAL RELIABILITY AND MAINTAINABILITY SYMPOSIUM, RAMS},
Series = {Reliability and Maintainability Symposium},
Year = {2025},
Note = {71st Reliability and Maintainability Symposium-RAMS-Annual, Destin, FL,
   JAN 27-30, 2025},
Abstract = {This paper presents a Large Language Model (LLM) framework to assess and
   map each failure mechanism and failure mode of individual Airworthiness
   Directives (ADs) available in the historical dataset. In addition, this
   framework can provide insights into related maintenance procedures and
   practices to help maintenance crews react faster and more effectively.
   Commercial and military regulators ensure the performance and protection
   of the aircraft by investigating and mitigating aircraft system failures
   through Airworthiness Directives (ADs). ADs, which delineate the total
   cost impact on operators, are imparted by the Federal Aviation
   Administration (FAA) and United States Airforce (USAF). For example, the
   Boeing 767 (B767) and its military derivative, USAF's KC46A dataset
   provide an understanding of failure mechanisms and related maintenance
   practices that may mitigate these costs.
   Additionally, AviationQA dataset was also used in this research work to
   finetune the LLMs. As compared to the B767 ADs historical dataset, this
   dataset is large as it contained about 1 million records in the training
   set.
   To facilitate faster extraction of maintenance-related information and
   ensure the reliability/accuracy of the information extracted, we
   proposed the use of the Retrieval Augmented Generation (RAG) approach.
   As a result, this framework will help the maintenance crews promptly
   resolve any symptoms of failure.
   Essentially, two LLMs which include Mistral 7b instruct model and
   Facebook Llama-2-7b-chat-hf, were finetuned individually. However, the
   result obtained shows that Mistral 7b outperformed the
   Llama-2-7b-chat-hf model on the ADs historical dataset and AviationQA
   dataset. Consequently, the Mistral 7b instruct model is used in the
   Retrieval Augmented Generation (RAG) framework.},
