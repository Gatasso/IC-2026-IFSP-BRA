Editor = {Alonso-Betanzos, A and Guijarro-Berdinas, B and Bolon-Canedo, V and Hernandez-Pereira, E and Fontenla-Romero, O and Camacho, D and Rabunal, JR and Ojeda-Aciego, M and Medina, J and Riquelme, JC and Troncoso, A},
Title = {An Architecture Towards Building a Reliable Suicide Information Chatbot},
Booktitle = {ADVANCES IN ARTIFICIAL INTELLIGENCE, CAEPIA 2024},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2024},
