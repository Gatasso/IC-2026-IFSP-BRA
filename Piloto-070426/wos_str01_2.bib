@inproceedings{ WOS:001431695500249,
Author = {Han, Rujun and Zhang, Yuhao and Qi, Peng and Xu, Yumo and Wang, Jenyuan
   and Liu, Lan and Wang, William Yang and Min, Bonan and Castelli,
   Vittorio},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {RAG-QA Arena: Evaluating Domain Robustness for Long-Form
   Retrieval-Augmented Question Answering},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING,
   EMNLP 2024},
Year = {2024},
Pages = {4354-4374},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {Question answering based on retrieval-augmented generation (RAG-QA) is
   an important research topic in NLP and has a wide range of real-world
   applications. However, most existing datasets for this task are either
   constructed using a single source corpus or consist of short extractive
   answers, which fall short of evaluating large language model (LLM) based
   RAG-QA systems on cross-domain generalization. To address these
   limitations, we create Long-form RobustQA (LFRQA), a new dataset
   comprising human-written long-form answers that integrate short
   extractive answers from multiple documents into a single, coherent
   narrative, covering 26K queries and large corpora across seven different
   domains. We further propose RAG-QA ARENA by directly comparing
   model-generated answers against LFRQA's answers using LLMs as
   evaluators. We show via extensive experiments that RAG-QA ARENA
   evaluation and human judgments on answer quality are highly correlated.
   Moreover, only 41.3\% of the most competitive LLM's answers are
   preferred to LFRQA's answers, demonstrating RAG-QA ARENA as a
   challenging evaluation platform for future research.(1)},
