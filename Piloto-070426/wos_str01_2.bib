@article{ WOS:001583849300004,
Author = {Fan, Yi and Shi, Longlong and Sun, Yu and Mi, Baigang},
Title = {AirfoilRAG: Retrieval augmented generation framework for airfoil
   aerodynamic design knowledge discovery and application},
Journal = {AEROSPACE SCIENCE AND TECHNOLOGY},
Year = {2026},
Volume = {168},
Number = {C},
Month = {JAN},
Abstract = {Data-driven airfoil design lacks expert design knowledge and suffers
   from poor interpretability, while conventional design methods
   excessively rely on design experience to meet the requirements of fast
   and efficient airfoil scheme screening. Thus, we propose an airfoil
   aerodynamic knowledge discovery and application framework based on
   combining a large language model (LLM) with retrieval augmented
   generation (RAG), called AirfoilRAG. First, based on the sensitivity
   analysis method, the discrete and continuous parameters of the geometric
   features of an airfoil are fused, and two-stage retrieval models with
   coarse ranking first stage and fine reranking second stage are
   constructed to realize the data retrieval link of coupling the geometric
   and aerodynamic characteristics of the airfoil. Furthermore, based on a
   large-parameter LLM, the correlation knowledge between the geometric
   characteristics of the airfoil and the aerodynamic performance data
   retrieved is further mined, and the LLM fine-tuning technology is used
   for efficient distillation and optimization of the knowledge. The
   knowledge method verification of airfoil aerodynamic design is performed
   based on a general airfoil dataset. The results demonstrate that the
   overall accuracy (mean absolute percentage error) of airfoil aerodynamic
   prediction does not exceed 5\%. This conclusion fully proves the
   effectiveness of AirfoilRAG. To the best of our knowledge, we are the
   first study to integrate LLMs with RAG for interpretable aerodynamic
   knowledge discovery in airfoil design, providing measurable objectives
   in both prediction accuracy and knowledge interpretability, which can
   effectively mine prior knowledge with interpretability for the airfoil
   aerodynamic design task and support the rapid and intelligent design of
   airfoils.},
