@inproceedings{ WOS:001665788100023,
Author = {Wei, Chen and Zhang, Yiwei and Guan, Xi and Zhang, Qianheng and Chen,
   Yanbing and Ji, Yuhan and Zhao, Yibo and Wang, Maoping and Nie, Ying and
   Zhuang, Hanchen and Gao, Song},
Editor = {Newsam, S and Yang, L and Gao, S and Zhu, D and Lunga, D and Mai, G and Martins, B and Arundel, S},
Title = {GeoAI for Driving Risk Assessment via Vision-Language Models: A
   Knowledge Guided RAG System and Dual Evaluation},
Booktitle = {PROCEEDINGS OF THE 8TH ACM SIGSPATIAL INTERNATIONAL WORKSHOP ON AI FOR
   GEOGRAPHIC KNOWLEDGE DISCOVERY, GEOAI 2025},
Year = {2025},
Pages = {161-173},
Note = {8th International Workshop on AI for Geographic Knowledge
   Discovery-GEOAI, Minneapolis, MN, NOV 03, 2025},
Organization = {Association for Computing Machinery; ACM Special Interest Group on
   Spatial Information; Apple Inc; Google Cloud; Esri Co Ltd; Oracle Corp;
   Quantum Geometry LLC; Springer Nature},
Abstract = {Accurate and reliable assessment of driving risks enhances road safety
   and supports efficient urban transportation management. This type of
   work utilizes diverse data sources and evaluates driving risks from
   multiple aspects. However, it remains challenging due to the complexity
   of heterogeneous data and the difficulty in interpreting varied results.
   This study introduces a novel GeoAI framework that employs
   Vision-Language Models (VLMs) with a knowledge-guided
   Retrieval-Augmented Generation (RAG) system to better estimate and
   evaluate driving risk from the geospatial environment perspective.
   Specifically, the study proposes a systematic prompt design framework
   that explicitly instructs VLMs for precise reasoning in driving risk
   scenarios. The expert knowledge-guided RAG system significantly improves
   the interpretability and accuracy of the initial VLM-generated results
   (with about 17\% average improvement in few-shot learning). Furthermore,
   a dual evaluation incorporating both objective performance metrics and
   subjective human rankings is applied to evaluate the results, revealing
   the robustness and practicality of our framework. We demonstrate that
   this framework provides an accurate identification and evaluation of
   driving risk under the real-world geospatial environment context. This
   research contributes to the advancements of traffic safety studies with
   VLMs and RAG and offers insights into geospatial environment reasoning
   tasks and multimodal GeoAI applications.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Wei, C (Corresponding Author), Univ Wisconsin Madison, Madison, WI 53706 USA.
   Wei, Chen; Zhang, Yiwei; Zhang, Qianheng; Chen, Yanbing; Ji, Yuhan; Zhao, Yibo; Wang, Maoping; Nie, Ying; Zhuang, Hanchen; Gao, Song, Univ Wisconsin Madison, Madison, WI 53706 USA.
   Guan, Xi, Cornell Univ, Ithaca, NY USA.},
