@inproceedings{ WOS:001706267700005,
Author = {Yi, Yulong and Ji, Qinwen and Zhu, Yongxu and Li, Guoxin and Liu, Lizhe
   and Chen, Jin},
Book-Group-Author = {IEEE},
Title = {Generative Model-Based Urban Blockage Modeling for Non-Line-of-Sight
   Networks with Partial Spatial Information},
Booktitle = {2025 SEVENTEENTH INTERNATIONAL CONFERENCE ON WIRELESS COMMUNICATIONS AND
   SIGNAL PROCESSING, WCSP},
Year = {2025},
Pages = {25-30},
Note = {17th International Conference on Wireless Communications and Signal
   Processing-WCSP-Annual, Chongqing, PEOPLES R CHINA, OCT 23-25, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Chongqing
   University of Posts and Telecommunications School of Automation; IEEE
   Communications Society (d/b/a IEEE ComSoc); Southeast University -
   China; University of Science and Technology of China School of Life
   Sciences; Zhejiang University},
Abstract = {In high-frequency wireless communication systems, signal propagation is
   highly susceptible to blockage from environmental obstacles. Accurate
   modeling of these blockages is critical for network planning and
   performance evaluation. This paper proposes a generative model-based
   approach for urban blockage modeling using large language models (LLMs),
   leveraging partial spatial information such as sampled building
   coordinates and statistical characteristics. The proposed method employs
   AI-assisted generative completion techniques to reconstruct
   comprehensive blockage layouts based on partial observations. Through
   both synthetic and real-world datasets, the performance of the
   LLMs-generated models is evaluated in terms of information rate and
   line-of-sight (LoS) probability. Experimental results demonstrate that
   the proposed approach can achieve high fidelity in replicating key
   communication metrics of the original environments, particularly when
   the sampled information is spatially clustered. Furthermore, the
   integration of retrieval-augmented generation (RAG) frameworks enhances
   the accuracy and adaptability of blockage reconstruction. This study
   confirms the feasibility and potential of using generative AI to support
   large-scale, data-efficient blockage modeling for future wireless
   systems.},
