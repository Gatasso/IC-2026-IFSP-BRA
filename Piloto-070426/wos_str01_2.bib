@inproceedings{ WOS:001708878900076,
Author = {Yang, Hong-Yi and Chen, Bo-Shen and Li, Yun-Jie and Li, Chao-Yin},
Book-Group-Author = {IEEE},
Title = {A Multi-Strategy Retrieval-Augmented Generation Approach for Enhancing
   Network Management},
Booktitle = {2025 25TH ASIA-PACIFIC NETWORK OPERATIONS AND MANAGEMENT SYMPOSIUM,
   APNOMS},
Series = {Asia-Pacific Network Operations and Management Symposium-APNOMS},
Year = {2025},
Note = {25th Asia-Pacific Network Operations and Management Symposium-APNOMS,
   Kaohsiung, TAIWAN, SEP 22-24, 2025},
Abstract = {With the fast growth of Large Language Models (LLMs), their use in
   network management has received more attention. While LLMs are good at
   understanding natural language, they still have clear limits in
   real-world use, especially in retrieving domain-specific knowledge and
   generating accurate responses. These problems make it hard for them to
   work well in intelligent network operations and maintenance (O\&M). To
   address these problems, this study proposes a Multi-Strategy RAG
   (Retrieval-Augmented Generation) approach that mixes hybrid retrieval,
   reranking methods, and real-time OSS. This method enhances the knowledge
   retrieval capabilities and response quality of LLMs in network
   management tasks by combining full-text and vector retrieval, using
   reranking to optimize candidate passages, and adding real-time data from
   the OSS system. Also, the method is tested using real network management
   datasets, and its result is evaluated by the RAGAS framework. Result
   shows that the method makes the retrieved knowledge more useful and the
   answers more correct. This study gives a useful way to build intelligent
   O\&M systems in network management.},
