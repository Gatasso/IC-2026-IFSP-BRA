   Chan, Brian J.; Chen, Chao-Ting; Cheng, Jui-Hung, Natl Chengchi Univ, Dept Comp Sci, Taipei, Taiwan.
   Huang, Hen-Hsen, Acad Sinica, Inst Informat Sci, Taipei, Taiwan.},
DOI = {10.1145/3701716.3715490},
ISBN = {979-8-4007-1331-6},
