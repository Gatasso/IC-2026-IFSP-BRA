@inproceedings{ WOS:001592428900492,
Author = {Lin, Junyong and Dai, Lu and Han, Ruiqian and Sui, Yijie and Wang,
   Ruilin and Sun, Xingliang and Wu, Qinglin and Feng, Min and Liu, Hao and
   Xiong, Hui},
