Title = {Privacy-Preserving Medical Advising System on Mobile Devices: On-Device
   PHI Anonymization, Medical Report Retrieval, and Cloud-Based RAG},
Booktitle = {2025 IEEE/ACM CONFERENCE ON CONNECTED HEALTH: APPLICATIONS, SYSTEMS AND
   ENGINEERING TECHNOLOGIES, CHASE},
