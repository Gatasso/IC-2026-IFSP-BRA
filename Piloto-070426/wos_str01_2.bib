@inproceedings{ WOS:001706267700129,
Author = {Wang, Yi and Wang, Ziyue and Wang, Wennai and Wu, Wei},
Book-Group-Author = {IEEE},
Title = {A Prototype of AI-Generated Network Protocol and Capability Maturity
   Evaluation},
Booktitle = {2025 SEVENTEENTH INTERNATIONAL CONFERENCE ON WIRELESS COMMUNICATIONS AND
   SIGNAL PROCESSING, WCSP},
Year = {2025},
Pages = {767-772},
Note = {17th International Conference on Wireless Communications and Signal
   Processing-WCSP-Annual, Chongqing, PEOPLES R CHINA, OCT 23-25, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Chongqing
   University of Posts and Telecommunications School of Automation; IEEE
   Communications Society (d/b/a IEEE ComSoc); Southeast University -
   China; University of Science and Technology of China School of Life
   Sciences; Zhejiang University},
Abstract = {An AI-driven approach is provided in the paper for innovative network
   protocol generation by a Large Language Model (LLM) aiming at rapid
   protocol synthesizing. The approach integrates Retrieval-Augmented
   Generation (RAG) and Chain-of-Thought (CoT) by pre-processing protocol
   specifications in text format and pre-defining prompt template files,
   respectively. Two commonly-used Point-To-Point Protocol (PPP) and Serial
   Line Internet Protocol (SLIP), the simplified variant of High-level Data
   Link Control (HDLC), are selected to restore those removed for
   AI-functional proving. The validation of the recovered protocol is
   tested for scenarios involving error control and flow control. Taking
   HDLC as a benchmark, five evaluation metrics, including sequence
   control, CRC verification, frame format compatibility, Finite State
   Machine completeness, and code usability, are employed to assess the
   quality of AI-generation. A comprehensive experiment is developed based
   on a locally deployed Llama3.1-8B baseline model, with temperature
   parameters set to 0 and 0.5. The experimental results show that LLMs are
   significantly helpful in protocol rapid and intelligent generation,
   while the combination of RAG and CoT is able to improve the
   effectiveness, yielding a 35\% enhancement in mean opinion score.},
