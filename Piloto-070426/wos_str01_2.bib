Title = {Semantically Enhanced Satellite Image Querying: A Knowledge Graph-Driven
   Agent Based System},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON ELECTRONICS, COMPUTING AND
   COMMUNICATION TECHNOLOGIES, CONECCT},
Series = {IEEE International Conference on Electronics Computing and Communication
   Technologies},
Year = {2025},
Note = {11th International Conference on Electronics Computing and Communication
   Technologies-CONECCT-Annual, INDIA, JUL 10-13, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The interpretation of Remote Sensing (RS) imagery remains a challenge
   due to the complexity of extracting meaningful insights from large-scale
   geospatial data. In this work, we propose an agentic Retrieval-Augmented
   Generation (RAG) system that enables interactive querying of a semantic
   knowledge graph-driven repository of annotated satellite images. We
   create a knowledge graph (KG) using OpenStreetMap (OSM) data, which is
   used to enhance our satellite imagery with semantic context. This is
   achieved by linking extracted geometric features (polygons) from
   satellite imagery to their corresponding entities in the knowledge
   graph, enabling precise localization and visual annotation of queried
   features. This satellite imagery builds our repository, which allows
   users to retrieve both textual responses and annotated images based on
   natural language queries. Our system effectively enhances the usability,
   accessibility, and contextual understanding of low resolution satellite
   imagery by transforming raw geospatial data into structured and
   retrievable information. Experimental results on satellite imagery of
   Bangalore demonstrate the effectiveness of our approach in retrieving
   and visualizing geographic information},
