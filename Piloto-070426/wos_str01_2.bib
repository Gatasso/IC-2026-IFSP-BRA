Title = {AI-Driven Document Analysis: Employing Streamlit, Faiss, Nvidia Nemo},
Booktitle = {2025 3RD INTERNATIONAL CONFERENCE ON INVENTIVE COMPUTING AND
   INFORMATICS, ICICI},
Year = {2025},
