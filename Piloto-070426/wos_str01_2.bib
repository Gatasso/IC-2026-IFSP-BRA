@inproceedings{ WOS:001663370300034,
Author = {Lam Nguyen and Barcelos, Erika and French, Roger and Wu, Yinghui},
Editor = {Garijo, D and Kirrane, S and Salatino, A and Shimizu, C and Acosta, M and Nuzzolese, AG and Ferrada, S and Soulard, T and Kozaki, K and Takeda, H and Gentile, AL},
Title = {KROMA: Ontology Matching with Knowledge Retrieval and Large Language
   Models},
Booktitle = {SEMANTIC WEB-ISWC 2025, PT I},
