Editor = {Folstad, A and Papadopoulos, S and Araujo, T and Law, ELC and Luger, E and Hobert, S and Brandtzaeg, PB},
Title = {Development and Evaluation of a University Chatbot Using Deep Learning:
   A RAG-Based Approach},
