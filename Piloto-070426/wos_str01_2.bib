   Wen, Zimo; Hu, Hanwen; Fang, Nan; Qian, Shiyou; Cao, Jian, Shanghai Jiao Tong Univ, Shanghai, Peoples R China.},
DOI = {10.1145/3746252.3761012},
ISBN = {979-8-4007-2040-6},
Keywords = {Retrieval-Augmented Generation; Few-Shot Time Series Forecasting; Dual
   Attention Mechanism},
