@inproceedings{ WOS:001378234403068,
Author = {Yang, Zhuolin and Ping, Wei and Liu, Zihan and Korthikanti, Vijay and
   Nie, Weili and Huang, De-An and Fang, Linxi and Yu, Zhiding and Lan,
   Shiyi and Li, Bo and Shoeybi, Mohammad and Liu, Ming-Yu and Zhu, Yuke
   and Catanzaro, Bryan and Xiao, Chaowei and Anandkumar, Anima},
Editor = {Bouamor, H and Pino, J and Bali, K},
Title = {Re-ViLM: Retrieval-Augmented Visual Language Model for Zero and Few-Shot
   Image Captioning},
Booktitle = {FINDINGS OF THE ASSOCIATION FOR COMPUTATIONAL LINGUISTICS (EMNLP 2023)},
Year = {2023},
Pages = {11844-11857},
Note = {Conference on Empirical Methods in Natural Language Processing (EMNLP),
   Singapore, SINGAPORE, DEC 06-10, 2023},
Organization = {Apple; Colossal AI; Google Res; GTCOM; King Salman Global Acad Arabic
   Language; LivePerson; SONY; Ahrefs; Alibaba Cloud; Amazon Sci; Baidu;
   ByteDance; Cohere; Megagon Labs; NEC; ANT Grp; Bloomberg Engn; HUAWEI; J
   P Morgan Chase \& Co; Salesforce; SAP; AiXplain; Duolingo; Jenni;
   Translated; Adobe; Babelscape; ModelBest; Nyonic; Mercari},
Abstract = {Augmenting pretrained language models (LMs) with a vision encoder (e.g.,
   Flamingo) has obtained the state-of-the-art results in imageto-text
   generation. However, these models store all the knowledge within their
   parameters, thus often requiring enormous model parameters to model the
   abundant visual concepts and very rich textual descriptions.
   Additionally, they are inefficient in incorporating new data, requiring
   a computational-expensive finetuning process. In this work, we introduce
   a Retrieval-augmented Visual Language Model, Re-ViLM, built upon the
   Flamingo, that supports retrieving the relevant knowledge from the
   external database for zero and in-context few-shot image-to-text
   generations. By storing certain knowledge explicitly in the external
   database, our approach reduces the number of model parameters and can
   easily accommodate new data during evaluation by simply updating the
   database. We also construct an interleaved image and text data that
   facilitates in-context few-shot learning capabilities. We demonstrate
   that Re-ViLM significantly boosts performance for image-to-text
   generation tasks, especially for zero-shot and few-shot generation in
   out-ofdomain settings with 4x less parameters compared with baseline
   methods.},
