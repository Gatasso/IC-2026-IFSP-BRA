@inproceedings{ WOS:001575960000167,
Author = {Qi, Yujia and Gu, Shijia and Ma, Wenxian and Wang, Nan and Wang, Qian},
Editor = {Shahriar, H and Alam, KS and Ohsaki, H and Cimato, S and Capretz, M and Ahmed, S and Ahamed, SI and Majumder, AKMJA and Haque, M and Yoshihisa, T and Cuzzocrea, A and Takemoto, M and Sakib, N and Elsayed, M},
Title = {DeepSem: Multilayer Semantic Image Retrieval for High-Accuracy
   Multimodal RAG in Industrial Applications},
Booktitle = {2025 IEEE 49TH ANNUAL COMPUTERS, SOFTWARE, AND APPLICATIONS CONFERENCE,
   COMPSAC},
Series = {IEEE Annual International Computer Software and Applications Conference},
Year = {2025},
Pages = {1388-1393},
Note = {49th Computers, Software and Applications Conference-COMPSAC, Toronto,
   CANADA, JUL 08-11, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The technical service costs associated with industrial software
   represent a significant portion of its lifecycle expenditures. For
   instance, large-scale software systems, such as SAP ERP, often require
   hundreds of maintenance engineers to provide troubleshooting services
   for thousands of users. Multimodal Large Language Models (MLLMs) offer a
   potential technique to perform as robot consultants, substantially
   reducing human resource costs in customer service. To achieve
   human-level response accuracy, the prevailing strategy involves
   implementing Multimodal Retrieval-Augmented Generation (MRAG) frameworks
   which equip MLLMs with detailed information and contextual references.
   However, existing MRAG frameworks are not well equipped to handle image
   data, such as user-provided error screenshots. Therefore, retrieval
   accuracy remains a critical bottleneck. This paper proposes an
   innovative retrieval methodology based on our multilayer semantic model,
   termed DeepSem, which deconstructs one image into three hierarchical
   semantic layers. During retrieval, each layer is independently matched,
   scored through weighted evaluation, and aggregated to enhance the output
   quality of large models. The experimental results demonstrate that the
   proposed framework achieves an improved retrieval accuracy of 43.9\% and
   30.6\% over MLLM baseline and naive multimodal RAG frameworks,
   respectively, without significant increases in computational latency.
   Finally, we highlight the broad applicability of this multilayer
   semantic multimodal RAG approach, offering advanced technical solutions
   for generalized customer service and intelligent QA systems in other
