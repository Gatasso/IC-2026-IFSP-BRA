   Chen, Po-Jui and Wilch, Jan and Cheng, Fan-Tien and Hsieh, Yu-Ming},
Book-Group-Author = {IEEE},
Title = {Deploying Vision Retrieval Augmented Generation as Assistant for xPPU
   Maintenance},
Booktitle = {2025 IEEE 21ST INTERNATIONAL CONFERENCE ON AUTOMATION SCIENCE AND
   ENGINEERING, CASE},
