@inproceedings{ WOS:001511155600033,
Author = {Wang, Tevin and He, Jingyuan and Xiong, Chenyan},
Editor = {Farias, DIH and Hope, T and Li, M},
Title = {RAGVIZ: Diagnose and Visualize Retrieval-Augmented Generation},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING},
Year = {2024},
Pages = {320-327},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {Retrieval-augmented generation (RAG) combines knowledge from
   domain-specific sources into large language models to ground answer
   generation. Current RAG systems lack customizable visibility on the
   context documents and the model's attentiveness towards such documents.
   We propose RAGViz, a RAG diagnosis tool that visualizes the
   attentiveness of the generated tokens in retrieved documents. With a
   built-in user interface, retrieval index, and Large Language Model (LLM)
   backbone, RAGViz provides two main functionalities: (1) token and
   document-level attention visualization, and (2) generation comparison
   upon context document addition and removal. As an open-source toolkit,
   RAGViz can be easily hosted with a custom embedding model and
   HuggingFace-supported LLM backbone. Using a hybrid ANN (Approximate
   Nearest Neighbor) index, memory-efficient LLM inference tool, and custom
   context snippet method, RAGViz operates efficiently with a median query
   time of about 5 seconds on a moderate GPU node.1},
