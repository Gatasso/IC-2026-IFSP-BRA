@inproceedings{ WOS:001704428100027,
Author = {Wang, Chao and Li, Haonan and Song, Weijian and Lin, Yiyang},
Book-Group-Author = {IEEE},
Title = {Retrieval-Augmented Generation: A Survey of Security Challenges and
   Countermeasures},
Booktitle = {2025 11TH IEEE INTERNATIONAL CONFERENCE ON PRIVACY COMPUTING AND DATA
   SECURITY, PCDS},
Year = {2025},
Pages = {210-217},
Note = {11th International Conference on Privacy Computing and Data
   Security-PCDS, Hakodate, JAPAN, AUG 01-04, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; IEEE Computer
   Society; Xidian University; Shanghai Jiao Tong University; Huazhong
   University of Science \& Technology},
Abstract = {Retrieval-Augmented Generation (RAG) systems enhance the accuracy and
   reliability of generated content by integrating retrieval and generation
   modules. However, their multi-module architecture introduces complex
   security risks. For instance, the PoisonedRAG attack demonstrates how
   injecting a small number of malicious texts into the knowledge base can
   manipulate the system to generate specific outputs. This paper provides
   the first comprehensive analysis of RAG security threats from a
   full-chain perspective, including adversarial attacks, data poisoning,
   privacy leaks, and a novel trigger-based backdoor poisoning attack. We
   also review existing defense techniques, such as robustness enhancement
   and privacy protection frameworks, and explore future research
   directions like dynamic defense, multi-modal threat handling, and
   trigger-specific countermeasures, offering insights for building secure
   and trustworthy RAG applications.},
