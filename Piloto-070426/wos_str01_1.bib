@inproceedings{ WOS:001669254000030,
Author = {Germain, Mickael and Alayet, Manel},
Book-Group-Author = {ACM},
Title = {A Hybrid GraphRAG Framework for Geospatial Contextualization in Decision
   Support Systems},
Booktitle = {PROCEEDINGS OF THE 18TH IEEE/ACM INTERNATIONAL CONFERENCE ON UTILITY AND
   CLOUD COMPUTING, UCC 2025},
Year = {2025},
Note = {18th International Conference on Utility and Cloud Computing-UCC, IMT
   Atlantique, Nantes, FRANCE, DEC 01-04, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; ACM SIGARCH},
Abstract = {Large Language Models (LLMs) face limitations in specialized domains
   such as environmental management due to hallucinations and static
   knowledge. Standard Retrieval-Augmented Generation (RAG) provides
   contextualization through vector search but struggles with complex
   queries requiring structured reasoning and explainability-crucial in
   geospatial contexts where ``where{''} matters. We propose a hybrid
   GraphRAG architecture that combines vector retrieval with a dynamically
   constructed Knowledge Graph (KG). By enabling LLMs to extract and link
   entities (e.g., regulations, project sites) within the KG, our approach
   enhances both semantic flexibility and structured reasoning, improving
   accuracy for spatially aware and regulatory queries.},
