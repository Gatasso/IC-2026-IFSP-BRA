@inproceedings{ WOS:001479295000007,
Author = {Varma, Sandeep and Shivam, Shivam and Natarajan, Sarun and Banerjee,
   Ankita and Roy, Sourodeep},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {From Data to Decisions: Enterprise-Level Domain-Specific Graph
   Retrieval-Augmented Generation Systems for Advanced Question Answering},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON BIG DATA AND SMART COMPUTING,
   BIGCOMP},
Series = {International Conference on Big Data and Smart Computing},
Year = {2025},
Pages = {41-48},
Note = {2025 International Conference on Big Data and Smart
   Computing-BIGCOMP-Annual, Kota Kinabalu, MALAYSIA, FEB 09-12, 2025},
Organization = {IEEE Computer Society; Korean Institute of Information Scientists and
   Engineers},
Abstract = {Retrieval-Augmented Generation (RAG) is aimed at improving the
   functionality of large language model (LLM) applications by
   incorporating specific data. This may include searching for relevant
   materials or files concerning a particular issue or search provided as
   background information to the LLM. Some prominent architectures like the
   Vanilla RAG architecture focuses primarily on retrieval of textual data,
   primarily utilizing vector databases, thus neglecting the structural
   intricacies of textual data, resulting in a critical gap in the
   generation process. To address this gap, we have introduced SAGE-QA
   (Scalable Advanced Graph RAG for Enterprise Question Answering), which
   significantly enhances both the retrieval and generation processes by
   emphasizing the importance of topological information for reasoning
   tasks on a variety of data sources.
   For our use case, SAGE-QA significantly outperforms current
   state-of-the-art RAG methods with its novel retrieval mechanism, which
   effectively mitigates hallucinations, and acts as a sustainable
   contextually relevant application.},
