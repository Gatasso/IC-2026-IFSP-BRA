Title = {Multiple Optimization with Retrieval-Augmented Generation and
   Fine-Grained Denoising for Biomedical Event Causal Relation Extraction},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON BIOINFORMATICS AND BIOMEDICINE,
   BIBM},
