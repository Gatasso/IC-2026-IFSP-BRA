@article{ WOS:001715247200001,
Author = {Lv, Jinxin and Li, Zijie and Gan, Jianhou and Ren, Wenqi and Chen, Shuyu
   and Wang, Jun},
Title = {Dual-strategy retrieval-augmented generation for anomaly recovery in
   large language models},
Journal = {PATTERN RECOGNITION},
Year = {2026},
Volume = {178},
Month = {OCT},
Abstract = {Large language models (LLMs) excel in question-answering tasks, but
   their heavy reliance on parametric knowledge makes them prone to
   hallucinations, especially when processing real-time information. From a
   safety-critical perspective, these hallucinations can be regarded as
   anomaly that compromise system reliability and require effective
   recovery strategies. Retrieval-augmented generation (RAG) enhances LLMs
   by retrieving relevant information from an external knowledge base,
   effectively mitigating hallucinations. However, indiscriminate retrieval
   or the inclusion of irrelevant paragraphs can introduce redundancy or
   incorrect reference texts into the RAG process, potentially harming
   model performance. To address this issue, we propose a dual-strategy
   retrieval-augmented method based on answer candidates and task
   decomposition(ACTD). This method first determines whether retrieval is
   necessary by assessing the model's parametric knowledge. It then handles
   different types of questions separately. For questions requiring
   retrieval, the method uses task decomposition to retrieve more relevant
   paragraphs. For questions that do not require retrieval, the method
   optimizes the answer generation process by evaluating candidate answers.
   Experiments demonstrate that the ACTD method outperforms existing
   retrieval-augmented generation methods. When we used Llama3-8B as the
   generation model, ACTD excelled in single-hop and multi-hop
   question-answering datasets such as NQ and HotpotQA, significantly
   enhancing fact-based reasoning while effectively reducing
   hallucination-induced anomaly.},
Publisher = {ELSEVIER SCI LTD},
Address = {125 London Wall, London, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Gan, JH (Corresponding Author), Yunnan Normal Univ, Key Lab Educ Informatizat Nationalities, Minist Educ, Juxian St 768, Kunming 650500, Peoples R China.
   Gan, JH (Corresponding Author), Yunnan Normal Univ, Yunnan Key Lab Smart Educ, Juxian St 768, Kunming 650500, Peoples R China.
