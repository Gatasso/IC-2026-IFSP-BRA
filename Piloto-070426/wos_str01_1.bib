@inproceedings{ WOS:001661448300045,
Author = {Chen, Ziyang and Min, Erxue and Zhao, Xiang and Li, Yunxin and Jia, Xin
   and Liao, Jinzhi and Wang, Shuaiqiang and Hu, Baotian and Yin, Dawei},
Book-Group-Author = {ACM},
Title = {Advancing Temporal Sensitive Question Answering through Progressive
   Multi-Step Reflection},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
Year = {2025},
Pages = {425-435},
Note = {34th Conference on Information and Knowledge Management-CIKM, SOUTH
   KOREA, NOV 10-14, 2025},
Organization = {Association for Computing Machinery; The ACM Special Interest Group on
   Hypertext and the Web; ACM Special Interest Group on Information
   Retrieval; Korea Tourism Organization; Seoul Metropolitan Government},
Abstract = {Retrieval-augmented generation (RAG) has demonstrated strong potential
   in enhancing large language models (LLMs) for complex, real-world
   question answering. However, existing RAG frameworks remain inadequate
   for temporal scenarios, primarily due to their inability to jointly
   model temporal constraints in both retrieval and reasoning. On the
   retrieval side, traditional approaches focus on semantic similarity,
   often returning outdated or temporally misaligned evidence. On the
   generation side, these systems frequently produce factually incorrect or
   hallucinated answers when confronted with incomplete or temporally
   inconsistent information. Motivated by the observed limitations, we
   propose ChronoReflect+, a temporal logic-aware RAG framework that
   incorporates hybrid temporal-aware retrieval and progressive multi-step
   reflection. Our method iteratively refines both retrieval and reasoning,
   identifying and bridging information gaps as context accumulates.
   Extensive experiments demonstrate that ChronoReflect+ significantly
   outperforms state-of-the-art RAG baselines-improving end-to-end accuracy
   by 15.2\%-particularly on questions involving implicit time expressions
   and multi-hop reasoning.},
