@article{ WOS:001341655200001,
Author = {Iaroshev, Ivan and Pillai, Ramalingam and Vaglietti, Leandro and Hanne,
   Thomas},
Title = {Evaluating Retrieval-Augmented Generation Models for Financial Report
   Question and Answering},
