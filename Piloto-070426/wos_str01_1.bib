   Lei and Cristea, I, Alexandra and Kiden, Sarah and Stein, Sebastian},
Editor = {Ardito, C and Barbosa, SDJ and Conte, T and Freire, A and Gasparini, I and Palanque, P and Prates, R},
Title = {TutorLLM: Customizing Learning Recommendations with Knowledge Tracing
   and Retrieval-Augmented Generation},
Booktitle = {HUMAN-COMPUTER INTERACTION - INTERACT 2025, PT III},
Series = {Lecture Notes in Computer Science},
Year = {2026},
