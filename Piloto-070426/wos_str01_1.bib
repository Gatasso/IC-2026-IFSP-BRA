@inproceedings{ WOS:001431695500178,
Author = {Zhao, Xinping and Li, Dongfang and Zhong, Yan and Hu, Boren and Chen,
   Yibin and Hu, Baotian and Zhang, Min},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {SEER: Self-Aligned Evidence Extraction for Retrieval-Augmented
   Generation},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING,
   EMNLP 2024},
Year = {2024},
Pages = {3027-3041},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {Recent studies in Retrieval-Augmented Generation (RAG) have investigated
   extracting evidence from retrieved passages to reduce computational
   costs and enhance the final RAG performance, yet it remains challenging.
   Existing methods heavily rely on heuristic-based augmentation,
   encountering several issues: (1) Poor generalization due to hand-crafted
   context filtering; (2) Semantics deficiency due to rule-based context
   chunking; (3) Skewed length due to sentence-wise filter learning. To
   address these issues, we propose a model-based evidence extraction
   learning framework, SEER, optimizing a vanilla model as an evidence
   extractor with desired properties through self-aligned learning.
   Extensive experiments show that our method largely improves the final
   RAG performance, enhances the faithfulness, helpfulness, and conciseness
   of the extracted evidence, and reduces the evidence length by 9.25
   times. The code will be available at https://github.com/HITsz-TMG/SEER.},
