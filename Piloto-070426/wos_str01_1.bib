@article{ WOS:001623300000001,
Author = {Jiang, Ziyang and Chen, Guangyao and Xu, Zhao},
Title = {Building regulation question-answering system using retrieval-augmented
   generation with dual-stage fine-tuned large language model},
Journal = {ADVANCED ENGINEERING INFORMATICS},
Year = {2026},
Volume = {69},
Number = {D},
Month = {JAN},
Abstract = {Building regulations are complex and interrelated, causing engineers to
   face a ``Document Skipping{''} problem when referring to multiple
   regulations, which increases information processing costs. Traditional
   question answering (QA) systems have limitations including insufficient
   specialized domain knowledge and lack of logical coherence. While
   combining Large Language Models (LLMs) with Retrieval-Augmented
   Generation (RAG) can reduce model hallucinations, the final generation
   process remains a black box lacking interpretability. This paper
   proposes an improved end-to-end building regulation RAG system combined
   with a specialized domain LLM trained through supervised fine-tuning
   capability distillation using the Open-Book Exam (OBE) framework. The
   system decomposes the retrieval task into multiple stages, with each
   stage generating results using a domain-specific LLM trained for a
   specific task within the OBE framework. The output of the previous stage
   serves as the input and reasoning basis for the subsequent stage,
   forming a complete process content tracking mechanism. This design
   provides interpretability and credibility for foundation models in
   construction engineering. Experimental results show that ROUGE-L reaches
   91.05 \%, a 27.57 \% improvement over the baseline, and Reasoning EM
   Accuracy of 98.6 \%. User evaluations show an overall score of 8.6/10,
   outperforming both GPT-4o and traditional RAG systems. The system
   effectively addresses recall difficulties, ``Document Skipping{''}, and
   noisy document interference, improving the accuracy, logical coherence,
   and user-friendliness of building regulation QA tasks.},
