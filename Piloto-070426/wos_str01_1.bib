@inproceedings{ WOS:001706379900076,
Author = {Noguera, Adriana and Mogollon-Benavides, Andres L. and Rua, Santiago and
   Sanin-Villa, Daniel and Tejada, Juan C.},
Book-Group-Author = {IEEE},
Title = {Retrieval-Augmented Generation for Maternal Healthcare: Design and
   Evaluation of a Clinical Question-Answering System in Spanish},
Booktitle = {2025 MEXICAN INTERNATIONAL CONFERENCE ON COMPUTER SCIENCE, ENC},
Series = {Proceedings of the Mexican Conference on Computer Science},
Year = {2025},
Note = {2025 Mexican International Conference on Computer Science-ENC-Annual,
   MEXICO, NOV 10-14, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Artificial intelligence (AI) is emerging as a key tool to strengthen
   maternal health through predictive models, remote monitoring, and
   decision-support systems. This work presents the design and evaluation
   of a Retrieval-Augmented Generation (RAG)-based Question Answering (QA)
   pipeline applied to clinical content on pregnancy. The system integrates
   preprocessing, semantic segmentation, and embedding generation using
   biomedical RoBERTa and multilingual SBERT models, with vector indexing
   in ChromaDB for efficient retrieval. A Colombian official guideline on
   maternal health served as the knowledge base, processed into
   semantically coherent fragments to enhance contextual retrieval.
   Experimental evaluation with hybrid strategies-combining semantic and
   keyword-based search with Cross-Encoder reranking-achieved a hit@5
   accuracy of 90\%, demonstrating the pipeline's capacity to deliver
   clinically grounded answers. Results highlight the relevance of adapting
   AI systems to Spanish-language and low-resource contexts, addressing
   challenges such as algorithmic transparency, data representativeness,
   and clinical validation. The proposed approach contributes to more
   equitable, accurate, and explainable maternal healthcare support
   systems.},
