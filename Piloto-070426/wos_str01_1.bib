Note = {6th WORLD AI IoT Congress-AIIoT-Annual, Seattle, WA, MAY 28-30, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This paper explores the application of artificial intelligence (AI) in
   extracting and analyzing data from online communities, specifically
   Reddit, to develop a first-of-its-kind, community-driven platform that
   delivers valuable insights for individuals managing Type 2 Diabetes
   (T2D). The platform leverages AI-driven techniques, including natural
   language processing (NLP), machine learning (ML), and advanced
   information retrieval systems, to streamline the discovery of relevant
   information-reducing the burden of manually sifting through vast
   user-generated content. By incorporating Retrieval Augmented Generation
   (RAG) and open-source Large Language Models (LLMs), the system enhances
   the accuracy and contextual relevance of responses to user queries,
   fostering a more supportive and informed environment for T2D management.},
