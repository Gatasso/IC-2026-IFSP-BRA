Title = {SAM-RAG: An Self-adaptive Framework for Multimodal Retrieval-Augmented
   Generation},
Booktitle = {2025 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS, IJCNN},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2025},
Note = {2025 International Joint Conference on Neural Networks-IJCNN, Rome,
   ITALY, JUN 30-JUL 05, 2025},
Organization = {PONTIFICAL GREGORIAN UNIVERSITY; International Neural Network Society;
   Institute of Electrical and Electronics Engineers Inc; IEEE
   Computational Intelligence Society; Sapienza University Rome; Intesa
   Sanpaolo Bank; IEEE Power and Energy Society},
Abstract = {Traditional Retrieval-Augmented Generation (RAG) methods are limited by
   their reliance on a fixed number of retrieved documents, often leading
   to incomplete or noisy information. While adaptive approaches have
   mitigated these issues, their application in complex multimodal tasks
   remains limited. We propose Self-adaptive Multimodal RAG (SAM-RAG),
   designed for multimodal contexts. SAM-RAG dynamically filters relevant
   documents, including image captions, and verifies the quality of both
   retrieved documents and outputs. Experiments show SAM-RAG outperforms
   state-of-the-art methods in retrieval accuracy and response generation.
   Ablation studies confirm its high recall quality and improved task
   performance in multimodal RAG.},
