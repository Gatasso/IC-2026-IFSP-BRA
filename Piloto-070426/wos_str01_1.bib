Title = {Prompt-Based Recommendation with In-Context Learning and
   Category-Enriched Modeling},
Booktitle = {2025 IEEE/ACS 22ND INTERNATIONAL CONFERENCE ON COMPUTER SYSTEMS AND
   APPLICATIONS, AICCSA},
Series = {International Conference on Computer Systems and Applications},
Year = {2025},
Note = {22nd International Conference on Computer Systems and
   Applications-AICCSA, QATAR, OCT 19-22, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The increasing scale and diversity of available content pose significant
   challenges for recommendation systems, including data sparsity,
   cold-start scenarios, and lack of personalization. We present a modular
   recommendation framework that addresses these issues by combining
   category-level sequence modeling with retrieval-augmented generation
   guided by structured prompts. By predicting semantic category
   trajectories rather than individual items, the system captures long-term
   user interests and improves generalization to unseen content. Retrieved
   documents and user context are dynamically injected into generation via
   prompt engineering strategies, enabling high-quality recommendations
   without model fine-tuning. Experiments demonstrate that incorporating
   category signals leads to substantial performance improvements,
   particularly in cold-start settings.},
