@article{ WOS:001689865300001,
Author = {Han, Nana and Liu, Dong and Norton, Tomas},
Title = {Towards an AI-based knowledge assistant for goat farmers based on
   retrieval-augmented generation},
Journal = {COMPUTERS AND ELECTRONICS IN AGRICULTURE},
Year = {2026},
Volume = {245},
Month = {APR},
Abstract = {To address the challenges of limited expertise and complex data in goat
   farming, this study creates a ``Domain-First{''} Retrieval-Augmented
   Generation (RAG) assistant framework. It uses table textualization and
   decision-tree textualization technologies to merge essential knowledge
   for goat husbandry. The system has a specialized knowledge base covering
   five key areas, including Disease Prevention and treatment, Nutrition
   Management, Rearing Management, Goat Milk Management, and Basic Farming
   Knowledge. It also includes an online retrieval module for acquiring
   real-time information. Experimental results show that this knowledge
   fusion strategy performs well, with average accuracies of 87.90\% on the
   validation set and 84.22\% on the test set. In Q\&A tasks using text,
   tables, and decision trees, accuracy exceeds 85\%, confirming the
   effectiveness of the modular design for structured knowledge. This study
   enhances the model's logical reasoning and long-tail knowledge capture
   capabilities through heterogeneous knowledge synergy. However, analysis
   reveals that ``Omission{''} is the main cause of performance loss.
   Additionally, the initial professional corpus limits retrieval coverage
   and online filtering. Future work will aim to expand the knowledge base
   through active learning and improve retrieval strategies.},
