@inproceedings{ WOS:001431695500321,
Author = {Wang, Yuhao and Ren, Ruiyang and Li, Junyi and Zhao, Wayne Xin and Liu,
   Jing and Wen, Ji-Rong},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {REAR: A Relevance-Aware Retrieval-Augmented Framework for Open-Domain
   Question Answering},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING,
   EMNLP 2024},
Year = {2024},
Pages = {5613-5626},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {Considering the limited internal parametric knowledge,
   retrieval-augmented generation (RAG) has been widely used to extend the
   knowledge scope of large language models (LLMs). Despite the extensive
   efforts on RAG research, in existing methods, LLMs cannot precisely
   assess the relevance of retrieved documents, thus likely leading to
   misleading or even incorrect utilization of external knowledge (i.e.,
   retrieved documents). To address this issue, in this paper, we propose
   REAR, a RElevance-Aware Retrieval-augmented approach for open-domain
   question answering (QA). As the key motivation, we aim to enhance the
   self-awareness regarding the reliability of external knowledge for LLMs,
   so as to adaptively utilize external knowledge in RAG systems.
   Specially, we develop a novel architecture for LLM-based RAG systems, by
   incorporating a specially designed assessment module that precisely
   assesses the relevance of retrieved documents. Furthermore, we propose
   an improved training method based on bigranularity relevance fusion and
   noise-resistant training. By combining the improvements in both
   architecture and training, our proposed REAR can better utilize external
   knowledge by effectively perceiving the relevance of retrieved
   documents. Experiments on four open-domain QA tasks show that REAR
   significantly outperforms previous a number of competitive RAG
   approaches. Our codes can be accessed at
   https://github.com/RUCAIBox/REAR.},
