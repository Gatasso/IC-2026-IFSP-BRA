@article{ WOS:001502792000002,
Author = {Ko, Seoyoung and Shim, Hyunjeong and Doh, Wanju and Yun, Sungmin and So,
   Jinin and Kwon, Yongsuk and Park, Sang-Soo and Roh, Si-Dong and Yoon,
   Minyong and Song, Taeksang and Ahn, Jung Ho},
Title = {Cosmos: A CXL-Based Full In-Memory System for Approximate Nearest
   Neighbor Search},
Journal = {IEEE COMPUTER ARCHITECTURE LETTERS},
Year = {2025},
Volume = {24},
Number = {1},
Pages = {173-176},
Month = {JAN},
Abstract = {Retrieval-Augmented Generation (RAG) is crucial for improving the
   quality of large language models by injecting proper contexts extracted
   from external sources. RAG requires high-throughput, low-latency
   Approximate Nearest Neighbor Search (ANNS) over billion-scale vector
   databases. Conventional DRAM/SSD solutions face capacity/latency limits,
   whereas specialized hardware or RDMA clusters lack flexibility or incur
   network overhead. We present Cosmos, integrating general-purpose cores
   within CXL memory devices for full ANNS offload and introducing
   rank-level parallel distance computation to maximize memory bandwidth.
   We also propose an adjacency-aware data placement that balances search
   loads across CXL devices based on inter-cluster proximity. Evaluations
   on SIFT1B and DEEP1B traces show that Cosmos achieves up to 6.72x higher
   throughput than the baseline CXL system and 2.35x over a
   state-of-the-art CXL-based solution, demonstrating scalability for RAG
   pipelines.},
