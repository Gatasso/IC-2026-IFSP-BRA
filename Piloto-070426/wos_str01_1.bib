@inproceedings{ WOS:001527543600170,
Author = {Kaiser, Magdalena and Weikum, Gerhard},
Book-Group-Author = {ACM},
Title = {Preference-based Learning with Retrieval Augmented Generation for
   Conversational Question Answering},
Booktitle = {COMPANION PROCEEDINGS OF THE ACM WEB CONFERENCE 2025, WWW COMPANION 2025},
Year = {2025},
Pages = {1053-1057},
Note = {2025 Web Conference-WWW, Sydney, AUSTRALIA, APR 28-MAY 02, 2025},
Organization = {The ACM Special Interest Group on Hypertext and the Web},
Abstract = {Conversational Question Answering (ConvQA) involves multiple subtasks,
   i) to understand incomplete questions in their context, ii) to retrieve
   relevant information, and iii) to generate answers. This work presents
   Praise, a pipeline-based approach for ConvQA that trains LLM adapters
   for each of the three subtasks. As labeled training data for individual
   subtasks is unavailable in practice, Praise learns from its own
   generations using the final answering performance as feedback signal
   without human intervention and treats intermediate information, like
   relevant evidence, as weakly labeled data. We apply Direct Preference
   Optimization by contrasting successful and unsuccessful samples for each
   subtask. In our experiments, we show the effectiveness of this training
   paradigm: Praise shows improvements per subtask and achieves new
   state-of-the-art performance on a popular ConvQA benchmark, by gaining
   15.5 percentage points increase in precision over baselines.},
