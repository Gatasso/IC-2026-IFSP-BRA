@article{ WOS:001582781700003,
Author = {Du, Kangning and Wang, Wenyu and Zhang, Benkui and Wang, Pengcheng and
   Zhang, Fan and Cao, Lin and Guo, Yanan},
Title = {IRAGKR:Iterative retrieval augmented generation with fine-grained
   knowledge refinement},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {655},
Month = {NOV 28},
Abstract = {Iterative Retrieval-Augmented Generation has emerged as a promising
   strategy for maintaining the timeliness of information. Nevertheless,
   existing iterative retrieval-augmented generation methods are often
   plagued by irrelevant text noise during multi-round retrieval cycles,
   which can lead to degraded performance. To tackle this challenge, we
   propose a novel approach called Iterative Retrieval Augmented Generation
   with Fine-grained Knowledge Refinement (IRAGKR). IRAGKR comprises three
   key components: a dynamic retrieval gating module, a query semantic
   expansion module, and a document information compression module.
   Firstly, the dynamic retrieval gating module leverages the LLM's
   self-attention mechanism, entropy calculation, and part-of-speech
   metrics to assess the necessity of retrieving generated answer
   fragments. Secondly, when the retrieval process is triggered, the query
   semantic expansion module formulates retrieval queries tailored to the
   model's information needs based on attention mechanisms and prompt
   instructions to enhance retrieval precision. Finally, the document
   information compression module performs fine-grained knowledge filtering
   on the retrieved documents. IRAGKR is evaluated along with five
   different types of baseline methods on four open-domain
   question-answering datasets. Experimental results demonstrate the
   effectiveness of our method.},
Publisher = {ELSEVIER},
Address = {RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS},
