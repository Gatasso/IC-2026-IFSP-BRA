@inproceedings{ WOS:001690442800073,
Author = {Khan, Tahiyya and Simha, J. B. and Paramesh, G.},
Book-Group-Author = {IEEE},
Title = {Retrieval-Augmented Generation and Language Model for Advanced Product
   Querying},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON ELECTRONICS, COMPUTING AND
   COMMUNICATION TECHNOLOGIES, CONECCT},
Series = {IEEE International Conference on Electronics Computing and Communication
   Technologies},
Year = {2025},
Note = {11th International Conference on Electronics Computing and Communication
   Technologies-CONECCT-Annual, INDIA, JUL 10-13, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Artificial Intelligence (AI) driven chatbot development has advanced
   significantly and is widely adopted to assist sales representatives in
   retrieving product information and streamlining the sales process.
   However, effective customer care remains hindered by the inefficiencies
   and time-consuming nature of manual product data retrieval from sources
   like product brochures, databases, and websites. Sales representatives
   often face delays and inefficiencies when searching through multiple
   data sources for product information. A cohesive and efficient solution
   to provide accurate information from a unified platform is introduced.
   By introducing a centralized and secure chatbot solution, the primary
   objective is to accelerate the sales process by facilitating the quick
   and accurate retrieval of product details. The chatbot utilizes
   sophisticated models like Phi-3 for generating responses and leverages
   Retrieval-Augmented Generation (RAG) to extract relevant product
   information. The HuggingFace BAAI/bge-base-en-v1.5 embeddings model is
   used to index data from product documents. The system is integrated into
   a chatbot interface providing users with a seamless and efficient
   experience. The RAG component efficiently retrieves information from
   indexed sources and Phi-3 ensures the generation of accurate and
   relevant responses. The semantic search metrics show strong results,
   with a precision of 0.8687, recall of 0.9162, and F1 score of 0.8917,
   indicating high accuracy and relevance in information retrieval. This
   solution simplifies the provision of accurate product information,
   improves sales efficiency and customer satisfaction.},
