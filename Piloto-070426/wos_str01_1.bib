@inproceedings{ WOS:001391786802040,
Author = {Yu, Han-Cheng and Shih, Yu-An and Law, Kin-Man and Hsieh, Kai-Yu and
   Cheng, Yu-Chen and Ho, Hsin-Chih and Lin, Zih-An and Hsu, Wen-Chuan and
   Fan, Yao-Chung},
