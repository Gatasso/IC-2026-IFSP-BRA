@inproceedings{ WOS:001691464100014,
Author = {Bourkoukouand, Outhmane and Ghommat, Khadija},
Editor = {Mukund, M and Lahlou, S},
Title = {Plant Diseases Detection with Retrieval-Augmented Generation},
Booktitle = {NETWORKED SYSTEMS, NETYS 2025},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15736},
Pages = {214-229},
Note = {13th International Conference on Networked Systems-NETYS, Rabat,
   MOROCCO, MAY 21-23, 2025},
Organization = {UM6P Ventures; Universite Mohammed V de Rabat Bibliotheque; CID GmbH},
Abstract = {To address the growing challenges of plant diseases and their impact on
   global food security, this study presents an innovative AIdriven
   workflow for disease detection and management. Leveraging the Plant
   Village dataset, our approach combines image classification, information
   retrieval, and response generation to provide actionable insights for
   farmers. The proposed system employs a hybrid VGG16/VGG19 model,
   achieving 96.12\% accuracy in disease identification, alongside a
   fine-tuned BLIP model for symptom captioning. Language models, such as
   Mistral-Small-3.1-24B-Instruct, further enhance response quality,
   demonstrating a Faithfulness score of 0.6085. While the method shows
   robustness. This scalable solution aims to reduce crop losses (estimated
   at 20-40\% annually) and minimize reliance on chemical pesticides,
   supporting sustainable agricultural practices in vulnerable regions.},
