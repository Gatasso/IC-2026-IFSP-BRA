@inproceedings{ WOS:001656858300003,
Author = {Keita, Mamadou and Hamidouche, Wassim and Eutamene, Hessen B.},
Book-Group-Author = {ACM},
Title = {REVEAL: A Retrieval-Augmented Generation Approach for Contextual
   Identification of Synthetic Visual Content},
Booktitle = {PROCEEDINGS OF THE 1ST DEEPFAKE FORENSICS WORKSHOP: DETECTION,
   ATTRIBUTION, RECOGNITION, AND ADVERSARIAL CHALLENGES IN THE ERA OF
   AI-GENERATED MEDIA, DFF 2025},
Year = {2025},
Pages = {12-20},
Note = {1st Deepfake Forensics Workshop-DFF, Dublin, IRELAND, OCT 27-31, 2025},
Organization = {ACM SIGMM},
Abstract = {Detecting AI-generated images remains a major challenge due to the
   limited robustness and generalizability of existing methods, which often
   rely on low-level artifacts or features specific to particular
   generative models. These limitations reduce their effectiveness against
   unknown models or under degraded conditions. To overcome these
   challenges, we propose REVEAL, a new framework based on visual
   retrieval-augmented generation (RAG) and majority voting. REVEAL uses a
   fine-tuned CLIP image encoder to extract a visual representation of a
   query image and dynamically retrieves the.. most similar images from a
   labeled vector database. The final label (real or fake) is determined by
   majority vote among the retrieved images. By leveraging the most
   relevant visual context instead of relying on complex classifiers or
   multimodal fusion, REVEAL achieves strong generalization and robustness.
   Evaluated on the UniversalFakeDetect benchmark, which includes 19
   generative models, REVEAL achieves an average accuracy of 93.90\%,
   outperforming the best existing method, C2P-CLIP. Under degraded
   conditions such as Gaussian blur and JPEG compression, it maintains an
   average accuracy of 80.29\%, significantly higher than C2P-CLIP's
   63.44\%. REVEAL also shows strong cross-domain generalization, achieving
   78.81\% average accuracy on diverse unseen data, confirming its
   effectiveness in open-world scenarios. The code can be publicly accessed
   at https://github.com/Mamadou-Keita/REVEAL.},
