Title = {Company-Specific Knowledge Matters: Retrieval-Augmented Generation for
   Earnings Call Answer Rehearsal},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
Year = {2025},
