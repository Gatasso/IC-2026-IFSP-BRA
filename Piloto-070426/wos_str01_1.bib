@inproceedings{ WOS:001591673900034,
Author = {Ha-Thanh Nguyen and Satoh, Ken},
Editor = {Savelka, J and Harasta, J and Novotna, T and Misek, J},
Title = {ConsRAG: Minimize LLM Hallucinations in the Legal Domain},
Booktitle = {LEGAL KNOWLEDGE AND INFORMATION SYSTEMS, JURIX 2024},
Series = {Frontiers in Artificial Intelligence and Applications},
Year = {2024},
Volume = {395},
Pages = {327-332},
Note = {37th International Conference on Legal Knowledge and Information
   Systems-JURIX, Brno, CZECH REPUBLIC, DEC 11-13, 2024},
Organization = {Masaryk University Brno},
Abstract = {Retrieval-Augmented Generation (RAG) systems have shown potential in
   improving legal question-answering applications. However, they often
   struggle to provide precise information for legal queries, as
   broad-topic relevance may not always align with contextual usefulness.
   To address this challenge, we introduce Constrained Retrieval-Augmented
   Generation (ConsRAG), a novel approach that employs aspect-based
   constraints during both retrieval and generation phases. ConsRAG aims to
   enhance precision and contextual relevance in legal outputs through
   these constraints and an iterative backtracking mechanism. Our
   experiments suggest that ConsRAG may offer improvements over existing
   systems in terms of accuracy and relevance of retrieved documents. This
   paper presents the framework, implementation, and evaluation of ConsRAG,
   exploring its potential to enhance the reliability of legal AI
   applications.},
