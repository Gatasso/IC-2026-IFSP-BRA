Editor = {Wu, X and Spiliopoulou, M and Wang, C and Kumar, V and Cao, L and Wu, Y and Yao, Y and Wu, Z},
Title = {Graph Retrieval-Augmented LLM for Conversational Recommendation Systems},
Booktitle = {ADVANCES IN KNOWLEDGE DISCOVERY AND DATA MINING, PAKDD 2025, PT III},
Series = {Lecture Notes in Artificial Intelligence},
