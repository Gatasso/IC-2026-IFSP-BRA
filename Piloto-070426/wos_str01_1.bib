@inproceedings{ WOS:001576448300037,
Author = {Pinna, Simone and Massa, Silvia Maria and Fenu, Matteo and Casti, Giulio
   and Riboni, Daniele},
Book-Group-Author = {ACM},
Title = {Integration of Retrieval-Augmented Generation Technique for LLM-based
   Differential Diagnosis Assistant},
Booktitle = {PROCEEDINGS OF THE 18TH ACM INTERNATIONAL CONFERENCE ON PERVASIVE
   TECHNOLOGIES RELATED TO ASSISTIVE ENVIRONMENTS, PETRA 2025},
Year = {2025},
Pages = {277-284},
Note = {18th International Conference on Pervasive Technologies Related to
   Assistive Environments-PETRA, Corfu, GREECE, JUN 25-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {Artificial Intelligence (AI) is increasingly transforming the medical
   field, offering significant potential for diagnosis, treatment, and
   patient care. However, its successful integration relies on healthcare
   professionals, such as doctors, psychologists, and nurses, trusting the
   technology's reliability and accuracy. For Large Language Models (LLMs),
   this trust requires transparent, verifiable, and rigorously reviewed
   information sources. This paper presents an AI-powered tool for
   differential diagnosis and disease comparison, utilizing an LLM enhanced
   by Retrieval-Augmented Generation (RAG). RAG overcomes traditional LLM
   limitations by enabling access to external, domain-specific knowledge,
   ensuring accurate and contextually relevant responses. The system
   leverages PubMed, a biomedical article aggregator, to extract
   symptom-related information from scientific literature on various
   disorders. Evaluations involving psychologist-administered
   questionnaires demonstrate that combining a similarity score with
   detailed symptom descriptions provides a clear understanding of
   relationships between disorders. This approach may enhance diagnostic
   precision and build trust in AI-driven tools, encouraging their broader
   adoption in clinical practice.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Pinna, S (Corresponding Author), Univ Cagliari, Dept Math \& Comp Sci, Cagliari, Italy.
   Pinna, Simone; Massa, Silvia Maria; Fenu, Matteo; Casti, Giulio; Riboni, Daniele, Univ Cagliari, Dept Math \& Comp Sci, Cagliari, Italy.},
DOI = {10.1145/3733155.3733192},
ISBN = {979-8-4007-1402-3},
Keywords = {Large Language Models; Retrieval-Augmented Generation; e-Health;
   Differential diagnosis},
