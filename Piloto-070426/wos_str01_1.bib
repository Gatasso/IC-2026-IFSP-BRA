@inproceedings{ WOS:001336908500165,
Author = {Maes, Ulysse and Michiels, Lien and Smets, Annelien},
Book-Group-Author = {ACM},
Title = {GenUI(ne) CRS: UI Elements and Retrieval-Augmented Generation in
   Conversational Recommender Systems with LLMs},
