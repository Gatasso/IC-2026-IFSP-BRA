Author = {Ngandu, Bernard and Mbale, Landry and Bagula, Antoine},
Editor = {Ngatched, TMN and Woungang, I and Tapamo, JR and Viriri, S},
Title = {Juro: A Retrieval-Augmented Generation AI Chatbot for Enhancing Legal
