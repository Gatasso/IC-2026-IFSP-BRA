@inproceedings{ WOS:001697407700216,
Author = {Costachioiu, Teodor and Vaduva, Corina and Faur, Daniela},
Book-Group-Author = {IEEE},
Title = {Large Language Models with Retrieval Augmented Generation to streamline
   Sentinel-2 data Description},
Booktitle = {IGARSS 2025-2025 IEEE INTERNATIONAL GEOSCIENCE AND REMOTE SENSING
   SYMPOSIUM},
Series = {IEEE International Symposium on Geoscience and Remote Sensing IGARSS},
Year = {2025},
