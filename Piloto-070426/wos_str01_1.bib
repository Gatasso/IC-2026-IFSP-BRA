Title = {MulSAFER: A Framework for Extraction and Interpretation of Safe Mobility
   Paths from Multimodal Spatial Data},
Booktitle = {PROCEEDINGS OF THE 4TH ACM SIGSPATIAL INTERNATIONAL WORKSHOP ON
   SEARCHING AND MINING LARGE COLLECTIONS OF GEOSPATIAL DATA, GEOSEARCH
   2025},
Year = {2025},
Pages = {1-8},
Note = {4th International Workshop on Searching and Mining Large Collections of
   Geospatial Data-GEOSEARCH, Minneapolis, MN, NOV 03, 2025},
Organization = {Association for Computing Machinery; Apple Inc; Google Cloud; Esri Co
   Ltd; Oracle Corp; Springer Nature; NSF International},
Abstract = {Current route searching systems prioritize efficiency over safety,
   exposing users to preventable hazards through outdated static data and
   opaque decision-making. We present MulSAFER, a multimodal safety-aware
   routing framework addressing these limitations through three
   innovations: real-time risk mapping from user-uploaded dashcam footage
   as Volunteered Geographic Information (VGI), fusion of accident records,
   traffic news, and visual data via semantic retrieval, and interpretable
   route explanations generated by Retrieval-Augmented Generation (RAG).
   The system processes real-time visual data to detect illegal parking
   while providing contextual explanations grounded in historical patterns.
   Results demonstrate that MulSAFER effectively balances route efficiency
   and safety, delivering transparent, data-driven guidance that adapts to
   dynamic urban conditions.},
