Editor = {Shahriar, H and Alam, KS and Ohsaki, H and Cimato, S and Capretz, M and Ahmed, S and Ahamed, SI and Majumder, AKMJA and Haque, M and Yoshihisa, T and Cuzzocrea, A and Takemoto, M and Sakib, N and Elsayed, M},
Title = {Personalized Mental Health Assistance with Large Language Models},
