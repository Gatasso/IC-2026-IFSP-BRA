@inproceedings{ WOS:001667438200003,
Author = {Palomino, Alonso and Buschhueter, David and Roller, Roland and Pinkwart,
   Niels and Paassen, Benjamin},
Editor = {Zhang, Y and Chen, C and Li, S and Geva, M and Han, C and Wang, X and Feng, S and Gao, S and Augenstein, I and Bansal, M and Li, M and Ji, H},
Title = {EdTec-ItemGen: Enhancing Retrieval-Augmented Item Generation Through Key
   Point Extraction},
