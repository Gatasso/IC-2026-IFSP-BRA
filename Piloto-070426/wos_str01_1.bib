Note = {2025 International Conference on Information Reuse and Integration for
   Data Science-IRI, San Jose, CA, AUG 06-08, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This study explores the integration of a domain-specific knowledge graph
   (KG) into a Retrieval-Augmented Generation (RAG) pipeline to improve the
   retrieval of medical information. We constructed a knowledge graph from
   unstructured diabetes-related text. Two experimental setups were
   compared: a standard RAG model using raw text retrieval, and a
   graph-ehanced RAG model that retrieves information based on the
   structured graph queries. Results indicate that incorporating the
   knowledge graph significantly improved the retrieval process by getting
   more in-depth information from graph.},
