@article{ WOS:001696415800001,
Author = {Song, Zhipeng and Kong, Xiangyu and Bao, Xinrui and Zhou, Yizhi and
   Jiao, Jiulong and Liu, Sitong and Zhou, Yuhang and Qi, Heng},
Title = {LLM-confidence reranker: A training-free approach for enhancing
   retrieval-augmented generation systems},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {314},
Month = {JUN 5},
Abstract = {Retrieval-augmented generation (RAG) improves factuality by grounding
   large language models (LLMs) on external documents, but its reliability
   strongly depends on ranking quality. Existing rerankers often require
   task-specific training or proprietary models, and may still be
   suboptimal under zero-shot settings. We introduce LLM-Confidence
   Reranker (LCR), a training-free and black-box reranking layer that
   exploits an LLM's confidence signal as a proxy for document helpfulness.
   The key idea is that helpful evidence leads to more consistent model
   answers across stochastic generations, while unhelpful evidence
   increases semantic variability. LCR leverages this signal to refine
   candidate rankings in a plug-and-play manner and can be applied
   standalone or on top of existing rerankers. Experiments on BEIR and TREC
   with both BM25 and Contriever, across pretrained LLM-based and
   fine-tuned neural rerankers, show consistent NDCG@5 gains with no
   observed degradation, achieving up to 20.6\% relative improvement using
   lightweight 7-9B LLMs. LCR also provides practical efficiency knobs to
   balance effectiveness and cost, making it suitable for real-world RAG
   deployments.},
