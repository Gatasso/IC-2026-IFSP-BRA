@article{ WOS:001458438100001,
Author = {Ren, Tengfei and Zhang, Zhipeng and Jia, Bo and Zhang, Shiwen},
Title = {Retrieval-Augmented Generation-aided causal identification of aviation
   accidents: A large language model methodology},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {278},
Month = {JUN 10},
Abstract = {Identification and assessment of key information within historical
   aviation accident reports are essential for preventing future accidents.
   However, manual causation extraction of key details is a labor-intensive
   and inefficient process due to the unstructured or semi-structured
   format of reports. To narrow these gaps, this paper proposes a
   Retrieval-Augmented Generation (RAG)-aided Causal Identification (RACI)
   model combining the Large Language Model approach. This novel model
   comprises a retrieval module and a generation module. Leveraging the
   real-world aviation reports published by the National Transportation
   Safety Board (NTSB), the proposed model demonstrates a substantial
   improvement in both retrieval accuracy and robustness. Specifically, the
   RACI method achieves a mean Average Precision (mAP) of 0.815 and a
   maximum mean Normalized Discounted Cumulative Gain (mNDCG) of 0.761.
   This study further examines the influence of various prompt designs on
   the reason localization performance of RACI. With the enhancement of RAG
   and noise filter method, RACI shows great robustness to noisy inputs.
   This highlights RACI's potential applicability in assisting the experts
   with causation identification. The experiment results demonstrate that
   RACI can serve as an efficient expert system to enhance decision making
   and risk management in aviation safety.},
