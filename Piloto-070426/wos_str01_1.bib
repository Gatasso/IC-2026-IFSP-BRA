@article{ WOS:001714861800001,
Author = {Fang, Chengyang and Li, Jian and Xie, Yilong and Jiang, Wenhui and Zeng,
   Gangyan and Li, Zhixuan and Fang, Yuming},
Title = {Retrieval Augmented video captioning with quality-aware re-ranking and
   cross-gating fusion},
Journal = {DISPLAYS},
Year = {2026},
Volume = {93},
Month = {JUL},
Abstract = {Video captioning aims to generate natural language descriptions for
   video content, yet remains challenging due to the significant gap
   between visual and linguistic modalities. Most existing methods rely on
   spatiotemporal visual features but often fail to fully capture all
   visual and syntactic information in annotated video-caption pairs,
   resulting in unnatural and less human-like descriptions. Recently,
   Retrieval-Augmented Generation methods have introduced external
   knowledge to improve video captioning performance. However, retrieved
   captions are often noisy and inconsistent due to over-reliance on visual
   similarity, which may inversely impair caption quality. Furthermore,
   existing retrieval-augmented approaches primarily rely on text-only
   retrieval, overlooking the complementary value of the video modality. To
   address these limitations, we introduce two core modules: a
   quality-aware re-ranking module that ensures the retrieved textual
   captions are of high linguistic quality, and a cross-gating fusion
   module that aggregates and filters the retrieved video features. With
   these two modules, our method can process the retrieved video features
   and combine them with the high-quality captions to form effective
   multi-modal contextual examples. These examples are then formatted into
   a structured prompt, allowing the model to refer to high-quality
   video-text examples during the caption generation, which help to
   generate more accurate, fluent, and contextually appropriate captions.
   Experimental results show that our model achieves state-of-the-art
   methods on MSR-VTT and MSVD.},
