Editor = {Qian, Y and Jin, Q and Ou, Z and Ling, Z and Wu, Z and Li, Y and Xie, L and Tao, J},
Title = {An Empirical Study of Retrieval Augmented Generation with
   Chain-of-Thought},
Booktitle = {2024 IEEE 14TH INTERNATIONAL SYMPOSIUM ON CHINESE SPOKEN LANGUAGE
   PROCESSING, ISCSLP 2024},
