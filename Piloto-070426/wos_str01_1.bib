@inproceedings{ WOS:001661529600044,
Author = {Guzzi, Pietro Hiram and Defilippo, Annamaria and Procopio, Nicola and
   Trapuzzano, Albino and Canino, Giovanni and Vizza, Patrizia and
   Sorrentino, Sabato and Indolfi, Ciro and Veltri, Pierangelo},
