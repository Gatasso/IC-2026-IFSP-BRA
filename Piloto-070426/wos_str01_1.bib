@inproceedings{ WOS:001704661700063,
Author = {Zhou, Xuewen and Li, Zhuowei and Jiang, Rong and Xu, Chaojun and Shao,
   Chengcheng},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {A Method for Improving Retrieval Effectiveness in RAG},
Booktitle = {2025 IEEE 10TH INTERNATIONAL CONFERENCE ON DATA SCIENCE IN CYBERSPACE,
   DSC},
Year = {2025},
Pages = {501-507},
Note = {10th International Conference on Data Science in Cyberspace-DSC,
   Baoding, PEOPLES R CHINA, AUG 15-17, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {To address the performance fluctuation issues in Retrieval-Augmented
   Generation (RAG) frameworks, this paper proposes a collaborative
   optimization method integrating hybrid retrieval, grid search parameter
   optimization, and recursive hierarchical retrieval. The method
   dynamically adjusts weights to balance contributions from keyword-based
   sparse retrieval (BM25) and semantic dense retrieval (DPR). Combined
   with grid search for global optimization of hybrid weights, it
   significantly improves text recall across diverse query scenarios.
   Furthermore, a recursive retrieval strategy is introduced to enhance
   coverage of long-tail knowledge and complex structured documents through
   multi-granularity parsing and progressive retrieval augmentation.
   Experimental results on the Amnesty\_qa dataset demonstrate that hybrid
   retrieval achieves over 20\% recall improvement compared to single dense
   retrieval, while recursive retrieval boosts precision by 4.61\%,
   validating the effectiveness of the proposed approach.},
