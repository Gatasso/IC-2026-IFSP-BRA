@inproceedings{ WOS:001706337700608,
Author = {Luo, Yani},
Book-Group-Author = {IEEE},
Title = {KairosRAG: Enhancing On-Demand Retrieval and Filtering with Lightweight
   Adapters},
Booktitle = {2025 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS, IJCNN},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2025},
Note = {2025 International Joint Conference on Neural Networks-IJCNN, Rome,
   ITALY, JUN 30-JUL 05, 2025},
Organization = {PONTIFICAL GREGORIAN UNIVERSITY; International Neural Network Society;
   Institute of Electrical and Electronics Engineers Inc; IEEE
   Computational Intelligence Society; Sapienza University Rome; Intesa
   Sanpaolo Bank; IEEE Power and Energy Society},
Abstract = {Retrieval-augmented generation has become a crucial approach for
   enhancing the accuracy and reliability of large language models (LLMs).
   However, existing reflection-based methods face significant efficiency
   challenges, requiring nearly double the generation time and substantial
   computational resources for training. To address these limitations, we
   propose KairosRAG, a lightweight and efficient framework for reflection
   retrieval-augmented generation. KairosRAG introduces two key
   innovations: a retrieval adapter that dynamically determines when
   retrieval is necessary at each generation point, and a score adapter
   that efficiently filters out irrelevant documents. Both adapters are
   implemented using simple multiple linear layers, making them
   plug-and-play components that are significantly easier to train and
   integrate compared to existing approaches.
   Our comprehensive evaluation demonstrates that KairosRAG achieves
   state-of-the-art performance across multiple benchmarks. Compared to
   Self-RAG, the framework reduces generation time by 39.3\%-42.6\% (x1.75
   vs x3.05 for 7B models) while improving accuracy on knowledge-intensive
   tasks like PopQA (+1.6\% absolute improvement for 7B) and TriviaQA
   (+2.7\% for 13B). Notably, KairosRAG 13B achieves new SOTA results on
   ASQA with 35.0 EM and 39.0 ROUGE scores, outperforming all baseline
   methods by 3.3\%-19.8\% across evaluation metrics. The lightweight
   adapters require only 0.02\% additional parameters compared to base
   LLMs, establishing KairosRAG as a breakthrough in efficient and accurate
   retrieval-augmented generation.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
