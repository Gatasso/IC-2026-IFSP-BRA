@article{ WOS:001506299000003,
Author = {Kang, Xinhui and You, Wenjie and Luo, Ying},
Title = {Bio-inspired product design system integrating retrieval-augmented
   question answering and semantic fusion diffusion model},
Journal = {ADVANCED ENGINEERING INFORMATICS},
Year = {2025},
Volume = {67},
Month = {SEP},
Abstract = {Bio-inspired Design (BID) drives design innovation by leveraging natural
   communications, forms and structures, offering significant advantages in
   enhancing product performance and inspiring creativity. However, despite
   its potential, BID faces two critical challenges: (1) difficulties in
   accurately and efficiently matching suitable biological sources, and (2)
   inefficiencies in traditional BID workflows, which hinder rapid
   iteration to meet market demands. To address these issues, this study
   proposes a BID system integrating a Retrieval-Augmented Generation (RAG)
   framework and a Semantic Fusion Diffusion Model (SFDM). The system first
   optimizes the LLaMA 2-7B large language model with RAG architecture,
   trained on 12,670 BID-related articles and 15,500 user Q\&A pairs, to
   develop BionicGPT, a domain-specific intelligent Q\&A model. Users input
   design requirements via an interactive interface to efficiently obtain
   recommended biological sources. Subsequently, biological images and
   design requirements are fed into SFDM to generate diverse, high-quality
   BID solutions rapidly. A case study on furniture design produced six
   bio-inspired sofa chairs, which were prioritized through Fuzzy TOPSIS
   for user satisfaction. The optimal design underwent functional
   simulation using JACK software. This framework reduces reliance on
   designer experience, enhances efficiency, shortens product development
   cycles, and establishes a cross-disciplinary BID platform for
   innovation.},
