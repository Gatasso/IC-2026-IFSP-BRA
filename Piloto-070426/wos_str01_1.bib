@inproceedings{ WOS:001661448300469,
Author = {Han, Donghee and Lim, Seungjae and Yi, Mun Yong},
Book-Group-Author = {ACM},
Title = {RAG-based Unanswerable Question Detection in Clinical Text-to-SQL},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
Year = {2025},
Pages = {4759-4764},
Note = {34th Conference on Information and Knowledge Management-CIKM, SOUTH
   KOREA, NOV 10-14, 2025},
Organization = {Association for Computing Machinery; The ACM Special Interest Group on
   Hypertext and the Web; ACM Special Interest Group on Information
   Retrieval; Korea Tourism Organization; Seoul Metropolitan Government},
Abstract = {Large-scale language models (LLMs) have shown exceptional performance in
   various tasks, particularly in zero-shot and few-shot settings. However,
   in sensitive domains like healthcare, detecting unanswerable questions
   remains a critical challenge. This task is challenging due to data
   imbalance, and existing methods are computationally expensive and
   inflexible to data distribution changes. To address these issues, we
   propose Retrieval-augmented Question Answerability Detection (RaQAD), a
   training-free method that uses LLMs to identify unanswerable questions
   by retrieving semantically similar examples as few-shot prompts. RaQAD
   ensures semantically similar sampling, adapts to schema changes, and
   eliminates the need for additional training. Extensive experiments on
   clinical datasets demonstrate its effectiveness in outperforming
   existing approaches while addressing data imbalance challenges.},
