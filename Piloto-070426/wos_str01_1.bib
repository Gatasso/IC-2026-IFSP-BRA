@article{ WOS:001651948400006,
Author = {Lin, Hsin-Yi and Chang, Yu-Che and Chien, Jen-Tzung},
Title = {Variational Dehallucination via Retrieval-Augmented Prompt Learning},
Journal = {IEEE TRANSACTIONS ON AUDIO SPEECH AND LANGUAGE PROCESSING},
Year = {2026},
Volume = {34},
Pages = {259-271},
Abstract = {Large language models (LLMs) are powerful but prone to hallucination,
   generating fluent yet factually incorrect responses. Existing approaches
   such as prompt learning and retrieval-augmented generation (RAG) offer
   partial remedies in a condition that prompt learning adapts model
   behavior but often lacks contextual specificity while RAG improves
   factual grounding but treats retrieval deterministically and lacks
   prompt optimization. To address these gaps, we propose a variational
   dehallucination framework that unifies RAG with prompt learning through
   variational inference. By modeling prompts as latent variables, a
   posterior prompt encoder is learned with the condition on both questions
   and answers, and is aligned with a prior encoder to enable robust
   inference without labels. To further suppress the hallucination, a
   mutual information loss is incorporated to be minimized to disentangle
   the hidden-state features due to the prompt signals from top-k and
   bottom k retrieved examples. Experiments on Natural Questions, TriviaQA,
   and ASQA show that the proposed method significantly improves accuracy,
   semantic relevance, and consistency over strong prompting and retrieval
   baselines. This demonstrates the value of combining probabilistic prompt
   modeling with retrieval scheme to generate factual and reliable LLM
   outputs.},
Publisher = {IEEE-INST ELECTRICAL ELECTRONICS ENGINEERS INC},
Address = {445 HOES LANE, PISCATAWAY, NJ 08855-4141 USA},
