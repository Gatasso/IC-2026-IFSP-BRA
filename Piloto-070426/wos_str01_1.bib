   Belal and Mezei, Kitti and Varga, Pal and Tauber, Markus},
Editor = {Zuckerman, D and Ulema, M and Limam, N and Kim, YT and Granville, LZ and Fulber-Garcia, V},
Title = {Let's have a Chat with the EU AI Act},
Booktitle = {NOMS 2025-2025 IEEE NETWORK OPERATIONS AND MANAGEMENT SYMPOSIUM},
Series = {IEEE IFIP Network Operations and Management Symposium},
Year = {2025},
Note = {2025 Network Operations and Management Symposium-NOMS, Honolulu, HI, MAY
   12-16, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {As artificial intelligence (AI) regulations evolve and the regulatory
   landscape develops and becomes be more complex, ensuring compliance with
   ethical guidelines and legal frameworks remains a challenge for AI
   developers. This paper introduces an AI-driven self-assessment chatbot
   designed to assist users in navigating the European Union AI Act and
   related standards. Leveraging a Retrieval-Augmented Generation (RAG)
   framework, the chatbot enables real-time, context-aware compliance
   verification by retrieving relevant regulatory texts and providing
   tailored guidance. By integrating both public and proprietary standards,
   it streamlines regulatory adherence, reduces complexity, and fosters
   responsible AI development. The paper explores the chatbot's
   architecture, comparing naive and graph-based RAG models, and discusses
   its potential impact on AI governance.},
