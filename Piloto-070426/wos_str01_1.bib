Note = {2025 International Geoscience and Remote Sensing
   Symposium-IGARSS-Annual, Brisbane, AUSTRALIA, AUG 03-08, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {In this paper, we introduce a novel methodology for interpreting the
   content of Sentinel-2 multispectral imagery by leveraging a combination
   of spectral indices, Retrieval-Augmented Generation (RAG), and
   context-aware prompting strategies. Specifically, we calculate spectral
   indices at the patch level to enhance the representation of image
   content and integrate this information with the Mistral Small 3.1 large
   language model (LLM) to generate interpretable context-aware analyses.
   Our approach aims to bridge the gap between remote sensing expertise and
   the reasoning capabilities of LLMs. Importantly, the proposed framework
   is lightweight and does not require finetuning, making it suitable for
   real-world use cases on modest hardware; all experiments were conducted
   on a consumer-grade PC with a 24GB VRAM GPU.},
