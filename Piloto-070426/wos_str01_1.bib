Book-Group-Author = {IEEE COMPUTER SOC},
Title = {LAKE-RED: Camouflaged Images Generation by Latent Background Knowledge
   Retrieval-Augmented Diffusion},
Booktitle = {2024 IEEE/CVF CONFERENCE ON COMPUTER VISION AND PATTERN RECOGNITION,
