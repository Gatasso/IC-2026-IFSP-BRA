@inproceedings{ WOS:001699548500057,
Author = {Betancur-Vasquez, D. and Hoyos-Giraldo, Nicolas and Hander Mejia-Munoz,
   Jhon and Felipe Giraldo-Forero, Andres},
Book-Group-Author = {IEEE},
Title = {Evaluating Retrieval-Augmented Generation Architectures for Clinical
   Guideline Question Answering: A Case Study in Obstetrics},
Booktitle = {2025 12TH INTERNATIONAL CONFERENCE ON SOFT COMPUTING \& MACHINE
   INTELLIGENCE, ISCMI},
Series = {International Conference on Soft Computing \& Machine Intelligence ISCMI},
Year = {2025},
Pages = {305-309},
Note = {12th International Conference on Soft Computing and Machine
   Intelligence-ISCMI-Annual, Rio de Janeiro, BRAZIL, NOV 21-23, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Maternal complications remain an important public health challenge,
   highlighting the need for effective mechanisms to support the
   consultation and application of clinical guidelines. Large Language
   Models (LLMs) have shown transformative potential in this area, yet
   their reliability decreases when handling domain-specific queries.
   Retrieval-Augmented Generation (RAG) offers a promising strategy by
   establishing responses in authoritative evidence. In this work, we
   compare four RAG architectures: Simple Semantic, Hybrid, HyDE, and Query
   Rewriting. Applied to ten questions related to obstetrics extracted from
   an official clinical guideline. The evaluation employed four OpenAI
   models and was conducted using the RAGAS framework. The results show
   that HyDE achieved the highest faithfulness scores, significantly
   reducing hallucinations, while Query Rewriting maximized response
   relevancy and context recall. Simple Semantic and HyDE provided greater
   context precision, whereas Hybrid introduced noise due to lexical
   matches. Notably, the nano models combined with HyDE delivered
   competitive results at lower computational cost. These findings suggest
   that HyDE is the most suitable configuration for clinical contexts
   requiring reliability, while Query Rewriting is advantageous for broader
   or ambiguous queries that require evidence coverage.},
