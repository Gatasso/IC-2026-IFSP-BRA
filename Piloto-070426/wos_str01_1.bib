@inproceedings{ WOS:001551103900009,
Author = {Ding, Shiyao and Ito, Takayuki},
Editor = {Mathieu, P and DeLaPrieta, F},
Title = {MineLlama: Llama with Retrieval-Augmented Generation as A Decision Maker
   in Minecraft},
Booktitle = {ADVANCES IN PRACTICAL APPLICATIONS OF AGENTS, MULTI-AGENT SYSTEMS, AND
   DIGITAL TWINS: THE PAAMS COLLECTION, PAAMS 2024},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15157},
Pages = {97-108},
Note = {22nd International Conference on Practical Applications of Agents and
   Multi Agent Systems-PAAMS, Salamanca, SPAIN, JUN 26-28, 2024},
Organization = {University of Salamanca BISITE Research Group},
Abstract = {This paper introduces MineLlama, a lightweight framework that utilizes a
   localized large language model, Llama, to enhance decision-making in the
   sandbox game Minecraft, without relying on external APIs. MineLlama
   operates a two-layer framework, consisting of planning and executing
   modules. In the planning module, MineLlama employs a retrieval-augmented
   generation (RAG) paired with a query engine that utilizes recipe
   information from Minecraft to decompose a final goal into a series of
   interdependent subgoals. In the executing module, MineLlama is also
   constructed using a RAG, with a query engine informed by general
   knowledge of Minecraft, to guide the agent in choosing the appropriate
   actions. The framework's efficiency is demonstrated through evaluations
   on 7 diverse Minecraft tasks, showcasing its ability to guide agents in
   achieving specific goals. We upload all the contents including code and
   videos to: https://minecraftagents.github.io/MineLlama\_hp/.},
