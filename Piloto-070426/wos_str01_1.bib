@inproceedings{ WOS:001604686000012,
Author = {Chang, Chen-Chi and Li, Chong-Fu and Lee, Chu-Hsuan and Lee, Hung-Shin},
Editor = {Arai, K},
Title = {Enhancing Low-Resource Minority Language Translation with LLMs and
   Retrieval-Augmented Generation for Cultural Nuances},
