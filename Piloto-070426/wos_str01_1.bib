@article{ WOS:001607022200002,
Author = {Le, Van The and Malik, Muhammad Shahid and Ou, Yu-Yen},
Title = {DEEPTRANS: Enhancing primary active transport protein prediction via
   RAG-augmented protein language models and multi-scale deep learning},
Journal = {CHEMICAL PHYSICS LETTERS},
Year = {2026},
Volume = {882},
Month = {JAN},
Abstract = {DEEPTRANS is a deep learning framework for accurate classification of
   primary active transport (PAT) proteins using sequence data. It combines
   ProtT5 embeddings with contextual knowledge retrieved from the
   Transporter Classification Database (TCDB) via a Retrieval-Augmented
   Generation (RAG) approach. A Multi-Scale CNN captures both local and
   long-range sequence patterns. DEEPTRANS achieves state-of-the-art
   performance with 94.78 \% and 93.06 \% mean accuracy on two independent
   datasets, and and gains 90 \% accuracy on new PDBbased PAT and non-PAT
   proteins. This method enhances protein function annotation, supporting
   research in drug discovery and precision medicine.},
