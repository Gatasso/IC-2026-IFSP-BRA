@inproceedings{ WOS:001181086805036,
Author = {Wang, Rui and Bao, Jianzhu and Mi, Fei and Chen, Yi and Wang, Hongru and
   Wang, Yasheng and Li, Yitong and Shang, Lifeng and Wong, Kam-Fai and Xu,
   Ruifeng},
