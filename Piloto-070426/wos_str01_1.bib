Editor = {Celebi, ME and Muller, JP and Barata, C and Halpern, A and Breininger, K and Lindholz, M and Hutter, J and Ruppel, R and Tripathy, S and Mathis-Ullrich, F and Burghaus, S and May, M},
Title = {Retrieval-Augmented VLMs for Multimodal Melanoma Diagnosis},
Booktitle = {SKIN IMAGE ANALYSIS, AND COMPUTER-AIDED PELVIC IMAGING FOR FEMALE
   HEALTH, ISIC 2025, CAPI 2025},
Series = {Lecture Notes in Computer Science},
