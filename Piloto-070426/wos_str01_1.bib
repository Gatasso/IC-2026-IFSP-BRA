Language = {English},
Affiliation = {Chu, SW (Corresponding Author), Anhui Univ, Sch Elect \& Informat Engn, Hefei, Peoples R China.
   Liu, Jie, iFLYTEK Co Ltd, Hefei, Peoples R China.
   Chu, Shiwei, Anhui Univ, Sch Elect \& Informat Engn, Hefei, Peoples R China.},
