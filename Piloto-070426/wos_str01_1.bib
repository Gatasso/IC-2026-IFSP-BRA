Title = {Legal Retrieval Augmented Generation with Structured Retrieval and
   Iterative Refinement},
Booktitle = {2025 22ND ANNUAL INTERNATIONAL CONFERENCE ON PRIVACY, SECURITY, AND
   TRUST, PST},
Series = {Annual Conference on Privacy Security and Trust-PST},
