@inproceedings{ WOS:001511618600100,
Author = {Stolfo, Alessandro},
Editor = {Duh, K and Gomez, H and Bethard, S},
Title = {Groundedness in Retrieval-augmented Long-form Generation: An Empirical
   Study},
Booktitle = {FINDINGS OF THE ASSOCIATION FOR COMPUTATIONAL LINGUISTICS: NAACL 2024},
Year = {2024},
Pages = {1537-1552},
Note = {2024 Conference of the North American Chapter of the Association for
   Computational Linguistics-NAACL, MEXICO, JUN 16-21, 2024},
Abstract = {We present an empirical study of groundedness in long-form question
   answering (LFQA) by retrieval-augmented large language models (LLMs). In
   particular, we evaluate whether every generated sentence is grounded in
   the retrieved documents or the model's pre-training data. Across 3
   datasets and 4 model families, our findings reveal that a significant
   fraction of generated sentences are consistently ungrounded, even when
   those sentences contain correct ground-truth answers. Additionally, we
   examine the impacts of factors such as model size, decoding strategy,
   and instruction tuning on groundedness. Our results show that while
   larger models tend to ground their outputs more effectively, a
   significant portion of correct answers remains compromised by
   hallucinations. This study provides novel insights into the groundedness
   challenges in LFQA and underscores the necessity for more robust
   mechanisms in LLMs to mitigate the generation of ungrounded content.},
