@inproceedings{ WOS:001553213900019,
Author = {Chen, Zikang and Wang, Qinchuan and Liu, Jinyan and Sun, Yaoqian and
   Zheng, Heming and Li, Haomin and Duan, Huilong and Lu, Xudong},
