@article{ WOS:001708023600001,
Author = {Wang, Ruiwen and Liu, Jihong and Xie, Yanling and Yu, Kai and Song,
   Ziming},
Title = {Facilitating police equipment design via retrieval-augmented generation
   with knowledge graphs and small language models},
Journal = {JOURNAL OF ENGINEERING DESIGN},
Year = {2026},
Month = {2026 MAR 6},
Abstract = {To address the challenges of incomplete knowledge acquisition and
   lagging technological iteration in police equipment design, this paper
   proposes a Retrieval-Augmented Generation (RAG) framework integrating
   Patent Knowledge Graphs (PKG) and Small Language Models (SLM). First, to
   construct a structured PKG from unstructured texts, we introduce the
   Semantic Feature and Dependency Relation Fusion Network (SDF-net). By
   fusing BERT-based semantic features with dependency relations extracted
   via Graph Attention Networks (GAT), SDF-net achieves efficient
   extraction of entities and relations from patent texts. Second, we
   propose a PKG-RAG method to enhance intelligent question answering. This
   method utilises multi-hop PKG retrieval to constrain the SLM in
   generating preliminary answers, employing a recall-filtering mechanism
   to screen high-quality patent segments. This approach expands the
   semantic space, effectively resolving the issue of incomplete recall in
   vague design queries. Experimental results demonstrate that SDF-net
   achieves an F1 score of 81.28\% in extraction tasks. Furthermore, the
   PKG-RAG method outperforms baseline models in multiple dimensions
   including innovativeness, relevance, practicality and feasibility,
   verifying the effectiveness of the knowledge graph-enhanced retrieval
   strategy.},
