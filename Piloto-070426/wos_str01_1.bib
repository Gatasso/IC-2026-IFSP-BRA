Language = {English},
DOI = {10.1109/UEMCON62879.2024.10754778},
ISBN = {979-8-3315-4091-3; 979-8-3315-4090-6},
Keywords = {Artificial Intelligence(AI); Knowledge Graph(KG); Large Language
   Models(LLM); LLM Fine-tuning; Contextual Information Extraction \&
   Retrieval Systems},
Research-Areas = {Computer Science; Engineering; Telecommunications},
