Title = {Multimodal Retrieval Augmented Generation Evaluation Benchmark},
Booktitle = {2024 IEEE 99TH VEHICULAR TECHNOLOGY CONFERENCE, VTC2024-SPRING},
Series = {IEEE Vehicular Technology Conference VTC},
