@inproceedings{ WOS:001443158500099,
Author = {Chen, Wei and Zhou, Mingji and Fan, Xinyi and Zhou, Lu and Zhu, Senliang
   and Cai, Tianyang},
Book-Group-Author = {IEEE},
Title = {Application of Retrieval-Augmented Generation in video},
Booktitle = {2024 12TH INTERNATIONAL CONFERENCE ON INFORMATION SYSTEMS AND COMPUTING
   TECHNOLOGY, ISCTECH},
Year = {2024},
Note = {12th International Conference on Information Systems and Computing
   Technology, Changsha University of Science and Technology, Xi'an,
   PEOPLES R CHINA, NOV 08-11, 2024},
Abstract = {The application of Retrieval-Augmented Generation (RAG) technology in
   the field of text has become increasingly mature. This paper
   innovatively proposes a new method for applying RAG technology to video
   retrieval. The method abandons the traditional retrieval method based on
   video frame descriptions, which often tends to break the context of the
   video. This paper proposes a context-aware dynamic fragmenting strategy
   that can intelligently adjust the fragmenting threshold according to the
   complexity and amount of information in the video content. In addition,
   to maximize the preservation of video information and by utilizing QKD
   (Quantum Key Distribution) quantum encryption technology, this method
   also performs multimodal feature extraction on video fragments,
   including audio, visual, and text dimensions, ensuring that the loss of
   information is minimized and data security.},
