@inproceedings{ WOS:001527543600179,
Author = {Lee, Hsiu-Hung and Chen, Chung-Chi and Yen, An-Zi},
Book-Group-Author = {ACM},
Title = {RAG-Enhanced Evidence Recommendation in Financial Legal Resolutions},
Booktitle = {COMPANION PROCEEDINGS OF THE ACM WEB CONFERENCE 2025, WWW COMPANION 2025},
Year = {2025},
Pages = {1096-1099},
Note = {2025 Web Conference-WWW, Sydney, AUSTRALIA, APR 28-MAY 02, 2025},
Organization = {The ACM Special Interest Group on Hypertext and the Web},
Abstract = {The complexity of legal documents, particularly in financial legal
   disputes, poses significant challenges for both experts and automated
   systems. This study introduces a system leveraging Large Language Models
   (LLMs) and Retrieval-Augmented Generation (RAG) technology to recommend
   key evidence in financial advisor dispute cases. Unlike traditional
   legal AI tasks focused on outcome prediction, our approach emphasizes
   supporting judicial reasoning by recommending key evidence relevant to
   adjudication. We constructed a dataset of 371 annotated cases from
   Taiwan, spanning 25 years, including claims, judicial opinions, and
   final judgments, with annotations highlighting key evidence. Using RAG,
   our system retrieves and generates evidence recommendations grounded in
   analogous past cases while maintaining temporal and contextual
   consistency. This methodology enhances judicial efficiency and supports
   equitable legal decision-making by streamlining the recommendation of
   critical evidence.},
