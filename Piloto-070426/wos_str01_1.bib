@inproceedings{ WOS:001551103900018,
Author = {Oliveira, Francisco and Gomes, Luis and Vale, Zita},
Editor = {Mathieu, P and DeLaPrieta, F},
Title = {Retrieval-Augmented Generation Powered by a Multi-agent System to
   Assisted the Operation of Industries},
Booktitle = {ADVANCES IN PRACTICAL APPLICATIONS OF AGENTS, MULTI-AGENT SYSTEMS, AND
   DIGITAL TWINS: THE PAAMS COLLECTION, PAAMS 2024},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15157},
Pages = {208-216},
Note = {22nd International Conference on Practical Applications of Agents and
   Multi Agent Systems-PAAMS, Salamanca, SPAIN, JUN 26-28, 2024},
Organization = {University of Salamanca BISITE Research Group},
Abstract = {The introduction of large language models in recent years transformed
   the use of artificial intelligence in our daily life, making it
   available to common users and allowing them to interact with natural
   language processing machines. However, the common and general knowledge
   of large language models is not reliable when it comes to the quality of
   the response and its veracity. The proposed work integrates the use of
   retrieval-augmented generation with large language models with a
   multi-agent system framework to enable the creation of trees of
   knowledge where multiple agents have domain specific knowledge. The
   proposed agent-based solution was tested in a realistic case study where
   multiple knowledge domains are distributed amongst six different agents.
   The case study evaluates the capacity of agents to delegate questions
   according to its topics and the capacity of correctly replying to
   questions. The results are promising, demonstrating the ability of large
   language models to assess and process information that wasn't used in
