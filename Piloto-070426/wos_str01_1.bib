Organization = {National Security Agency},
Abstract = {Generative artificial intelligence (AI) promises to revolutionize
   education and knowledge transfer. Educational paradigms are shifting as
   more AI-enabled tools flood the market. Combatting the common risks of
   hallucinations, outdated knowledge, and untraceable decision making are
   retrieval-augmented generation (RAG) models' promises. AI-assisted tools
   for education in both academia and industry have the potential of
   utilizing information retrieval methods like RAG for increasing
   knowledge transfer while increasing trust in the system. The paper
   describes the ``state of the art{''} in AI progress towards educational
   assistants and how current trends can help (or hinder) knowledge
