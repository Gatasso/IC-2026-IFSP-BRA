@inproceedings{ WOS:001547213200010,
Author = {Alam, Hasan Md Tusfiqur and Srivastav, Devansh and Selim, Abdulrahman
   Mohamed and Kadir, Md Abdul and Shuvo, Md Moktadirul Hoque and Sonntag,
   Daniel},
Book-Group-Author = {ACM},
Title = {CBM-RAG: Demonstrating Enhanced Interpretability in Radiology Report
   Generation with Multi-Agent RAG and Concept Bottleneck Models},
Booktitle = {COMPANION OF THE 2025 ACM SIGCHI SYMPOSIUM ON ENGINEERING INTERACTIVE
   COMPUTING SYSTEMS, EICS 2025 COMPANION},
Year = {2025},
