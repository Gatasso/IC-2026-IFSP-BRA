@article{ WOS:001681003200011,
Author = {Tran, Nguyen Phuc and Jaumard, Brigitte and Delgado, Oscar and Glatard,
   Tristan and Premkumar, Karthikeyan and Ni, Kun},
Title = {LLM-Augmented Knowledge Base Construction for Root Cause Analysis},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {16802-16816},
Abstract = {Communications networks now form the backbone of our digital world, with
   fast and reliable connectivity. However, even with appropriate
   redundancy and failover mechanisms, it is difficult to guarantee ``five
   9s{''} (99.999\%) reliability, requiring rapid and accurate root cause
   analysis (RCA) during outages. In the event of an outage, rapid and
   accurate RCA becomes essential to restore service and prevent future
   disruptions. This study evaluates three Large Language Model (LLM)
   methodologies - Fine-Tuning, RAG, and a Hybrid approach - for
   constructing a Root Cause Analysis (RCA) Knowledge Base from support
   tickets. We compare their performance using a comprehensive suite of
   lexical and semantic similarity metrics. Our experiments on a real
   industrial dataset demonstrate that the generated knowledge base
   provides an excellent starting point for accelerating RCA tasks and
   improving network resilience.},
