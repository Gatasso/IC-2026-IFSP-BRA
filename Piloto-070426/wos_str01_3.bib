@inproceedings{ WOS:001334560000113,
Author = {Shiri, Fatemeh and Moghimifar, Farhad and Haffari, Reza and Li,
   Yuan-Fang and Van Nguyen and Yoo, John},
Book-Group-Author = {IEEE},
Title = {Decompose, Enrich, and Extract! Schema-aware Event Extraction using
   LLMs.},
Booktitle = {2024 27TH INTERNATIONAL CONFERENCE ON INFORMATION FUSION, FUSION 2024},
Year = {2024},
Note = {27th International Conference on Information Fusion (FUSION), San Globbe
   Econ Campus, Venice, ITALY, JUL 07-11, 2024},
Organization = {IEEE; IEEE AESS; ISIF},
Abstract = {Large Language Models (LLMs) demonstrate significant capabilities in
   processing natural language data, promising efficient knowledge
   extraction from diverse textual sources to enhance situational awareness
   and support decision-making. However, concerns arise due to their
   susceptibility to hallucination, resulting in contextually inaccurate
   content. This work focuses on harnessing LLMs for automated Event
   Extraction, introducing a new method to address hallucination by
   decomposing the task into Event Detection and Event Argument Extraction.
   Moreover, the proposed method integrates dynamic schema-aware augmented
   retrieval examples into prompts tailored for each specific inquiry,
   thereby extending and adapting advanced prompting techniques such as
   Retrieval-Augmented Generation. Evaluation findings on prominent event
   extraction benchmarks and results from a synthesized benchmark
   illustrate the method's superior performance compared to baseline
   approaches.},
