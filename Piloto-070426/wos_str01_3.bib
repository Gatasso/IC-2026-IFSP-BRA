Title = {Adapting and Evaluating Multimodal Large Language Models for Adolescent
   Idiopathic Scoliosis Self-management: A Divide and Conquer Framework},
Booktitle = {AI FOR CLINICAL APPLICATIONS, AGENTIC AI 2025, CREATE 2025, CLINICAL
   MLLMS 2025},
