Author = {Zhu, Yue and Yu, Hao and Wang, Chen and Liu, Zhuoran and Lee, Eun Kyung},
Editor = {Chang, RN and Chang, CK and Yang, J and Atukorala, N and Chen, D and Helal, S and Tarkoma, S and He, Q and Kosar, T and Ardagna, C and Elkhatib, Y and Nurmi, P and Sarkar, S},
Title = {Towards Efficient Key-Value Cache Management for Prefix Prefilling in
   LLM Inference},
Booktitle = {2025 IEEE 18TH INTERNATIONAL CONFERENCE ON CLOUD COMPUTING, CLOUD},
Series = {IEEE International Conference on Cloud Computing},
Year = {2025},
Pages = {445-447},
Note = {18th International Conference on Cloud Computing-CLOUD, Helsinki,
   FINLAND, JUL 08-11, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The increasing adoption of large language models (LLMs) with extended
   context windows necessitates efficient KeyValue Cache (KVC) management
   to optimize inference performance. Inference workloads like
   Retrieval-Augmented Generation (RAG) and agents exhibit high cache
   reusability, making efficient caching critical to reducing redundancy
   and improving speed. We analyze real-world KVC access patterns using
   publicly available traces and evaluate commercial key-value stores like
   Redis and state-of-the-art RDMA-based systems (CHIME {[}1] and Sherman
   {[}2]) for KVC metadata management. Our work demonstrates the lack of
   tailored storage solution for KVC prefilling, underscores the need for
   an efficient distributed caching system with optimized metadata
   management for LLM workloads, and provides insights into designing
   improved KVC management systems for scalable, low-latency inference.},
