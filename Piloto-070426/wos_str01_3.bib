   Chen, Yunnong; Yu, Xinyu; Sun, Lingyun; Chen, Liuqing, Zhejiang Univ, Coll Comp Sci \& Technol, Hangzhou, Zhejiang, Peoples R China.
   Shen, Yishu, Shanghai Jiao Tong Univ, Sch Design, Shanghai, Peoples R China.
   Liu, Ruiyi, Tongji Univ, Coll Design \& Innovat, Shanghai, Peoples R China.},
DOI = {10.1080/10447318.2025.2559053},
EarlyAccessDate = {OCT 2025},
ISSN = {1044-7318},
EISSN = {1532-7590},
