Editor = {Kahraman, C and Oztaysi, B and Tolga, C and Otay, I and Cebi, S and Onar, SC and Sari, IU},
Title = {EmbedTurk: Leveraging Large Language Models as Text Encoders for Turkish
   Language},
Booktitle = {INTELLIGENT AND FUZZY SYSTEMS, INFUS 2025, VOL 2},
