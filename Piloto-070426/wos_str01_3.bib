@inproceedings{ WOS:001576324000015,
Author = {Yousaf, Raeesa and Walther, Marina and Gertz, Michael},
Editor = {Braun, T and Paassen, B and Stolzenburg, F},
Title = {Accessible Language Simplification: Large Language Models for Generating
   Easy German},
