@inproceedings{ WOS:001477505600071,
Author = {Deng, Boyi and Wang, Wenjie and Zhu, Fengbin and Wang, Qifan and Feng,
   Fuli},
Editor = {Walsh, T and Shah, J and Kolter, Z},
Title = {CrAM: Credibility-Aware Attention Modification in LLMs for Combating
   Misinformation in RAG},
Booktitle = {THIRTY-NINTH AAAI CONFERENCE ON ARTIFICIAL INTELLIGENCE, AAAI-25, VOL 39
   NO 22},
Series = {AAAI Conference on Artificial Intelligence},
Year = {2025},
Pages = {23760-23768},
Note = {39th AAAI Conference on Artificial Intelligence, Philadelphia, PA, FEB
   25-MAR 04, 2025},
Abstract = {Retrieval-Augmented Generation (RAG) can alleviate hallucinations of
   Large Language Models (LLMs) by referencing external documents. However,
   the misinformation in external documents may mislead LLMs' generation.
   To address this issue, we explore the task of ``credibility-aware
   RAG{''}, in which LLMs automatically adjust the influence of retrieved
   documents based on their credibility scores to counteract
   misinformation. To this end, we introduce a plug-and-play method named
   Credibility-aware Attention Modification (CrAM). CrAM identifies
   influential attention heads in LLMs and adjusts their attention weights
   based on the credibility of the documents, thereby reducing the impact
   of low-credibility documents. Experiments on Natual Questions and
   TriviaQA using Llama2-13B, Llama3-8B, and Qwen1.5-7B show that CrAM
   improves the RAG performance of LLMs against misinformation pollution by
   over 20\%, even surpassing supervised fine-tuning methods.},
