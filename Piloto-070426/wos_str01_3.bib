@inproceedings{ WOS:001431695500205,
Author = {Wu, Yike and Huang, Yi and Hu, Nan and Hua, Yuncheng and Qi, Guilin and
   Chen, Jiaoyan and Pan, Jeff Z.},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {CoTKR: Chain-of-Thought Enhanced Knowledge Rewriting for Complex
   Knowledge Graph Question Answering},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING,
   EMNLP 2024},
Year = {2024},
Pages = {3501-3520},
