@inproceedings{ WOS:001655308800027,
Author = {Guo, Beichen and Wen, Zhiyuan and Yang, Yu and Gao, Peng and Yang,
   Ruosong and Shen, Jiaxing},
Editor = {Yoshikawa, M and Meng, X and Cao, Y and Xiao, C and Chen, W and Wang, Y},
Title = {SGSimEval: A Comprehensive Multifaceted and Similarity-Enhanced
   Benchmark for Automatic Survey Generation Systems},
Booktitle = {ADVANCED DATA MINING AND APPLICATIONS, ADMA 2025, PT II},
Series = {Lecture Notes in Artificial Intelligence},
