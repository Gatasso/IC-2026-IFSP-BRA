@inproceedings{ WOS:001567374700074,
Author = {Jiang, Bo and Xu, Zhi and Li, Jiaheng and Yun, Mira},
Editor = {Paul, R},
Title = {E2A2: An Encouraging and Engaging Assignment
   Assistant for Learning Beyond Answers},
Booktitle = {2025 IEEE WORLD AI IOT CONGRESS, AIIOT},
Year = {2025},
Pages = {513-519},
Note = {6th WORLD AI IoT Congress-AIIoT-Annual, Seattle, WA, MAY 28-30, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {While adaptive AI tutoring can enhance learning outcomes in fundamental
   computer science, excessive reliance on AI-generated solutions may
   reduce cognitive engagement, which is essential for deep understanding.
   To address this, we introduce the Encouraging and Engaging Assignment
   Assistant (E(2)A(2)), an AI-powered tutoring system designed to foster
   active learning, structured guidance, and academic integrity in
   introductory programming courses. Unlike conventional AI systems that
   provide complete solutions, E(2)A(2) employs step-by-step guidance,
   retrieval-augmented generation, and adaptive feedback to promote
   meaningful engagement with learning modules rather than passive answer
   consumption. By integrating course materials, assignment guidelines, and
   student progress tracking, E(2)A(2) delivers context-aware, personalized
   support that strengthens problem-solving and programming skills. By
   redefining AI's role from an answer provider to a learning facilitator,
   E(2)A(2) offers a scalable, ethical approach to AI-driven tutoring,
   bridging the gap between AI assistance and authentic student learning.},
