@article{ WOS:001709096500001,
Author = {Li, Changjin and Jing, Fengshi and Li, Huarun and Dong, Zheng and Xu,
   Zhougzhi and Zou, Huiru and Wang, Qiting and He, Jie and Qian, Yuchen
   and Cao, Boyu and Liu, Wenjian and Qin, Si and Cheng, Weibin and Zhang,
   Haobin},
Title = {Medical multi-recall embedding: Adaptive retrieval for diverse evidence
   in medical RAG systems},
Journal = {INFORMATION PROCESSING \& MANAGEMENT},
Year = {2026},
Volume = {63},
Number = {5},
Month = {JUL},
Abstract = {Large language models have demonstrated promising capabilities in
   medical question answering but frequently generate unreliable or
   hallucinated content. Retrieval-Augmented Generation (RAG) addresses
   this issue by incorporating external knowledge, yet its effectiveness
   critically depends on retrieval quality. Existing medical retrievers are
   typically trained under a restrictive one-to-one paradigm, where each
   query is paired with a single document, failing to reflect the
   complexity of real-world clinical scenarios that often require
   synthesizing information from multiple complementary sources. To address
   this limitation, we introduce a specialized multi-document medical
   retrieval dataset comprising 6273 queries paired with approximately
   20,810 annotated passages spanning five clinical domains: general
   practice, cardiology, dermatology, breast tumor, and ophthalmology. Each
   query is associated with multiple clinically relevant documents that
   provide diverse yet complementary perspectives. Leveraging this dataset,
   we propose the Medical Multi-Recall Embedding (MMRE) model, which
   employs a one-to-many retrieval strategy enhanced by a novel Adaptive
   Multi-Recall Loss (AMR Loss). AMR Loss introduces three
   components-Adaptive Positive Margin, Difficulty-Aware Weighting, and
   Loss Normalization-and ablation studies on each component demonstrate
   that all three contribute effectively and work synergistically.
   Extensive retrieval experiments demonstrate that MMRE substantially
   outperforms competitive baselines across all evaluation metrics and
   domains. On average across five domains, MMRE achieves more than 10
   percentage point gains in Recall@10 and significant improvements in Hit
   Rate, MRR@10, and NDCG@10. Furthermore, when integrated into a RAG
   pipeline with a frozen language model, MMRE considerably improves
   downstream clinical question answering accuracy by at least 4 percentage
   points across all specialties, underscoring its effectiveness in
   enhancing the factual reliability and clinical relevance of
   LLM-generated medical answers. The constructed dataset and source code
   are publicly available
   https://github.com/WVKerl/Medical-one-to-many-data.},
