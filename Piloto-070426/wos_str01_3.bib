@inproceedings{ WOS:001661442600003,
Author = {Awasthi, Raghav and Mishra, Shreya and Singh, Nishant and Auron, Moises
   and Subramanian, Charumathi Raghu and Atreja, Ashish and Maheshwari,
   Kamal and Khanna, Ashish and Cywinski, Jacek B. and Papay, Francis and
   Mathur, Piyush},
Book-Group-Author = {ACM},
Title = {Promises and Pitfalls of Large Language Models use to interpret
   Healthcare Guidelines},
Booktitle = {16TH ACM INTERNATIONAL CONFERENCE ON BIOINFORMATICS, COMPUTATIONAL
   BIOLOGY AND HEALTH INFORMATICS, ACM BCB 2025},
Year = {2025},
Note = {16th Conference on Bioinformatics Computational Biology and Health
   Informatics-BCB, Philadelphia, PA, OCT 12-15, 2025},
Organization = {Association for Computing Machinery; The ACM Special Interest Group on
   Bioinformatics Computational Biology and Biomedical Informatics SIGBio},
Abstract = {Healthcare guidelines provide evidence-based recommendations for disease
   management, but their complexity can make interpretation challenging in
   patient-specific contexts. Large Language Models (LLMs) have been
   proposed to help query such guidelines, but they may produce inaccurate
   or incomplete responses when applied to clinical tasks.
   Retrieval-Augmented Generation (RAG) methods, which have been utilized
   to enhance LLM performance by incorporating relevant excerpts from
   healthcare guidelines, represent one strategy to improve the accuracy.
   In this study, we present a threefold contribution toward evaluating
   LLMs for healthcare guideline interpretation. First, in collaboration
   with board-certified physicians, we developed GuidelineQA, a clinically
   curated, in-house question-answer dataset covering three widely used
   guidelines on cardiovascular disease, diabetes, and colon cancer
   prevention. The dataset includes a variety of questions, including those
   commonly needed by physicians, a frequently asked patient question, and
   adversarial questions designed to challenge the LLMs. Second, we
   assessed the performance of two state-of-the-art models-GPT-4o
   closed-source) and LLaMA-2-7B (open-source) under both standard
   (non-augmented) and Retrieval-Augmented Generation (RAG) settings.
   Third, we conducted a comprehensive evaluation using both quantitative
   metrics (e.g., BERTScore) and qualitative human assessments.
   We observed that LLMs achieved BERTScores above 80\% across all
   experimental setups. Human evaluation further validated that the models
   performed well in generating clinically relevant responses. When
   comparing LLMs in RAG-augmented and non-augmented settings, we did not
   observe a significant overall difference in performance. However, for
   adversarial questions, responses generated using RAG, particularly from
   GPT-4o, demonstrated improved reliability. Overall, our findings
   highlight that while LLMs perform well in interpreting common healthcare
   guidelines, RAG offers added benefit primarily in handling adversarial
   queries.},
