   Sobhi and Kaplan, Nicolas and Chiu, Richard and Yang, Kevin and Zeid,
   Naji Bou and Corcoran, Julia and Alkureishi, Lee W. T.},
Title = {Prompt engineering to increase GPT3.5's performance on the Plastic
   Surgery In-Service Exams},
Journal = {JOURNAL OF PLASTIC RECONSTRUCTIVE AND AESTHETIC SURGERY},
Year = {2024},
Volume = {98},
Pages = {158-160},
Month = {NOV},
Abstract = {This study assesses ChatGPT's (GPT-3.5) performance on the 2021 ASPS
   Plastic Surgery In-Service Examination using prompt modifications and
   Retrieval Augmented Generation (RAG). ChatGPT was instructed to act as a
   ``resident,{''} ``attending,{''} or ``medical student,{''} and RAG
   utilized curated vector database for context. Results showed no
   significant improvement, with the ``resident{''} prompt yielding the
   highest accuracy at 54\%, and RAG failing to enhance performance, with
   accuracy remaining at 54.3\%. Despite appropriate reasoning when
   correct, ChatGPT's overall performance fell in the 10th percentile,
   indicating the need for fine-tuning and more sophisticated approaches to
   improve AI's utility in complex medical tasks. (c) 2024 British
   Association of Plastic, Reconstructive and Aesthetic Surgeons. Published
   by Elsevier Ltd. All rights are reserved, including those for text and
