Funding-Acknowledgement = {NSF CAREER Award {[}IIS-2145280]; NSF AI Institute for Foundations of
   Machine Learning (IFML); Open Philanthropy; UT Austin Office of the Vice
   President for Research},
Funding-Text = {We would like to thank Jessy Li for comments on a draft of this work.
