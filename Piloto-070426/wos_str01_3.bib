@inproceedings{ WOS:001666520500067,
Author = {Nema, Jayant},
Book-Group-Author = {ASME},
Title = {AN LLM-POWERED PIPELINE FOR AUTOMATED EXTRACTION, ANALYSIS, AND
   VALIDATION OF REQUIREMENTS IN SYSTEMS ENGINEERING},
Booktitle = {PROCEEDINGS OF ASME 2025 INTERNATIONAL MECHANICAL ENGINEERING CONGRESS
   AND EXPOSITION - INDIA, IMECE-INDIA2025, VOL 4},
Year = {2025},
Note = {2025 International Mechanical Engineering Congress and Exposition -
   India-IMECE India, Hyderabad, INDIA, SEP 10-13, 2025},
Organization = {The American Society of Mechanical Engineers},
Abstract = {This research paper discusses the development and capabilities of an
   LLM-powered pipeline for engineering requirements validation. The
   pipeline tests each requirement for completeness, missing information,
   and testability. Requirements that pass these tests are further checked
   for inconsistency and conflict. Cleaned requirements are then
   categorized and converted into SysML graph objects using Gaphor, with
   support for SysML 1.6 and Python 3.13.2. The pipeline uses RAG to
   connect external schemas, performs topic modeling to discover
   stakeholder priorities, and extracts requirements from MME transcripts.
   Preliminary results show promise in identifying missing information and
   inconsistencies. This work may be of help in integrating LLMs into
   requirements engineering processes.},
