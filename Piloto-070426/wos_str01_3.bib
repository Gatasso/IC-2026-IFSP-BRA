@inproceedings{ WOS:001511154400037,
Author = {Schnabel, Tobias and Neville, Jennifer},
Editor = {Al-Onaizan, Y and Bansal, M and Chen, YN},
Title = {Symbolic Prompt Program Search: A Structure-Aware Approach to Efficient
   Compile-Time Prompt Optimization},
Booktitle = {FINDINGS OF THE ASSOCIATION FOR COMPUTATIONAL LINGUISTICS: EMNLP 2024},
Year = {2024},
Pages = {670-686},
Note = {29th Conference on Empirical Methods in Natural Language Processing,
   Miami, FL, NOV 12-16, 2024},
Organization = {ByteDance Inc; Intuit Inc; Adobe Inc; Florida International University;
   Figma Inc},
Abstract = {In many modern LLM applications, such as retrieval augmented generation,
   prompts have become programs themselves. In these settings, prompt
   programs are repeatedly called with different user queries or data
   instances. A big practical challenge is optimizing such prompt programs.
   Recent work has mostly focused on either simple prompt programs or
   assumed that the structure of a prompt program is fixed.
   We introduce SAMMO, a framework to perform symbolic prompt program
   search for compile-time optimizations of prompt programs. SAMMO
   represents prompt programs on a symbolic level which allows for a rich
   set of transformations that can be searched over during optimization. We
   show that SAMMO generalizes previous methods and improves the
   performance of complex prompts on (1) instruction tuning, (2) RAG
   pipeline tuning, and (3) prompt compression, across several different
   LLMs. We make all code available open-source at
   https://github.com/microsoft/sammo.},
