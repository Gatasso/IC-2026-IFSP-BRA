@article{ WOS:001699557300033,
Author = {Bulut, Ahmet},
Title = {Marketing Keywords Exploration via LLMs With Domain Expertise},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {25968-25979},
Abstract = {We demonstrated how to explore the space of search marketing keywords
   using LLMs with the help of tool support. These external tools represent
   the domain expertise and the use of proprietary performance data. The
   LLM consults the tools provided when necessary in order to generate
   keywords that are expected to get user attention. We investigated
   whether the linguistic expressiveness of an LLM when combined with valid
   purchase intents provided by human marketers as few shots in a prompt
   would result in discovering new prospective keywords. We conducted an
   empirical study on two different domains: 1) the healthcare domain and
   2) the online learning domain. The LLM agent was able to explore a
   viable set of keywords, which was validated quantitatively by the number
   of user impressions, clicks and conversions the generated keywords were
   expected to receive.},
