Title = {AI-Assisted Assurance Profile Creation for System Security Assurance},
Booktitle = {COMPUTER SECURITY. ESORICS 2024 INTERNATIONAL WORKSHOPS, SECAI, DISA,
   CPS4CIP, AND SECASSURE, PT II},
