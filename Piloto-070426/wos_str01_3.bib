Title = {SHREADS: A Shrimp Health Diagnosis and Advisory System using Agentic RAG},
Booktitle = {2025 17TH INTERNATIONAL CONFERENCE ON KNOWLEDGE AND SYSTEM ENGINEERING,
   KSE},
Series = {International Conference on Knowledge and Systems Engineering},
Year = {2025},
Pages = {37-42},
Note = {17th International Conference on Knowledge and System Engineering-KSE,
   Da Lat, VIETNAM, NOV 06-08, 2025},
Abstract = {Shrimp aquaculture, a key driver of Vietnam's economy, faces persistent
   disease threats that cause severe production and financial losses.
   Traditional diagnostics often fail to enable timely responses. We
   propose SHREADS (SHRimp hEAlth Diagnosis and advisory System), an
   intelligent platform providing rapid, accurate disease detection and
   management. SHREADS conducts an Agentic Retrieval-Augmented Generation
   (A-RAG) framework with a multi-agent architecture for optimized query
   processing. Farmers submit text or image queries through a mobile
   application, which are processed through specialized models, i.e., a
   ResNet50-based CNN for image-based diagnosis and a FastText model for
   textual symptom analysis. Experiments demonstrate high performance, with
   ResNet50 achieving an F1score of 92.85\% for classifying healthy shrimp
   and FastText reaching 82.4\%. By integrating Agentic RAG and multimodal
   deep learning, SHREADS enhances early intervention, supports sustainable
   aquaculture, and promotes technological adoption in Vietnam. Our dataset
   and implementation are published in Github:
   https://github.com/p4wndev/shreads.},
