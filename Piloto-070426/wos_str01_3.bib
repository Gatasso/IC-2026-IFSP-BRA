   Teng and Hou, Mingliang and Gao, Boyu and Tian, Mi and Liu, Zitao and
   Luo, Weiqi},
Editor = {Olney, AM and Chounta, IA and Liu, Z and Santos, OC and Bittencourt, II},
Title = {Automatic Lesson Plan Generation via Large Language Models with
   Self-critique Prompting},
Booktitle = {ARTIFICIAL INTELLIGENCE IN EDUCATION: POSTERS AND LATE BREAKING RESULTS,
   WORKSHOPS AND TUTORIALS, INDUSTRY AND INNOVATION TRACKS, PRACTITIONERS,
   DOCTORAL CONSORTIUM AND BLUE SKY, AIED 2024, PT I},
