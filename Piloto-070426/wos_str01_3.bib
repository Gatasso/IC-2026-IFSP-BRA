Title = {LLM Agents for InteractiveWorkflow Provenance: Reference Architecture
   and Evaluation Methodology},
Booktitle = {PROCEEDINGS OF 2025 WORKSHOPS OF THE INTERNATIONAL CONFERENCE ON HIGH
