@inproceedings{ WOS:001606850700036,
Author = {Jadhav, Suramya and Shanbhag, Abhay and Joshi, Sumedh and Date, Atharva
   and Sonawane, Sheetal},
Editor = {Naumann, T and Abacha, AB and Bethard, S and Roberts, K and Bitterman, D},
Title = {Maven at MEDIQA-CORR 2024: Leveraging RAG and Medical LLM for Error
   Detection and Correction in Medical Notes},
Booktitle = {PROCEEDINGS OF THE 6TH CLINICAL NATURAL LANGUAGE PROCESSING WORKSHOP},
Year = {2024},
Pages = {374-381},
Note = {6th Clinical Natural Language Processing Workshop-ClinicalNLP, MEXICO,
   JUN 21, 2024},
Organization = {Association for Computational Linguistics},
Abstract = {Addressing the critical challenge of identifying and rectifying medical
   errors in clinical notes, we present a novel approach tailored for the
   MEDIQA-CORR task@ NAACL-ClinicalNLP 2024, which comprises three
   subtasks: binary classification, span identification, and natural
   language generation for error detection and correction. Binary
   classification involves detecting whether the text contains a medical
   error; span identification entails identifying the text span associated
   with any detected error; and natural language generation focuses on
   providing a free text correction if a medical error exists. Our proposed
   architecture leverages Named Entity Recognition (NER) for identifying
   diseaserelated terms, Retrieval-Augmented Generation (RAG) for
   contextual understanding from external datasets, and a quantized and
   fine-tuned Palmyra model for error correction. Our model achieved a
   global rank of 5 with an aggregate score of 0.73298, calculated as the
   mean of ROUGE-1-F, BERTScore, and BLEURT scores.},
