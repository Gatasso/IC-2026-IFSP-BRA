Title = {GOODTRIEVER: Adaptive Toxicity Mitigation with Retrieval-augmented
   Models},
Booktitle = {FINDINGS OF THE ASSOCIATION FOR COMPUTATIONAL LINGUISTICS - EMNLP 2023},
Year = {2023},
Pages = {5108-5125},
