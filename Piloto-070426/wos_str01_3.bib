Note = {20th International Symposium on Broadband Multimedia Systems and
   Broadcasting-BMSB-Annual, Dublin, IRELAND, JUN 11-13, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Dublin City
   University Faculty of Engineering and Computing},
Abstract = {The paper proposes a Multi-Agent Collaborative Approach to enhance the
   answer quality in industry-specific question-answering tasks. The system
   integrates a retrieval-augmented large language model with multi-agent
   collaboration, aiming to improve the accuracy and robustness of
   multi-turn interactions within professional domains. It is structured
   into three layers for efficient query decomposition and multi-source
   information fusion. Task-specific agents are deployed for intent
   classification, query rewriting, information retrieval, and answer
   generation, ensuring precise understanding of user intent and accurate
   synthesis of information. A dynamic adjustment algorithm and memory
   module are implemented to optimize efficiency by learning from past user
   interactions. Extensive testing across various industries demonstrates
   that the system effectively overcomes traditional limitations,
   significantly enhancing question-answering accuracy and reliability.},
