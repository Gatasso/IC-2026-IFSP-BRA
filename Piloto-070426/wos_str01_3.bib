   Tsironis, Vasileios and Karantzalos, Konstantinos},
Editor = {Neale, CM and Maltese, A and Bostater, CR and Castagna, A},
Title = {Naiad: Novel Agentic Intelligent Autonomous System for Inland Water
   Monitoring},
