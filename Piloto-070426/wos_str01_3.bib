   Romeo, Francesco; Arena, Luigi; Blefari, Francesco; Pironti, Francesco Aurelio; Lupinacci, Matteo; Furfaro, Angelo, Univ Calabria, I-87036 Arcavacata Di Rende, CS, Italy.
   Romeo, Francesco; Blefari, Francesco, IMT Sch Adv Studies Lucca, I-55100 Lucca, LU, Italy.},
DOI = {10.1007/978-3-032-05727-3\_39},
