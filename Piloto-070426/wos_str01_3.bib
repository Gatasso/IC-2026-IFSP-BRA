Book-Group-Author = {IEEE COMPUTER SOC},
Title = {MenTeR: A fully-automated Multi-agenT workflow for end-to-end RF/Analog
   Circuits Netlist Design},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON LLM-AIDED DESIGN, ICLAD},
Year = {2025},
Pages = {124-132},
Note = {1st International Conference on LLM-Aided Design-ICLAD, Stanford, CA,
   JUN 26-27, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; IEEE Council on
   Electronic Design Automation; IEEE Solid State Circuits Society;
   Advanced Micro Devices; Cadence Inc; Google Incorporated; Intel
   Corporation; International Buisness Machines Corp; Mediatek Llc; Nvidia
   Corporation; NXP Semiconductors; Qualcomm; Siemens AG; Synopsys Inc;
   Taiwan Semiconductor Manufacturing Company},
Abstract = {RF/Analog design is essential for bridging digital technologies with
   real-world signals, ensuring the functionality and reliability of a wide
   range of electronic systems. However, analog design procedures are often
   intricate, time-consuming and reliant on expert intuition, and hinder
   the time and cost efficiency of circuit development. To overcome the
   limitations of the manual circuit design, we introduce MenTeR - a
   multi-agent workflow integrated into an end-to-end analog design
   framework. By employing multiple specialized AI agents that
   collaboratively address different aspects of the design process, such as
   specification understanding, circuit optimization, and test bench
   validation, MenTeR reduces the dependency on frequent
   trial-and-error-style intervention. MenTeR not only accelerates the
   design cycle time but also facilitates a broader exploration of the
   design space, demonstrating robust capabilities in handling real-world
   analog systems. We believe that MenTeR lays the groundwork for future
   ``RF/Analog Copilots{''} that can collaborate seamlessly with human
   designers.},
