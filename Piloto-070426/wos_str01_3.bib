@inproceedings{ WOS:001672891900101,
Author = {Mittal, Akshay and Tadi, Goutam and Madduri, Srinu},
Editor = {Paul, R},
Title = {A Unified Framework for Mitigating Hallucinations in Large Language
   Models: Integrating Internal and External Validation Strategies},
Booktitle = {2025 IEEE 16TH ANNUAL UBIQUITOUS COMPUTING, ELECTRONICS \& MOBILE
   COMMUNICATION CONFERENCE, UEMCON},
Year = {2025},
Pages = {724-730},
Note = {16th Ubiquitous Computing Electronics and Mobile Communication
   Conference-UEMCON-Annual, Yorktown Heights, NY, OCT 22-24, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Large Language Models (LLMs) suffer from hallucination-generating
   plausible but factually incorrect content-posing significant threats to
   AI system reliability with documented \$100 billion market losses and
   critical failures across healthcare, legal, and educational domains.
   Existing mitigation techniques achieve 12-35\% improvements but lack
   comprehensive integration. This paper proposes a unified validation
   framework combining internal and external validation strategies.
   Internal validation uses semantic entropy, attention analysis, and
   representation probing to achieve 79\% AUROC in hallucination detection.
   External validation employs advanced RAG architectures and automated
   factchecking, demonstrating 28-95\% hallucination reduction. The
   framework uses internal signals as an efficient triage mechanism (95\%
   overhead reduction) to trigger external verification, achieving 1.82x
   cost-effectiveness ratios. Evaluation across 15+ benchmarks and
   production deployments validates effectiveness in critical applications.},
