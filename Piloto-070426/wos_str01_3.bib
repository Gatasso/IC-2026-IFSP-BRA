@inproceedings{ WOS:001665568700043,
Author = {Pineda, Victor and Dayan, Niv and de Lara, Eyal},
Book-Group-Author = {ACM},
Title = {Poster: Leveraging Geo-Spatiality in Geo-Distributed Vector Databases},
Booktitle = {PROCEEDINGS OF THE 2025 THE TENTH ACM/IEEE SYMPOSIUM ON EDGE COMPUTING,
   SEC 2025},
Year = {2025},
Note = {10th Symposium on Edge Computing-SEC-Annual, Arlington, VA, DEC 03-06,
   2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; ACM SIGMOBILE;
   Akamai Technologies Inc; Toyota-Fonden; Ernst \& Young Global Ltd;
   Microsoft Corp; IEEE Computer Society},
Abstract = {Multimodal Retrieval-Augmented Generation (MRAG) systems depend on
   geo-distributed vector database management systems (GVDBMS) to deliver
   low-latency multimedia retrieval. Multimedia content that encodes
   spatial information (e.g., images from Toronto or audio from the Amazon)
   is produced worldwide. Consequently, GVDBMS face a fundamental trade-off
   when serving approximate nearest neighbor (ANN) queries: full data
   replication or broadcast querying. We hypothesize that embeddings
   produced by pre-trained models exhibit strong geographic locality. By
   exploiting this non-IID characteristic, query routing can be optimized
   to reduce cross-region traffic for these datasets and avoid the costs of
   full replication or query broadcasting. Our evaluation on real-world
   datasets shows that 42-93\% of queries are satisfied by a single
   geographic partition, and 65-85\% require at most half of the partitions
   to retrieve the top-10 results. Across five datasets (including
   street-view images and geo-tagged sounds) and multiple embedding models,
   our approach yields a 2-4x overall system throughput improvement while
   maintaining 90\% accuracy over broadcast querying.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Pineda, V (Corresponding Author), Univ Toronto, Toronto, ON, Canada.
