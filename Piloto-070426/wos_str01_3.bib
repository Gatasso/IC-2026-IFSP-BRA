@article{ WOS:001642984300001,
Author = {Qu, Wei and Chen, Cong and Lu, Wei and Wei, Yingying and Li, Tao},
Title = {CM-MRAG: A multimodal retrieval-augmented framework for content
   moderation},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {304},
Month = {APR 1},
Abstract = {Large Language Models (LLMs) have catalyzed a transformative paradigm
   shift in the auditing of User-Generated Content (UGC) and AI-Generated
   Content (AIGC), advancing content moderation systems from rule-based
   paradigms to cognition-driven architectures. Despite their promising
   capabilities, current LLM-based moderation frameworks predominantly rely
   on fine-tuning approaches, which encounter three critical limitations:
   (1) the heterogeneity and continuous evolution of safety standards
   across platforms and jurisdictions; (2) the prohibitive cost and limited
   accessibility of high-quality, domain-specific annotated datasets; and
   (3) the susceptibility to hallucinations coupled with insufficient
   decision traceability, undermining moderation reliability and
   auditability. To address these challenges comprehensively, this study
   introduces CM-MRAG, a general-purpose multimodal moderation framework
   that integrates fine-tuned multimodal LLMs with a flexible retrieval
   module. A base model is trained to detect harmful patterns in multimodal
   content, and the MRAG component is subsequently employed to enhance
   reasoning through relevant examples. This design enables rapid
   adaptation to new safety requirements without repeated fine-tuning. The
   approach reduces data and computational demands and improves reliability
   by mitigating hallucinations. Experimental results demonstrate that
   CM-MRAG reaches 97.92 \% accuracy on in-distribution data and 93.07\% on
   out-of-distribution data, outperforming strong baselines such as
   Llama-Guard (93.20 \%) and LlavaGuard-B (91.64 \%). The ablation studies
   further indicate that scaling the MRAG repository consistently boosts
   accuracy, from 94.17\% to 99.17\%. In practice, CM-MRAG can be
   integrated into a wide range of applications, including social media
   platforms, online learning environments, and digital marketplaces. By
   maintaining reliable performance and low latency while adapting to
   evolving content patterns, it provides a practical solution for
   strengthening content security across diverse digital ecosystems. The
   implementation is available at https://github.com/clsyc/CMRAG.},
