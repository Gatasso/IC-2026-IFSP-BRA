Author = {Peng, Jingyang and Shen, Wenyuan and Rao, Jiarui and Lin, Jionghao},
Editor = {Cristea, AI and Walker, E and Lu, Y and Santos, OC and Isotani, S},
Title = {Automated Bias Assessment in AI-Generated Educational Content Using CEAT
   Framework},
Booktitle = {ARTIFICIAL INTELLIGENCE IN EDUCATION: POSTERS AND LATE BREAKING RESULTS,
   WORKSHOPS AND TUTORIALS, INDUSTRY AND INNOVATION TRACKS, PRACTITIONERS,
   DOCTORAL CONSORTIUM, BLUE SKY, AND WIDEAIED, AIED 2025, PT II},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2591},
