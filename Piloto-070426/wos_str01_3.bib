@inproceedings{ WOS:001669941600011,
Author = {He, Chuanni and Liu, Min and He, Weilin},
Editor = {Akinci, B and Berges, M and Jazizadeh, F and Menassa, CC and Yeoh, J},
Title = {Prompt-Based Virtual Assistant Framework for Construction Working Method
   Specifications},
Booktitle = {COMPUTING IN CIVIL ENGINEERING 2024: ARTIFICIAL INTELLIGENCE, AUTOMATION
   AND ROBOTICS, AND HUMAN-CENTERED INNOVATIONS},
Year = {2024},
Pages = {107-115},
Note = {2024 International Conference on Computing in Civil Engineering-I3CE,
   Carnegie Mellon University, Pittsburgh, PA, JUL 28-31, 2024},
Abstract = {Labor shortage is a major challenge in the construction industry. A
   skilled worker requires deep knowledge or extensive engineering
   experience of complex working methods for various construction tasks.
   Hence, an efficient knowledge retrieval and communication tool is
   indispensable. Given this challenge, this research aims to (1) establish
   a data index to organize fragmented construction method specifications
   for machine retrieval and (2) develop a virtual assistant for answering
   queries related to construction methods. This research employs a
   retrieval augmented generation ( RAG) approach to formulate a framework
   that facilitates knowledge retrieval through a generative pretrained
   transformer (GPT) model. This framework transforms text-based
   construction method specifications into a machine-readable knowledge
   embedding. The system uses similarity scoring to extract relevant
   answers from the embedding upon receiving user queries. A
   question-answering tool for construction contexts is developed by
   integrating the GPT-4 model with the embedding. Testing results indicate
   that the virtual assistant delivers accurate responses to
   domain-specific inquiries. The findings can potentially enhance learning
   efficiency and productivity among front-line construction laborers.},
