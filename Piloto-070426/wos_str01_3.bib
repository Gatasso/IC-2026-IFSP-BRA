@inproceedings{ WOS:001591523800080,
Author = {Kurma, Sravani and Paul, Anal and Singh, Keshav and Dev, Kapal and Li,
   Chih-Peng},
Book-Group-Author = {IEEE},
Title = {LLMs for Resource Allocation in Next-Gen RIS-Aided Healthcare Wireless
   Networks},
Booktitle = {IEEE INFOCOM 2025-IEEE CONFERENCE ON COMPUTER COMMUNICATIONS WORKSHOPS,
   INFOCOM WKSHPS},
Series = {IEEE Conference on Computer Communications Workshops},
Year = {2025},
Note = {2025 Conference on Computer Communications-INFOCOM-Annual, London,
   ENGLAND, MAY 19-22, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This study introduces a groundbreaking approach by integrating large
   language models (LLMs), interactive artificial intelligence (IAI), and
   edge computing to enhance healthcare systems within next-generation
   wireless networks. We consider a scenario where multiple Internet of
   Things (IoT) devices transmit their data through a reconfigurable
   intelligent surface (RIS) and are processed by edge computing nodes
   (ECNs) before reaching a central control unit (CCU) and an LLM-based
   server (LLS). Using an advanced IAI-LLM framework, including modular
   components like retrieval-augmented generation (RAG), we develop a
   strategy to minimize operational overhead, focusing on dynamic
   user-specific data routing (DUDR). We validate our proposed IAI-driven
   model (IAIM) using a deep reinforcement learning (DRL) algorithm and
   compare it against a traditional manual optimization method. Simulation
   results show that IAIM reduces overhead by 44.96\% compared to manual
   methods and significantly improves network scalability, particularly
   with the inclusion of DUDR and an increased number of ECNs. The IAIM
   framework's priority-based weight selection further optimizes resource
   management and data flow, outperforming random weight methods in
   large-scale IoT environments.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
