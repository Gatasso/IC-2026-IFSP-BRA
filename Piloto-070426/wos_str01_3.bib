@inproceedings{ WOS:001592980400122,
Author = {Sun, Jiashuo and Zhang, Hang and Lin, Chen and Su, Xiangdong and Gong,
   Yeyun and Guo, Jian},
Editor = {Calzolari, N and Kan, MY and Hoste, V and Lenci, A and Sakti, S and Xue, N},
Title = {APOLLO: An Optimized Training Approach for Long-form Numerical Reasoning},
Booktitle = {PROCEEDINGS OF THE 2024 JOINT INTERNATIONAL CONFERENCE ON COMPUTATIONAL
   LINGUISTICS, LANGUAGE RESOURCES AND EVALUATION, LREC-COLING 2024},
Series = {International Conference on Computational Linguistics Language Resources
   and Evaluation},
Year = {2024},
Pages = {1370-1382},
Note = {2024 Joint International Conference on Computational Linguistics,
   Language Resources and Evaluation-LREC-COLING, Torino, ITALY, MAY 20-25,
   2024},
Abstract = {Long-form numerical reasoning aims to generate a reasoning program to
   calculate the answer for a given question. Previous work followed a
   retriever-generator framework, where the retriever selects key facts
   from a long-form document, and the generator generates a reasoning
   program based on the retrieved facts. However, they treated all facts
   equally without considering the different contributions of facts with
   and without numerical information. Furthermore, they ignored program
   consistency, leading to the wrong punishment of programs that differed
   from the ground truth. In order to address these issues, we proposed
   APOLLO (An optimized training aPproach fOr Long-form numericaL
   reasOning), to improve long-form numerical reasoning. APOLLO includes a
   number-aware negative sampling strategy for the retriever to
   discriminate key numerical facts, and a consistency-based reinforcement
   learning with target program augmentation for the generator to
   ultimately increase the execution accuracy. Experimental results on the
   FinQA and ConvFinQA leaderboards verify the effectiveness of our
   proposed methods, achieving the new state-of-the-art.},
