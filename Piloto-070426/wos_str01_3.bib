@inproceedings{ WOS:001511155600022,
Author = {Zheng, Yuxiang and Sun, Shichao and Qiu, Lin and Ru, Dongyu and Jiayang,
   Cheng and Li, Xuefeng and Lin, Jifan and Wang, Binjie and Luo, Yun and
   Pan, Renjie and Xu, Yang and Min, Qingkai and Zhang, Zizhao and Wang,
   Yiwen and Li, Wenjie and Liu, Pengfei},
Editor = {Farias, DIH and Hope, T and Li, M},
Title = {OpenResearcher: Unleashing AI for Accelerated Scientific Research},
Booktitle = {2024 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING},
Year = {2024},
