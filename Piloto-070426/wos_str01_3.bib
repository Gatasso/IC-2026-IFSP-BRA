   Gheorghe Cosmin},
Editor = {Bork, D and Lukyanenko, R and Sadiq, S and Bellatreche, L and Pastor, O},
Title = {Comparative Experiments on Natural Language Querying of Knowledge Graphs
   Using a Graph RAG Approach},
