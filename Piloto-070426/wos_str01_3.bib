Title = {Instruct-to-SPARQL: A text-to-SPARQL dataset for training SPARQL Agents},
Booktitle = {PROCEEDINGS OF THE 2025 CONFERENCE ON HUMAN INFORMATION INTERACTION AND
   RETRIEVAL, CHIIR 2025},
Year = {2025},
