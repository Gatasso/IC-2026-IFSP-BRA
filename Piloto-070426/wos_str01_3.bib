Title = {Enhance FMEA with Large Language Models for Assisted Risk Management in
   Technical Processes and Products},
Booktitle = {2024 IEEE 29TH INTERNATIONAL CONFERENCE ON EMERGING TECHNOLOGIES AND
   FACTORY AUTOMATION, ETFA 2024},
