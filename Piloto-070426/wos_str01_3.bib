@inproceedings{ WOS:001655278000026,
Author = {Xu, Zhen and Li, Xinjin and Huan, Yingqi and Minaya, Veronica and Yu,
   Renzhe},
Editor = {Cristea, AI and Walker, E and Lu, Y and Santos, OC and Isotani, S},
Title = {From Course to Skill: Evaluating Large Language Model Performance in
   Curricular Analytics},
Booktitle = {ARTIFICIAL INTELLIGENCE IN EDUCATION, AIED 2025, PT VI},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15882},
Pages = {203-211},
Note = {26th International Conference on Artificial Intelligence in
   Education-AIED, Palermo, ITALY, JUL 22-26, 2025},
Abstract = {Curricular analytics (CA) - systematic analysis of curricula data to
   inform program and course refinement - becomes an increasingly valuable
   tool to help institutions align academic offerings with evolving
   societal and economic demands. Large language models (LLMs) are
   promising for handling large-scale, unstructured curriculum data, but it
   remains uncertain how reliably LLMs can perform CA tasks. In this paper,
   we systematically evaluate four text alignment strategies based on LLMs
   or traditional NLP methods for skill extraction, a core task in CA.
   Using a stratified sample of 400 curriculum documents of different types
   and a human-LLM collaborative evaluation framework, we find that
   retrieval-augmented generation (RAG) is the top-performing strategy
   across all types of curriculum documents, while zero-shot prompting
   performs worse than traditional NLP methods in most cases. Our findings
   highlight the promise of LLMs in analyzing brief and abstract curriculum
   documents, but also reveal that their performance can vary significantly
   depending on model selection and prompting strategies. This underscores
   the importance of carefully evaluating the performance of LLM-based
   strategies before large-scale deployment.},
