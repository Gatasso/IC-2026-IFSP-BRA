@article{ WOS:001714513000001,
Author = {Song, Eunji and Lee, Hwansoo},
Title = {Defending financial RAG systems against jailbreak attacks},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {317},
Month = {JUN 25},
Abstract = {Large language model (LLM)-based generative AI systems are vulnerable to
   jailbreak attacks, in which malicious prompts bypass safety mechanisms.
   This study investigates whether retrieval augmented generation
   (RAG)-based LLM systems are susceptible to such attacks. The
   effectiveness and efficiency of various defense techniques, including
   safety-enhanced system prompts and input/output filtering, are analyzed.
   The results of experiments demonstrate that RAG-based LLM systems remain
   vulnerable to jailbreak attacks. Implementing defense mechanisms at each
   stage significantly reduces attack success rates (ASRs). Specifically,
   safety-enhanced system prompts reduce ASRs by over 78\% with minimal
   impact on response time, indicating high defense efficiency.
   Incorporating Prompt Guard as an input/output guardrail slightly
   increases response time but reduces ASRs by approximately 93.9\%, while
   increasing the false positive rate by only 2\%. This defense combination
   is the most effective in our experimental setup.},
