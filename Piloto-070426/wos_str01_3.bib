Title = {Memory and Knowledge Augmented Language Models for Inferring Salience in
   Long-Form Stories},
Booktitle = {2021 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING
   (EMNLP 2021)},
Year = {2021},
Pages = {851-865},
Note = {Conference on Empirical Methods in Natural Language Processing (EMNLP),
   Punta Cana, DOMINICAN REP, NOV 07-11, 2021},
Abstract = {Measuring event salience is essential in the understanding of stories.
   This paper takes a recent unsupervised method for salience detection
   derived from Barthes Cardinal Functions and theories of surprise and
   applies it to longer narrative forms. We improve the standard
   transformer language model by incorporating an external knowledgebase
   (derived from Retrieval Augmented Generation) and adding a memory
   mechanism to enhance performance on longer works. We use a novel
   approach to derive salience annotation using chapter-aligned summaries
   from the Shmoop corpus for classic literary works. Our evaluation
   against this data demonstrates that our salience detection model
   improves performance over and above a non-knowledgebase and memory
   augmented language model, both of which are crucial to this improvement.},
