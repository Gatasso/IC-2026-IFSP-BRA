Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Guo, W (Corresponding Author), Guangdong Univ Finance, Sch Credit Management, Guangzhou, Guangdong, Peoples R China.
   Guo, Zikun; Li, Qixian; Zou, Yuchang; Cai, Jingyao, Guangdong Univ Finance, Sch Natl Finance, Guangzhou, Guangdong, Peoples R China.
   Guo, Wei, Guangdong Univ Finance, Sch Credit Management, Guangzhou, Guangdong, Peoples R China.},
