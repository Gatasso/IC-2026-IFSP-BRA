@inproceedings{ WOS:001481304900059,
Author = {Guo, Zikun and Guo, Wei and Li, Qixian and Zou, Yuchang and Cai, Jingyao},
Book-Group-Author = {IEEE},
Title = {FN-Agents: Analysis of Exchange Rate Volatility Prediction Based on
   Multi-Agent Systems},
Booktitle = {2024 5TH INTERNATIONAL CONFERENCE ON COMPUTERS AND ARTIFICIAL
   INTELLIGENCE TECHNOLOGY, CAIT},
Year = {2024},
Pages = {350-355},
Note = {5th International Conference on Computers and Artificial Intelligence
   Technology-CAIT, Hangzhou, PEOPLES R CHINA, DEC 20-22, 2024},
Organization = {Institute of Electrical and Electronics Engineers Inc; Zhejiang
   University - Zhijiang Campus},
Abstract = {Exchange rate prediction is challenging. While large language models
   (LLMs) offer new approaches, their lack of domain-specific fine-tuning
   hinders effective assessment of factors influencing exchange rates. To
   address this, we propose FN-Agents-a framework integrating technologies
   such as vector databases, Retrieval-Augmented Generation(RAG), and
   self-reflection-to enable LLMs to better utilize external resources for
   exchange rate tasks. FN-Agents assists LLMs in acquiring expert
   knowledge, learning through self-reflection, building fine-tuned
   datasets, and ultimately generating interpretable core feature sets
   autonomously. Experiments demonstrate that FN-Agents excels in feature
   selection and enhances the predictive accuracy of mainstream models.},
