@inproceedings{ WOS:001672943800014,
Author = {Sarellano Acevedo, Andres and Diaz Arenas, Ivan Eric and Limon, Valeria
   Enriquez and Montemayor Marroquin, Guillermo and Maldonado Mata, Abraham
   de Jesus and Muboz Ubando, Luis Alberto},
Book-Group-Author = {IEEE},
Title = {LLMs for Embodied Robotics: A comparative analysis on augmentation
   methods between an embedded AI computer and consumer-grade hardware for
   Autonomous Navigation},
Booktitle = {2025 LATIN AMERICAN ROBOTICS SYMPOSIUM, LARS},
Series = {IEEE Latin American Robotics Symposium},
Year = {2025},
Note = {2025 Latin American Robotics Symposium-LARS-Annual, Monterrey, MEXICO,
   OCT 29-NOV 01, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Large Language Model (LLM) Augmentation methods have introduced the
   capability of employing Agentic AI systems in Autonomous Vehicles (AVs)
   for autonomous navigation purposes. Such systems typically are
   implemented using cloud-based computing and are not exposed to the
   hardware limitations that embodied robotics suffers from. For this
   reason, we present a comparative analysis on augmentation methods for a
   real-time Agentic AI systems for AVs. In particular we: (1) evaluated
   the real-time feasibility of employing a single-board AI embedded
   computer for LLMs against consumergraded hardware and (2) compared the
   accuracy of multiple LLM responses on spatial queries following two
   different augmentation methods, i.e., Retrieval-Augmented Memory for
   Embodied Robots (ReMEmbR) and Cache Augmented Generation (CAG). Our
   tests indicated that the Jetson Orin AGX embedded computer was incapable
   of generating real-time performance for position related queries, and
   the consumergraded hardware demonstrated that models with a higher
   number of parameters seemed to improve precision when using CAG as the
   augmentation method.},
