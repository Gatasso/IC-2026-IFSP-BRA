Editor = {Anya, O and Lazem, S and Saleh, M and Nkwo, MS and Gamundani, AM and Ogunyemi, AA and Isafiade, OE},
Title = {From A to Ashe: Designing for Layered Meaning in Diasporic Knowledge
   Systems},
Booktitle = {PROCEEDINGS OF THE FIFTH BIENNIAL AFRICAN HUMAN-COMPUTER INTERACTION
   CONFERENCE, AFRICHI 2025},
Year = {2025},
