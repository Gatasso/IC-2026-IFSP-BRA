@article{ WOS:001724447300001,
Author = {Yang, Hao and Zhang, Chijun and Yang, Feiyang and Ertem, Melissa Zeynep
   and Zhang, Xinwei and Wang, Qi and Guan, Wenze and Wang, Haoyang},
Title = {Large language models enhance reinforcement learning for public health
   resource allocation},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {195},
Month = {JUN},
Abstract = {Efficient resource allocation is crucial to prevent healthcare overload
   during public health emergencies. However, existing methods are limited
   by static single-period models, manual preprocessing of heterogeneous
   data, and suboptimal solvers. To address these, we propose a
   multi-period dynamic framework that incorporates regional prioritization
   and adapts to evolving epidemic severity, while achieving end-to-end
   automation through a hy brid agent integrating an enhanced Q-learning
   variant (QL-DA) with large language models (LLMs): QL-DA enables stable
   multi-objective optimization via dynamic exploration and adaptive
   normalization, while LLMs with retrieval-augmented generation (RAG)
   automate dynamic ingestion and normalization of multi-source data.
   Validated on Hong Kong COVID-19 datasets, our approach achieves lower
   operational costs and improved equity, providing a deployable
   decision-support system for emergency response.},
