@inproceedings{ WOS:001597593600148,
Author = {Agrawal, Shweta and (Tony) Li, He Nan and Lu, Lucas},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {LLM Interpretability: Tracing how LLMs answer factual queries and math
   questions},
Booktitle = {2025 IEEE CONFERENCE ON ARTIFICIAL INTELLIGENCE, CAI},
Year = {2025},
Pages = {853-858},
Note = {2025 Conference on Artificial Intelligence-CAI-Annual, Santa Clara, CA,
   MAY 05-07, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {In this paper, we study how LLMs like GPT store and retrieve facts to
   answer factual queries. Using a pretrained GPT-2 model, we evaluate
   factual accuracy on knowledge datasets, math questions, and hand-crafted
   prompts, employing metrics such as weighted first token accuracy, F1
   score for token overlap, perplexity, and BLEU. We leverage
   interpretability techniques like attention visualization, logit-lens
   analysis, and causal tracing to identify layers responsible for
   knowledge retrieval. To enhance the model's factual and mathematical
   capabilities, we implement prompt engineering, retrieval-augmented
   generation (RAG), and fine-tuning, comparing their impact on accuracy
   and fact retrieval mechanisms.},
