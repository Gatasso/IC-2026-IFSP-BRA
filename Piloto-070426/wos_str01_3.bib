@inproceedings{ WOS:001615394500007,
Author = {Reddy, G. Sai Linisha and Kankhara, Mounil Hiren and Maheshwari, Mridul
   and Bansal, Swayam and Kapoor, Rishit and Reddy, Himesh M. and Kumar, M.
   Bagesh},
Editor = {Rambelli, G and Ilievski, F and Bolognesi, M and Sommerauer, P},
Title = {Simulating Emotional Intelligence in LLMs through Behavioral
   Conditioning and Analogical Retrieval},
Booktitle = {PROCEEDINGS OF THE 2ND WORKSHOP ON ANALOGICAL ABSTRACTION IN COGNITION,
   PERCEPTION, AND LANGUAGE, ANALOGY-ANGLE II},
Year = {2025},
