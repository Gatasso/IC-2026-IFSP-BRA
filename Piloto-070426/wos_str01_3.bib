@article{ WOS:001588405800001,
Author = {Yu, Chunyang and Chen, Yue and Wang, Luyu and Yan, Tianxin},
Title = {Reconstructed generative design for industrial products enabled by a RAG
   engine},
Journal = {JOURNAL OF ENGINEERING DESIGN},
Year = {2025},
Month = {2025 OCT 4},
Abstract = {Iterative development is crucial in industrial design, yet it remains a
   time-intensive process - especially for complex products where balancing
   system-level aesthetics with component-specific functionality presents a
   persistent challenge. Traditional design methodologies often fail to
   reconcile these global and local perspectives efficiently, resulting in
   compromised workflows and sub-optimal solutions. This study introduces
   BrepRAG, an innovative design framework that combines
   Retrieval-Augmented Generation (RAG) with Brep model transformation to
   bridge this critical gap. BrepRAG empowers designers to modify local
   components while preserving global design integrity, enabling seamless
   harmonisation of macro-scale aesthetics and micro-scale precision. The
   framework further accelerates decision-making through a global scheme
   scoring mechanism, which quantitatively evaluates design alternatives to
   maintain coherence across all levels. A detailed case study validates
   BrepRAG's practical efficacy, demonstrating significant reductions in
   iteration cycles while achieving superior design outcomes. This
   framework advances industrial design practices by unifying creative
   flexibility with technical rigour, offering a scaleable solution for
   complex product development.},
