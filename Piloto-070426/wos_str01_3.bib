@inproceedings{ WOS:001562425500005,
Author = {Tang, Jinwei and Qin, Jiayin and Thorat, Kiran and Chen Zhu-Tian and
   Cao, Yu and Zhao, Yang (Katie) and Ding, Caiwen},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {HiVeGen - Hierarchical LLM-based Verilog Generation for Scalable Chip
   Design},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON LLM-AIDED DESIGN, ICLAD},
Year = {2025},
Pages = {30-36},
Note = {1st International Conference on LLM-Aided Design-ICLAD, Stanford, CA,
   JUN 26-27, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; IEEE Council on
   Electronic Design Automation; IEEE Solid State Circuits Society;
   Advanced Micro Devices; Cadence Inc; Google Incorporated; Intel
   Corporation; International Buisness Machines Corp; Mediatek Llc; Nvidia
   Corporation; NXP Semiconductors; Qualcomm; Siemens AG; Synopsys Inc;
   Taiwan Semiconductor Manufacturing Company},
Abstract = {With Large Language Models (LLMs) recently demonstrating impressive
   proficiency in code generation, it is promising to extend their
   abilities to Hardware Description Language (HDL). However, LLMs tend to
   generate single HDL code blocks rather than hierarchical structures for
   hardware designs, leading to hallucinations, particularly in complex
   designs like Domain-Specific Accelerators (DSAs). To address this, we
   propose HiVeGen, a hierarchical LLM-based Verilog generation framework
   that decomposes generation tasks into LLM-manageable hierarchical
   submodules. HiVeGen further harnesses the advantages of such
   hierarchical structures by integrating automatic Design Space
   Exploration (DSE) into hierarchy-aware prompt generation, introducing
   weight-based retrieval to enhance code reuse, and enabling real-time
   human-computer interaction to lower error-correction cost, significantly
   improving the quality of generated designs.},
Publisher = {IEEE COMPUTER SOC},
Address = {10662 LOS VAQUEROS CIRCLE, PO BOX 3014, LOS ALAMITOS, CA 90720-1264 USA},
Type = {Proceedings Paper},
