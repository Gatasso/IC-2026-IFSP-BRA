@article{ WOS:001537085600001,
Author = {Fu, Jiashun and Liu, Xuyang and Cai, Wensheng and Fu, Haohao and Shao,
   Xueguang},
Title = {SpeLL: An Agent for Natural Language-Driven Intelligent Spectral
   Modeling},
