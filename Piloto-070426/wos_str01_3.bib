Title = {POTS - A Polyparadigmatic Ontology Term Search with Fine-Grained
   Context Steering using Hyper-Level Vector Spaces},
Booktitle = {COMPANION PROCEEDINGS OF THE ACM WEB CONFERENCE 2025, WWW COMPANION 2025},
