@inproceedings{ WOS:001611618300114,
Author = {Xian, Ziting and Gu, Jiawei and Li, Lingbo and Liang, Shangsong},
Editor = {Che, W and Nabende, J and Shutova, E and Pilehvar, MT},
Title = {MolRAG: Unlocking the Power of LLMs for Molecular Property Prediction},
Booktitle = {PROCEEDINGS OF THE 63RD ANNUAL MEETING OF THE ASSOCIATION FOR
   COMPUTATIONAL LINGUISTICS, VOL 1: LONG PAPERS},
Year = {2025},
Pages = {15513-15531},
Note = {63rd Association for Computational Linguistics Meeting-ACL-Annual,
   Vienna, AUSTRIA, JUL 27-AUG 01, 2025},
Abstract = {Recent LLMs exhibit limited effectiveness on molecular property
   prediction task due to the semantic gap between molecular
   representations and natural language, as well as the lack of
   domain-specific knowledge. To address these challenges, we propose
   MolRAG, a Retrieval-Augmented Generation framework integrating
   Chain-of-Thought reasoning for molecular property prediction. MolRAG
   operates by retrieving structurally analogous molecules as contextual
   references to guide stepwise knowledge reasoning through chemical
   structureproperty relationships. This dual mechanism synergizes
   molecular similarity analysis with structured inference, while
   generating humaninterpretable rationales grounded in domain knowledge.
   Experimental results show MolRAG outperforms pre-trained LLMs on four
   datasets, and even matches supervised methods, achieving performance
   gains of 1.1\%-45.7\% over direct prediction approaches, demonstrating
   versatile effectiveness. Our code is available at
   https://github.com/AcaciaSin/MolRAG.},
