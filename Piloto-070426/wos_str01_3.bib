@inproceedings{ WOS:001594400600020,
Author = {Yang, Chao and Wang, Deliang and Chen, Gaowei},
Book-Group-Author = {ACM},
Title = {Chat-LAD: Enhancing Teacher Understanding of Learning Analytics
   Dashboard with AI-Empowered Explanations},
Booktitle = {PROCEEDINGS OF THE TWELFTH ACM CONFERENCE ON LEARNING @ SCALE, L@S 2025},
Year = {2025},
Pages = {197-201},
Note = {2025 Conference on Learning@Scale-L@S, Palermo, ITALY, JUL 21-23, 2025},
Organization = {Association for Computing Machinery},
Abstract = {Despite the great potential of learning analytics dashboards (LADs) in
   presenting complex learning data to support teacher reflection and
   professional learning, several challenges persist. These include
   cognitive overload due to visualization complexities, limited data
   interpretation, and a lack of personalized support, which hinder the
   effective use for reflective practices and decision-making, especially
   for users with limited digital literacy. To address these issues, this
   study introduces Chat-LAD, an artificial intelligence (AI)-powered
   chatbot that leverages generative AI and multi-agent retrieval-augmented
   generation (RAG) to provide real-time explanations tailored to user
   needs, enhancing teachers' understanding of LADs for classroom discourse
   analysis. A case study demonstrates Chat-LAD's capabilities in
   clarifying visual elements, offering context-aware responses, and
   providing personalized feedback based on user historical data. This
   study facilitates a transition in human-AI interaction from a singular,
   passive text-based approach to a multimodal, collaborative framework,
   highlighting the educational value of generative AI in enhancing visual
   interpretability in the use of LADs.},
