@inproceedings{ WOS:001575462500083,
Author = {Cetin, Uzay and Colakgil, Ilhan Emre},
Book-Group-Author = {IEEE},
Title = {Comparison of Embedding Models for Turkish Financial RAG Applications},
Booktitle = {2025 33RD SIGNAL PROCESSING AND COMMUNICATIONS APPLICATIONS CONFERENCE,
   SIU},
Series = {Signal Processing and Communications Applications Conference},
Year = {2025},
Note = {33rd Conference on Signal Processing and Communications
   Applications-SIU-Annual, Istanbul, TURKIYE, JUN 25-28, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {In this study, embedding models used in the retrieval phase, which play
   a critical role in Retrieval-Augmented Generation (RAG) systems, are
   compared on financial texts. The performances of open and closed source
   models are analyzed and their advantages, disadvantages, and usage
   scenarios are evaluated. In addition, important factors such as security
   and copyright risks of open source models and access restrictions of
   closed source models are discussed. Our study presents findings to
   improve the accuracy, reliability, and efficiency of RAG systems in the
   financial domain. In the financial sector, where fast access to accurate
   information is critical, the effects of embedding model selection are
   examined in detail and conclusions are drawn to guide future research
   and industrial applications.},
