@inproceedings{ WOS:001661443400028,
Author = {Lan, Tianwei and Nait-Abdesselam, Farid},
Book-Group-Author = {IEEE},
Title = {Adversarial Agents: LLM-Powered Attacks and Defenses for Android Malware
   Detectors},
Booktitle = {2025 IEEE CONFERENCE ON DEPENDABLE AND SECURE COMPUTING, DSC},
Year = {2025},
Pages = {181-188},
Note = {2025 Conference on Dependable and Secure Computing-DSC-Annual, Taipei,
   TAIWAN, OCT 18-20, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {The growing sophistication and prevalence of Android malware have
   necessitated the deployment of machine learning (ML) models for scalable
   and effective threat detection. Despite their success, these models
   remain vulnerable to adversarial attacks, where subtle input
   perturbations can mislead classifiers while preserving malicious intent.
   In this work, we propose LAMLAD, a novel adversarial attack framework
   that harnesses the generative and reasoning capabilities of large
   language models (LLMs) to evade ML-based Android malware detectors.
   LAMLAD features a dual-agent architecture comprising an LLM-based
   manipulator and analyzer. To improve contextual relevance and reduce
   query overhead, it integrates retrieval-augmented generation (RAG) into
   the decision-making pipeline. We evaluate LAMLAD against three
   representative ML-based Android malware detectors and benchmark its
   performance against two state-of-the-art adversarial attack methods.
   Experimental results show that LAMLAD achieves a 97\% attack success
   rate (ASR) with an average of only three attempts per adversarial
   example, highlighting its efficiency and practicality in real-world
   settings. Additionally, we propose an adversarial training defense that
   reduces ASR by over 30\% on average, demonstrating its effectiveness in
   enhancing model robustness against LAMLAD attacks.},
Publisher = {IEEE},
Address = {345 E 47TH ST, NEW YORK, NY 10017 USA},
