@article{ WOS:001574689200001,
Author = {Chang, Zhi-Xing and Guo, Wei and Wang, Lei and Shao, Hong-Yu and Zhang,
   Yuan-Rong and Guo, Xiao},
Title = {A generation framework of conceptual solutions integrating link
   prediction and large language model},
Journal = {JOURNAL OF ENGINEERING DESIGN},
Year = {2025},
Month = {2025 SEP 12},
Abstract = {In the increasingly intense market environment, both the innovativeness
   and the generating speed of conceptual solutions is vital for companies.
   In previous studies, researchers have proposed various methods for
   identifying innovative ideas. However, the transition from these ideas
   to conceptual solutions still relies on designers' expertise and manual
   efforts. To address this challenge, we propose a generation framework of
   conceptual solutions. This framework employs semantic embedding methods
   to retrieve technologies relevant to requirements and utilises link
   prediction methods to uncover innovation opportunities. Subsequently,
